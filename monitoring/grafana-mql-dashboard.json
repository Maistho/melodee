        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.99, rate(mql_query_duration_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "title": "Query Latency Percentiles",
      "type": "timeseries"
    },
