@inject ILocalizationService LocalizationService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@implements IDisposable

<RadzenDropDown @bind-Value="@_selectedCulture"
                Data="@LocalizationService.SupportedCultures"
                TextProperty="DisplayName"
                ValueProperty="Name"
                Change="@OnCultureChanged"
                Style="@Style"
                Class="@Class"
                Placeholder="@Placeholder" />

@code {
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Select Language";
    
    private string _selectedCulture = "en-US";
    private bool _isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        _selectedCulture = LocalizationService.CurrentCulture.Name;
        LocalizationService.CultureChanged += OnCultureChangedExternally;
        _isInitialized = true;
        await base.OnInitializedAsync();
    }

    private async Task OnCultureChanged(object value)
    {
        if (!_isInitialized || value is not string cultureCode)
        {
            return;
        }

        try
        {
            // Set cookie for the middleware to read on next request
            // The cookie name must match what RequestLocalizationMiddleware expects
            var cookieValue = $"c={cultureCode}|uic={cultureCode}";
            await JSRuntime.InvokeVoidAsync("eval", 
                $"document.cookie = '.AspNetCore.Culture={Uri.EscapeDataString(cookieValue)}; path=/; max-age=31536000; samesite=lax'");
            
            // Also update localStorage for the LocalizationService
            await LocalizationService.SetCultureAsync(cultureCode);
            
            // Force full page reload to let middleware apply the new culture
            NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error changing culture: {ex.Message}");
        }
    }

    private void OnCultureChangedExternally(System.Globalization.CultureInfo culture)
    {
        _selectedCulture = culture.Name;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LocalizationService.CultureChanged -= OnCultureChangedExternally;
    }
}
