@using Melodee.Mql.Models
@using Melodee.Mql.Constants
@using Microsoft.AspNetCore.Components.Rendering

<div class="mql-field-reference">
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="Songs">
                <FieldTable EntityType="songs" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Albums">
                <FieldTable EntityType="albums" />
            </RadzenTabsItem>
            <RadzenTabsItem Text="Artists">
                <FieldTable EntityType="artists" />
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</div>

@code {
    private sealed class FieldTable : ComponentBase
    {
        [Parameter]
        public string EntityType { get; set; } = string.Empty;

        protected override void BuildRenderTree(RenderTreeBuilder builder)
        {
            var fields = GetFieldsForEntity(EntityType);

            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "field-table-container");

            builder.OpenElement(2, "table");
            builder.AddAttribute(3, "class", "field-table");
            builder.AddAttribute(4, "style", "width: 100%; border-collapse: collapse; font-size: 0.875rem;");

            // Header
            builder.OpenElement(5, "thead");
            builder.OpenElement(6, "tr");
            builder.AddAttribute(7, "style", "background: var(--rz-base-200);");
            
            builder.OpenElement(8, "th");
            builder.AddAttribute(9, "style", "padding: 0.75rem; text-align: left; border-bottom: 2px solid var(--rz-base-300);");
            builder.AddContent(10, "Field");
            builder.CloseElement();

            builder.OpenElement(11, "th");
            builder.AddAttribute(12, "style", "padding: 0.75rem; text-align: left; border-bottom: 2px solid var(--rz-base-300);");
            builder.AddContent(13, "Type");
            builder.CloseElement();

            builder.OpenElement(14, "th");
            builder.AddAttribute(15, "style", "padding: 0.75rem; text-align: left; border-bottom: 2px solid var(--rz-base-300);");
            builder.AddContent(16, "Example");
            builder.CloseElement();

            builder.OpenElement(17, "th");
            builder.AddAttribute(18, "style", "padding: 0.75rem; text-align: left; border-bottom: 2px solid var(--rz-base-300);");
            builder.AddContent(19, "Description");
            builder.CloseElement();

            builder.CloseElement(); // tr
            builder.CloseElement(); // thead

            // Body
            builder.OpenElement(20, "tbody");
            foreach (var field in fields)
            {
                builder.OpenElement(21, "tr");
                builder.AddAttribute(22, "style", "border-bottom: 1px solid var(--rz-base-300);");

                builder.OpenElement(23, "td");
                builder.AddAttribute(24, "style", "padding: 0.5rem 0.75rem;");
                builder.OpenElement(25, "code");
                builder.AddContent(26, field.Name);
                builder.CloseElement();
                if (field.Aliases?.Length > 0)
                {
                    builder.AddContent(27, $" ({string.Join(", ", field.Aliases)})");
                }
                builder.CloseElement();

                builder.OpenElement(28, "td");
                builder.AddAttribute(29, "style", "padding: 0.5rem 0.75rem;");
                builder.AddContent(30, GetTypeLabel(field.Type));
                builder.CloseElement();

                builder.OpenElement(31, "td");
                builder.AddAttribute(32, "style", "padding: 0.5rem 0.75rem;");
                builder.OpenElement(33, "code");
                builder.AddContent(34, field.Example);
                builder.CloseElement();
                builder.CloseElement();

                builder.OpenElement(35, "td");
                builder.AddAttribute(36, "style", "padding: 0.5rem 0.75rem; color: var(--rz-text-secondary-color);");
                builder.AddContent(37, field.Description);
                builder.CloseElement();

                builder.CloseElement(); // tr
            }
            builder.CloseElement(); // tbody

            builder.CloseElement(); // table
            builder.CloseElement(); // div
        }

        private static IEnumerable<FieldInfo> GetFieldsForEntity(string entityType)
        {
            return entityType.ToLowerInvariant() switch
            {
                "songs" => new[]
                {
                    new FieldInfo("title", MqlFieldType.String, "title:Time", "Song title"),
                    new FieldInfo("artist", MqlFieldType.String, "artist:Beatles", "Artist name (via album)"),
                    new FieldInfo("album", MqlFieldType.String, "album:Abbey Road", "Album name"),
                    new FieldInfo("genre", MqlFieldType.ArrayString, "genre:Rock", "Genre tags"),
                    new FieldInfo("mood", MqlFieldType.ArrayString, "mood:Chill", "Mood tags"),
                    new FieldInfo("year", MqlFieldType.Number, "year:>=1970", "Release year"),
                    new FieldInfo("duration", MqlFieldType.Number, "duration:<300", "Duration in seconds"),
                    new FieldInfo("bpm", MqlFieldType.Number, "bpm:>120", "Beats per minute"),
                    new FieldInfo("rating", MqlFieldType.Number, "rating:>=4", "User rating (requires login)"),
                    new FieldInfo("plays", MqlFieldType.Number, "plays:>10", "Play count (requires login)"),
                    new FieldInfo("starred", MqlFieldType.Boolean, "starred:true", "Starred status (requires login)"),
                    new FieldInfo("starredAt", MqlFieldType.Date, "starredAt:last-week", "When starred (requires login)"),
                    new FieldInfo("lastPlayedAt", MqlFieldType.Date, "lastPlayedAt:-30d", "Last played (requires login)"),
                    new FieldInfo("added", MqlFieldType.Date, "added:last-month", "When added to library"),
                },
                "albums" => new[]
                {
                    new FieldInfo("album", MqlFieldType.String, "album:Abbey Road", "Album name"),
                    new FieldInfo("name", MqlFieldType.String, "name:Abbey Road", "Album name (alias)"),
                    new FieldInfo("artist", MqlFieldType.String, "artist:Beatles", "Artist name"),
                    new FieldInfo("year", MqlFieldType.Number, "year:1970", "Release year"),
                    new FieldInfo("duration", MqlFieldType.Number, "duration:<3600", "Total duration in seconds"),
                    new FieldInfo("genre", MqlFieldType.ArrayString, "genre:Rock", "Genre tags"),
                    new FieldInfo("mood", MqlFieldType.ArrayString, "mood:Energetic", "Mood tags"),
                    new FieldInfo("rating", MqlFieldType.Number, "rating:>=4", "User rating (requires login)"),
                    new FieldInfo("plays", MqlFieldType.Number, "plays:>0", "Play count (requires login)"),
                    new FieldInfo("starred", MqlFieldType.Boolean, "starred:true", "Starred (requires login)"),
                    new FieldInfo("starredAt", MqlFieldType.Date, "starredAt:last-year", "When starred (requires login)"),
                    new FieldInfo("added", MqlFieldType.Date, "added:-6months", "When added to library"),
                },
                "artists" => new[]
                {
                    new FieldInfo("artist", MqlFieldType.String, "artist:Pink Floyd", "Artist name"),
                    new FieldInfo("name", MqlFieldType.String, "name:Miles Davis", "Artist name (alias)"),
                    new FieldInfo("rating", MqlFieldType.Number, "rating:>=4", "User rating (requires login)"),
                    new FieldInfo("starred", MqlFieldType.Boolean, "starred:true", "Starred (requires login)"),
                    new FieldInfo("starredAt", MqlFieldType.Date, "starredAt:last-year", "When starred (requires login)"),
                    new FieldInfo("plays", MqlFieldType.Number, "plays:>0", "Total play count"),
                    new FieldInfo("added", MqlFieldType.Date, "added:last-year", "When added to library"),
                },
                _ => Array.Empty<FieldInfo>()
            };
        }

        private static string GetTypeLabel(MqlFieldType type)
        {
            return type switch
            {
                MqlFieldType.String => "Text",
                MqlFieldType.Number => "Number",
                MqlFieldType.Boolean => "Boolean",
                MqlFieldType.Date => "Date",
                MqlFieldType.ArrayString => "String Array",
                _ => type.ToString()
            };
        }

        private sealed record FieldInfo(
            string Name,
            MqlFieldType Type,
            string Example,
            string Description,
            string[]? Aliases = null);
    }
}

<style>
    .mql-field-reference {
        padding: 1rem;
    }

    .field-table-container {
        overflow-x: auto;
    }

    .field-table th,
    .field-table td {
        padding: 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--rz-base-300);
    }

    .field-table tbody tr:hover {
        background: var(--rz-base-200);
    }
</style>
