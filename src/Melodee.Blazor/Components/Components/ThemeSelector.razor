@using Melodee.Common.Configuration
@using Melodee.Common.Constants
@using Melodee.Common.Models
@using Melodee.Common.Services
@inject IThemeService ThemeService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject Radzen.ThemeService RadzenThemeService
@inject IThemeClientService ThemeClientService
@implements IDisposable

<RadzenDropDown @bind-Value="@_selectedTheme"
                Data="@_availableThemes"
                TextProperty="Text"
                ValueProperty="Value"
                Change="@OnThemeChangedAsync"
                Style="width: 100%"
                Loading="@_loading"/>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    private string _selectedTheme = "melodee-dark";
    private bool _loading = true;
    private List<ThemeOption> _availableThemes = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadThemesAsync();
        RadzenThemeService.ThemeChanged += OnRadzenThemeChanged;
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Value) && _selectedTheme != Value)
        {
            _selectedTheme = Value;
        }
        base.OnParametersSet();
    }

    private async Task LoadThemesAsync()
    {
        try
        {
            _loading = true;
            var themes = await ThemeService.DiscoverThemePacksAsync();
            
            _availableThemes = themes.Select(t => new ThemeOption(
                t.Id,
                t.Name + (t.HasWarnings ? " ⚠️" : "")
            )).ToList();
            
            // Set current theme if available
            if (!string.IsNullOrEmpty(Value))
            {
                _selectedTheme = Value;
            }
            else
            {
                // Default to system default theme
                var config = await ConfigurationFactory.GetConfigurationAsync();
                _selectedTheme = config.GetValue<string>(SettingRegistry.SystemDefaultTheme) ?? "melodee-dark";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading themes: {ex.Message}");
            // Fallback to built-in themes
            _availableThemes = [
                new ThemeOption("melodee-dark", "Melodee Dark"),
                new ThemeOption("light", "Light"),
                new ThemeOption("dark", "Dark")
            ];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnThemeChangedAsync(object value)
    {
        if (value is not string newTheme || string.IsNullOrEmpty(newTheme))
        {
            return;
        }

        _selectedTheme = newTheme;
        
        // Load and apply the theme
        var theme = await ThemeService.GetThemePackAsync(newTheme);
        if (theme != null)
        {
            await ThemeClientService.ApplyThemeAsync(theme);
        }
        
        await ValueChanged.InvokeAsync(newTheme);
    }

    private void OnRadzenThemeChanged()
    {
        var theme = RadzenThemeService.Theme;
        if (!string.IsNullOrEmpty(theme) && _selectedTheme != theme)
        {
            _selectedTheme = theme;
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        RadzenThemeService.ThemeChanged -= OnRadzenThemeChanged;
    }

    private record ThemeOption(string Value, string Text);
}
