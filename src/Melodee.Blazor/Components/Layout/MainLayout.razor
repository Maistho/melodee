@inherits LayoutComponentBase
@using System.Drawing
@using System.Globalization
@using Melodee.Common.Enums
@using Microsoft.AspNetCore.Components.Authorization
@using HttpUtility = System.Web.HttpUtility

@implements IDisposable
@inject LibraryService LibraryService
@inject MainLayoutProxyService MainLayoutProxyService
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject IMelodeeConfigurationFactory MelodeeConfigurationFactory
@inject RequestActivityService RequestActivityService
@inject ILocalizationService LocalizationService

<RadzenComponents @rendermode="InteractiveServer"/>

<RadzenNotification/>
<RadzenTooltip/>
<RadzenContextMenu/>

<AuthorizeView>
    <NotAuthorized>
        @Body
    </NotAuthorized>
    <Authorized>
        <RadzenLayout dir="@LocalizationService.GetTextDirection()" class="@(_isRtl ? "rtl-layout" : "ltr-layout")">
            <RadzenHeader>
                <RadzenRow JustifyContent="JustifyContent.Start" AlignItems="AlignItems.Center" Gap="0">
                    <RadzenColumn Size="5">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0">
                            <RadzenSidebarToggle Click="@SidebarToggleClick"></RadzenSidebarToggle>
                            <RadzenText Text="@_siteTitle" TextStyle="TextStyle.H6" class="hide-below-480" Style="margin-top:13px;"/>
                        </RadzenStack>
                    </RadzenColumn>
                    <RadzenColumn Size="7">
                        <RadzenStack
                            AlignItems="AlignItems.Center"
                            Orientation="Orientation.Horizontal"
                            JustifyContent="JustifyContent.End">
                            <RadzenProgressBar Visible="@MainLayoutProxyService.ShowSpinner"
                                               Style="width:100px;"
                                               ProgressBarStyle="ProgressBarStyle.Info"
                                               Value="100"
                                               ShowValue="false"
                                               Mode="ProgressBarMode.Indeterminate"/>
                            <DebounceInput class="rz-textbox"
                                           style="width:200px;"
                                           autocomplete="off"
                                           @bind-Value="@_debounceInputValue"
                                           @bind-Value:event="OnInput"
                                           placeholder="@LocalizationService.Localize("Common.Search")"
                                           DebounceTime="2000"
                                           MinLength="2"
                                           OnValueChanged="@DoSearchAsync"
                                           ForceNotifyByEnter="true"
                                           ForceNotifyOnBlur="true"/>
                             <RadzenStack Orientation="Orientation.Vertical"
                                          Gap="0.5rem"
                                          class="rz-p-sm-2">
                             </RadzenStack>
                             <!-- Removed RadzenAppearanceToggle to prevent theme conflicts with our ThemeService -->
                             <RadzenIcon Visible="@context.User.IsAdmin()" IconColor="@Colors.Warning" title="@LocalizationService.Localize("Admin.YouAreAdmin")" Icon="server_person" />
                            <RadzenIcon Visible="@(!context.User.IsAdmin() && context.User.IsEditor())" IconColor="@Colors.Warning" title="@LocalizationService.Localize("Admin.YouAreEditor")" Icon="box_edit" />
                            <RadzenProfileMenu>
                                <ChildContent>
                                    <RadzenProfileMenuItem Path="@($"/user/{context.User.ToApiKey()}")" Icon="person" Text="@LocalizationService.Localize("Auth.AboutMe")"/>
                                    <RadzenProfileMenuItem Path="/account/profile" Icon="settings" Text="@LocalizationService.Localize("Navigation.Profile")"/>
                                    <RadzenProfileMenuItem Path="/account/logout" Text="@LocalizationService.Localize("Navigation.Logout")" Value="Logout"
                                                           Icon="power_settings_new"/>
                                </ChildContent>
                                <Template>
                                    <RadzenImage
                                        Path="@($"/images/{context.User.ToApiKey()}/{MelodeeConfiguration.DefaultThumbNailSize}")"
                                        style="border-radius:5px;height:40px;width:40px;"/>
                                </Template>
                            </RadzenProfileMenu>
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenHeader>
            <RadzenSidebar Style="width:160px;" @bind-Expanded="@_sidebarExpanded">
                <RadzenPanelMenu>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Dashboard")" Path="/" Icon="dashboard"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Stats")" Path="/stats" Icon="bar_chart"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Artists")" Path="/data/artists" Icon="artist"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Albums")" Path="/data/albums" Icon="album"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Charts")" Path="/charts" Icon="format_list_numbered"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Libraries")" Path="/data/libraries" Icon="library_music"
                                         Visible="@AuthService.IsAdmin"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.NowPlaying")" Path="/activity/nowplaying" Icon="sound_sampler"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Playlists")" Path="/data/playlists" Icon="playlist_play"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.RadioStations")" Path="/data/radiostations" Icon="radio"/>
                    <RadzenPanelMenuItem Path="/requests" Icon="assignment">
                      <Template>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                          <span>@LocalizationService.Localize("Navigation.Requests")</span>
                          @if (_hasUnreadRequests)
                          {
                            <RadzenBadge BadgeStyle="BadgeStyle.Danger" IsPill="true" Text=" " Style="width: 8px; height: 8px; min-width: 8px; padding: 0;"/>
                          }
                        </RadzenStack>
                      </Template>
                    </RadzenPanelMenuItem>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Songs")" Path="/data/songs" Icon="music_note"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Shares")" Path="/data/shares" Icon="share"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Users")" Path="/data/users" Icon="group"/>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Admin")" Icon="admin_panel_settings" IconColor="@Colors.Danger"
                                         Visible="@AuthService.IsAdmin">
                        <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Dashboard")" Path="/admin/dashboard" Icon="dashboard"/>
                        <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Media")" Icon="perm_media">
                            @foreach (var mediaLibraryInfo in _mediaLibraryInfos)
                            {
                                <RadzenPanelMenuItem Text="@mediaLibraryInfo.Text" Path="@mediaLibraryInfo.Path"
                                                     Icon="folder"/>
                            }
                        </RadzenPanelMenuItem>
                        <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.MediaArtists")" Path="/admin/mediaartists" Icon="artist"/>
                        <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Jobs")" Path="/admin/jobs" Icon="checklist"/>
                        <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.Settings")" Path="/admin/settings" Icon="settings"/>
                    </RadzenPanelMenuItem>
                    <RadzenPanelMenuItem Text="@LocalizationService.Localize("Navigation.About")" Path="/about" Icon="info" IconColor="@Colors.Secondary"/>
                </RadzenPanelMenu>
            </RadzenSidebar>
            <RadzenBody Style="margin: 10px; padding:3px;">
                @Body
            </RadzenBody>
        </RadzenLayout>
    </Authorized>
</AuthorizeView>

@code {
    bool _sidebarExpanded = true;
    string _siteTitle = string.Empty;
    bool _hasUnreadRequests;
    Timer? _activityTimer;
    bool _isRtl = false;

    string _debounceInputValue = "";

    MediaLibraryInfo[] _mediaLibraryInfos = [];

    private sealed record MediaLibraryInfo(string Text, string Path);

    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        // Initialize RTL state
        _isRtl = LocalizationService.IsRightToLeft();

        // Subscribe to culture changes
        LocalizationService.CultureChanged += OnCultureChanged;

        MainLayoutProxyService.HeaderChanged += OnHeaderChange;
        MainLayoutProxyService.SpinnerVisibleChanged += OnSpinnerChange;
    }

    private void OnCultureChanged(CultureInfo culture)
    {
        _isRtl = LocalizationService.IsRightToLeft();
        InvokeAsync(StateHasChanged);
    }

    private void OnHeaderChange(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnSpinnerChange(object? sender, EventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LocalizationService.CultureChanged -= OnCultureChanged;
        MainLayoutProxyService.HeaderChanged -= OnHeaderChange;
        MainLayoutProxyService.SpinnerVisibleChanged -= OnSpinnerChange;
        _activityTimer?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var configuration = await MelodeeConfigurationFactory.GetConfigurationAsync();
            _siteTitle = configuration.GetValue<string>(SettingRegistry.SystemSiteName) ?? "Melodee";

            _mediaLibraryInfos = (await LibraryService.ListMediaLibrariesAsync())
                .Data
                .Where(x => x.TypeValue is LibraryType.Inbound or LibraryType.Staging)
                .Select(x => new MediaLibraryInfo(x.Name, $"/media/library/{x.ApiKey}"))
                .ToArray();

            MainLayoutProxyService.ShowSpinner = false;

            await CheckUnreadRequestsAsync();
            _activityTimer = new Timer(async _ => await CheckUnreadRequestsAsync(), null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));

            StateHasChanged();
        }
    }

    private async Task CheckUnreadRequestsAsync()
    {
        try
        {
            var userId = AuthService.CurrentUser?.UserId() ?? 0;
            if (userId > 0)
            {
                _hasUnreadRequests = await RequestActivityService.HasUnreadAsync(userId);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Silently ignore errors in background polling
        }
    }

    private void SidebarToggleClick()
    {
        _sidebarExpanded = !_sidebarExpanded;
    }

    private void DoSearchAsync(string arg)
    {
        NavigationManager.NavigateTo($"/search/{HttpUtility.UrlEncode(arg)}", true);
    }

}
