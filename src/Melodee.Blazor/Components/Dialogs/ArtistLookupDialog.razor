@using Melodee.Blazor.Components.Pages
@using Melodee.Blazor.Controllers.Melodee.Models.ArtistLookup
@using Melodee.Common.Configuration
@using Melodee.Common.Models.SearchEngines
@using Melodee.Common.Plugins.SearchEngine
@using Melodee.Common.Services.SearchEngines

@inherits MelodeeComponentBase

@inject ArtistSearchEngineService ArtistSearchEngineService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenStack Gap="1rem">
    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="@L("ArtistLookup.ByName")">
                <RadzenStack Gap="1rem" class="rz-p-2">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <RadzenTextBox @bind-Value="@_searchText"
                                       Placeholder="@L("ArtistLookup.EnterArtistName")"
                                       Style="flex: 1"
                                       Name="SearchText"
                                       @onkeyup="@OnKeyUpAsync"
                                       Disabled="@_isLoading"/>
                        <RadzenButton Icon="search"
                                      Text="@L("Actions.Search")"
                                      Click="@SearchAsync"
                                      Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_searchText))"
                                      ButtonStyle="ButtonStyle.Primary"/>
                    </RadzenStack>
                </RadzenStack>
            </RadzenTabsItem>
            <RadzenTabsItem Text="@L("ArtistLookup.ByAmgId")">
                <RadzenStack Gap="1rem" class="rz-p-2">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                        <RadzenTextBox @bind-Value="@_amgIdText"
                                       Placeholder="@L("ArtistLookup.EnterAmgId")"
                                       Style="flex: 1"
                                       Name="AmgIdText"
                                       @onkeyup="@OnAmgIdKeyUpAsync"
                                       Disabled="@_isLoading"/>
                        <RadzenButton Icon="search"
                                      Text="@L("Actions.Search")"
                                      Click="@SearchByAmgIdAsync"
                                      Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_amgIdText))"
                                      ButtonStyle="ButtonStyle.Primary"/>
                    </RadzenStack>
                    <RadzenText Text="@L("ArtistLookup.AmghelpText")" class="rz-text-secondary" TextStyle="TextStyle.Caption"/>
                </RadzenStack>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>

    @if (_providers != null && _providers.Length > 0)
    {
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-mt-2">
            <RadzenLabel Text="@L("ArtistLookup.FilterByProvider")" Component="ProviderFilter"/>
            <RadzenDropDown @bind-Value="@_selectedProviderIds"
                            Data="@_providers.Where(p => p.IsEnabled)"
                            TextProperty="DisplayName"
                            ValueProperty="Id"
                            Multiple="true"
                            Placeholder="@L("ArtistLookup.AllEnabledProviders")"
                            Style="flex: 1"
                            Name="ProviderFilter"
                            AllowFiltering="false"/>
        </RadzenStack>
    }

    @if (_isLoading)
    {
        <RadzenStack AlignItems="AlignItems.Center" class="rz-p-4">
            <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate"/>
            <RadzenText Text="@L("ArtistLookup.Searching")" class="rz-text-secondary"/>
        </RadzenStack>
    }
    else if (_hasError)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">
            @L("ArtistLookup.SearchError")
        </RadzenAlert>
    }
    else if (_candidates != null && _candidates.Length > 0)
    {
        <RadzenStack Gap="0.5rem" class="rz-mt-2" Style="max-height: 400px; overflow-y: auto;">
            @foreach (var candidate in _candidates)
            {
                <RadzenCard class="candidate-card" Click="@(() => SelectCandidate(candidate))">
                    <RadzenStack Gap="0.5rem">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                            @if (!string.IsNullOrEmpty(candidate.ThumbnailUrl))
                            {
                                <RadzenImage Path="@candidate.ThumbnailUrl"
                                             Style="width: 48px; height: 48px; object-fit: cover;"
                                             AlternateText="@candidate.Name"/>
                            }
                            <RadzenStack Style="flex: 1">
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-font-weight-bold">
                                    @candidate.Name
                                </RadzenText>
                                @if (!string.IsNullOrEmpty(candidate.SortName) && candidate.SortName != candidate.Name)
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" class="rz-text-secondary">
                                        @candidate.SortName
                                    </RadzenText>
                                }
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-text-secondary">
                                    @L("ArtistLookup.FromProvider", candidate.ProviderDisplayName)
                                </RadzenText>
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" class="rz-mt-1">
                            @if (candidate.MusicBrainzId.HasValue)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@($"MB: {candidate.MusicBrainzId.Value.ToString()[..8]}...")"/>
                            }
                            @if (!string.IsNullOrEmpty(candidate.SpotifyId))
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@($"Spotify: {candidate.SpotifyId}")"/>
                            }
                            @if (!string.IsNullOrEmpty(candidate.DiscogsId))
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@($"Discogs: {candidate.DiscogsId}")"/>
                            }
                            @if (!string.IsNullOrEmpty(candidate.AmgId))
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="@($"AMG: {candidate.AmgId}")"/>
                            }
                            @if (!string.IsNullOrEmpty(candidate.ItunesId))
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@($"iTunes: {candidate.ItunesId}")"/>
                            }
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            }
        </RadzenStack>
    }
    else if (_hasSearched)
    {
        <RadzenText Text="@L("ArtistLookup.NoResults")" class="rz-text-secondary rz-text-align-center"/>
    }

    @if (_hasPartialFailures)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" class="rz-mt-2">
            @L("ArtistLookup.SomeProvidersFailed")
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End" class="rz-mt-4">
        <RadzenButton Text="@L("Actions.Cancel")"
                      ButtonStyle="ButtonStyle.Light"
                      Click="@(() => DialogService.Close(null))"/>
    </RadzenStack>
</RadzenStack>

@code {
    private string _searchText = string.Empty;
    private string _amgIdText = string.Empty;
    private ArtistLookupCandidate[]? _candidates;
    private ProviderInfo[]? _providers;
    private string[] _selectedProviderIds = [];
    private bool _isLoading;
    private bool _hasError;
    private bool _hasSearched;
    private bool _hasPartialFailures;
    private CancellationTokenSource? _searchCts;
    private IArtistSearchEnginePlugin[] _plugins = [];

    [Parameter]
    public string? InitialArtistName { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _searchText = InitialArtistName ?? string.Empty;
        await LoadProvidersAsync();
    }

    private async Task LoadProvidersAsync()
    {
        try
        {
            var configuration = await ConfigurationFactory.GetConfigurationAsync();
            await ArtistSearchEngineService.InitializeAsync(configuration);
            _plugins = ArtistSearchEngineService.GetRegisteredPlugins();
            _providers = _plugins.Select(p => new ProviderInfo
            {
                Id = p.Id,
                DisplayName = p.DisplayName,
                IsEnabled = p.IsEnabled
            }).ToArray();
        }
        catch (Exception)
        {
            _providers = [];
        }
    }

    private async Task OnKeyUpAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchText))
        {
            await SearchAsync();
        }
    }

    private async Task OnAmgIdKeyUpAsync(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !string.IsNullOrWhiteSpace(_amgIdText))
        {
            await SearchByAmgIdAsync();
        }
    }

    private async Task SearchByAmgIdAsync()
    {
        if (string.IsNullOrWhiteSpace(_amgIdText))
        {
            return;
        }

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();

        _isLoading = true;
        _hasError = false;
        _hasSearched = true;
        _hasPartialFailures = false;
        _candidates = null;

        try
        {
            var result = await ArtistSearchEngineService.LookupByAmgIdAsync(_amgIdText.Trim(), 20, _searchCts.Token);

            if (result.IsSuccess && result.Data != null)
            {
                _candidates = result.Data.Select(c => new ArtistLookupCandidate
                {
                    ProviderDisplayName = c.FromPlugin,
                    ProviderId = _plugins.FirstOrDefault(p => p.DisplayName == c.FromPlugin)?.Id,
                    Name = c.Name,
                    SortName = c.SortName,
                    ImageUrl = c.ImageUrl,
                    ThumbnailUrl = c.ThumbnailUrl,
                    MusicBrainzId = c.MusicBrainzId,
                    SpotifyId = c.SpotifyId,
                    DiscogsId = c.DiscogsId,
                    AmgId = c.AmgId,
                    WikiDataId = c.WikiDataId,
                    ItunesId = c.ItunesId,
                    LastFmId = c.LastFmId
                }).ToArray();
            }
            else
            {
                _hasError = true;
                _candidates = [];
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception)
        {
            _hasError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return;
        }

        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();

        _isLoading = true;
        _hasError = false;
        _hasSearched = true;
        _hasPartialFailures = false;
        _candidates = null;

        try
        {
            var result = await ArtistSearchEngineService.LookupAsync(
                _searchText,
                20,
                _selectedProviderIds.Length > 0 ? _selectedProviderIds : null,
                _searchCts.Token);

            _candidates = result.Candidates.Select(c => new ArtistLookupCandidate
            {
                ProviderDisplayName = c.FromPlugin,
                ProviderId = _plugins.FirstOrDefault(p => p.DisplayName == c.FromPlugin)?.Id,
                Name = c.Name,
                SortName = c.SortName,
                ImageUrl = c.ImageUrl,
                ThumbnailUrl = c.ThumbnailUrl,
                MusicBrainzId = c.MusicBrainzId,
                SpotifyId = c.SpotifyId,
                DiscogsId = c.DiscogsId,
                AmgId = c.AmgId,
                WikiDataId = c.WikiDataId,
                ItunesId = c.ItunesId,
                LastFmId = c.LastFmId
            }).ToArray();
            _hasPartialFailures = result.HasPartialFailures;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception)
        {
            _hasError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SelectCandidate(ArtistLookupCandidate candidate)
    {
        DialogService.Close(candidate);
    }
}

<style>
    .candidate-card {
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .candidate-card:hover {
        background-color: var(--rz-base-200);
    }
</style>
