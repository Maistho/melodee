@page "/admin/jobs"
@inherits MelodeeComponentBase
@using System.Globalization
@using Melodee.Blazor.ViewModels
@using Melodee.Common.Constants
@using Melodee.Common.Data
@using Microsoft.EntityFrameworkCore
@using NodaTime
@using Quartz
@using Quartz.Impl.Matchers
@using Quartz.Impl.Triggers
@using Serilog
@inject ISchedulerFactory SchedulerFactory
@inject IConfiguration AppSettingsConfiguration
@inject NotificationService NotificationService
@inject IDbContextFactory<MelodeeDbContext> DbContextFactory

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>@L("AdminJobs.PageTitle")</PageTitle>

<RadzenStack Gap="1rem">
    @* Header *@
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">
                <RadzenIcon Icon="schedule" class="rz-me-1"/>
                @L("AdminJobs.Title")
            </RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Icon="refresh" Text="@L("Actions.Refresh")" Click="@RefreshJobsClicked" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Primary" Disabled="@_isLoading"/>
                @if (_schedulerStarted)
                {
                    <RadzenButton Icon="pause" Text="@L("Actions.PauseAll")" Click="@PauseAllJobsClicked" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Warning" Disabled="@_isLoading"/>
                }
                else
                {
                    <RadzenButton Icon="play_arrow" Text="@L("Actions.ResumeAll")" Click="@ResumeAllJobsClicked" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success" Disabled="@_isLoading"/>
                }
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @if (AppSettingsConfiguration.GetValue<bool>(AppSettingsKeys.QuartzDisabled))
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Shade="Shade.Light" AllowClose="false">
            <RadzenText>@L("AdminJobs.JobsDisabledMessage") "<strong>@AppSettingsKeys.QuartzDisabled</strong>" @L("AdminJobs.JobsDisabledMessage2")</RadzenText>
        </RadzenAlert>
    }
    else
    {
        @* Scheduler Status Overview *@
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="6" SizeMD="2">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="@(_schedulerStarted ? "check_circle" : "pause_circle")" 
                                    Style="@($"font-size: 2rem; color: var(--rz-{(_schedulerStarted ? "success" : "warning")});")"/>
                        <RadzenText TextStyle="TextStyle.Overline">@L("AdminJobs.Scheduler")</RadzenText>
                        <RadzenText TextStyle="TextStyle.H6" Style="@($"color: var(--rz-{(_schedulerStarted ? "success" : "warning")});")">
                            @(_schedulerStarted ? L("Status.Running") : L("Status.Paused"))
                        </RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="2">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="list_alt" Style="font-size: 2rem; color: var(--rz-primary);"/>
                        <RadzenText TextStyle="TextStyle.Overline">@L("AdminJobs.TotalJobs")</RadzenText>
                        <RadzenText TextStyle="TextStyle.H6">@_jobs.Count</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="2">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="play_circle" Style="font-size: 2rem; color: var(--rz-info);"/>
                        <RadzenText TextStyle="TextStyle.Overline">@L("AdminJobs.Running")</RadzenText>
                        <RadzenText TextStyle="TextStyle.H6">@_currentlyExecutingCount</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="2">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="pause_circle" Style="font-size: 2rem; color: var(--rz-warning);"/>
                        <RadzenText TextStyle="TextStyle.Overline">@L("Status.Paused")</RadzenText>
                        <RadzenText TextStyle="TextStyle.H6">@_pausedJobsCount</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="2">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="history" Style="font-size: 2rem; color: var(--rz-secondary);"/>
                        <RadzenText TextStyle="TextStyle.Overline">@L("AdminJobs.HistoryRecords")</RadzenText>
                        <RadzenText TextStyle="TextStyle.H6">@_totalHistoryRecords.ToString("N0")</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            <RadzenColumn Size="6" SizeMD="2">
                <RadzenCard Style="height: 100%;">
                    <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenIcon Icon="error" Style="@($"font-size: 2rem; color: var(--rz-{(_totalFailures24h > 0 ? "danger" : "success")});")"/>
                        <RadzenText TextStyle="TextStyle.Overline">@L("AdminJobs.Failures24h")</RadzenText>
                        <RadzenText TextStyle="TextStyle.H6" Style="@($"color: var(--rz-{(_totalFailures24h > 0 ? "danger" : "success")});")">@_totalFailures24h</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        @if (_jobs.Count == 0 && !_isLoading)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Light" AllowClose="false">
                <RadzenText>@L("AdminJobs.NoJobsFound")</RadzenText>
            </RadzenAlert>
        }
        else
        {
            @* Jobs Data Grid *@
            <RadzenCard>
                <RadzenDataGrid @ref="_jobsGrid" TItem="JobStatusDetail" 
                                Data="@_jobs" 
                                AllowPaging="false" 
                                AllowSorting="true" 
                                AllowFiltering="false"
                                Density="Density.Compact"
                                RowExpand="@OnRowExpand"
                                ExpandMode="DataGridExpandMode.Single">
                    <Template Context="job">
                        <RadzenCard Variant="Variant.Flat" class="rz-background-color-base-100">
                            <RadzenRow Gap="1rem">
                                @* Job Details *@
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2">
                                        <RadzenIcon Icon="info" class="rz-me-1"/>
                                        @L("AdminJobs.JobDetails")
                                    </RadzenText>
                                    <RadzenStack Gap="0.25rem">
                                        @if (!string.IsNullOrEmpty(job.Description))
                                        {
                                            <RadzenRow>
                                                <RadzenColumn Size="4"><RadzenText TextStyle="TextStyle.Caption">@L("Label.Description")</RadzenText></RadzenColumn>
                                                <RadzenColumn Size="8"><RadzenText>@job.Description</RadzenText></RadzenColumn>
                                            </RadzenRow>
                                        }
                                        <RadzenRow>
                                            <RadzenColumn Size="4"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.JobGroup")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="8"><RadzenText>@job.JobGroup</RadzenText></RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="4"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.TriggerType")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="8"><RadzenText>@job.TriggerType</RadzenText></RadzenColumn>
                                        </RadzenRow>
                                        @if (!string.IsNullOrEmpty(job.CronExpression))
                                        {
                                            <RadzenRow>
                                                <RadzenColumn Size="4"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.CronExpression")</RadzenText></RadzenColumn>
                                                <RadzenColumn Size="8">
                                                    <RadzenText><code>@job.CronExpression</code></RadzenText>
                                                    @if (!string.IsNullOrEmpty(job.CronDescription))
                                                    {
                                                        <br/><RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">@job.CronDescription</RadzenText>
                                                    }
                                                </RadzenColumn>
                                            </RadzenRow>
                                        }
                                    </RadzenStack>
                                </RadzenColumn>

                                @* Execution Statistics *@
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2">
                                        <RadzenIcon Icon="analytics" class="rz-me-1"/>
                                        @L("AdminJobs.ExecutionStatistics")
                                    </RadzenText>
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.TotalRuns")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6"><RadzenText>@job.TotalRunCount.ToString("N0")</RadzenText></RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.SuccessRate")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6">
                                                @if (job.TotalRunCount > 0)
                                                {
                                                    <RadzenBadge BadgeStyle="@(job.SuccessRate >= 95 ? BadgeStyle.Success : job.SuccessRate >= 80 ? BadgeStyle.Warning : BadgeStyle.Danger)" 
                                                                 Text="@job.SuccessRateDisplay" Shade="Shade.Light"/>
                                                }
                                                else
                                                {
                                                    <RadzenText>---</RadzenText>
                                                }
                                            </RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.SuccessesFailures")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6">
                                                <RadzenText Style="color: var(--rz-success);">@job.SuccessCount</RadzenText>
                                                <RadzenText> / </RadzenText>
                                                <RadzenText Style="@(job.FailureCount > 0 ? "color: var(--rz-danger);" : "")">@job.FailureCount</RadzenText>
                                            </RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.ManualTriggers")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6"><RadzenText>@job.ManualTriggerCount</RadzenText></RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.AvgDuration")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6"><RadzenText>@job.AverageDurationDisplay</RadzenText></RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.MinMaxDuration")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6"><RadzenText>@job.MinMaxDurationDisplay</RadzenText></RadzenColumn>
                                        </RadzenRow>
                                    </RadzenStack>
                                </RadzenColumn>

                                @* Job Configuration *@
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2">
                                        <RadzenIcon Icon="settings" class="rz-me-1"/>
                                        @L("AdminJobs.Configuration")
                                    </RadzenText>
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.Durable")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6">
                                                <RadzenBadge BadgeStyle="@(job.IsDurable ? BadgeStyle.Success : BadgeStyle.Light)" 
                                                             Text="@(job.IsDurable ? L("Actions.Yes") : L("Actions.No"))" Shade="Shade.Light"/>
                                            </RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.DisallowConcurrent")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6">
                                                <RadzenBadge BadgeStyle="@(job.DisallowConcurrentExecution ? BadgeStyle.Info : BadgeStyle.Light)" 
                                                             Text="@(job.DisallowConcurrentExecution ? L("Actions.Yes") : L("Actions.No"))" Shade="Shade.Light"/>
                                            </RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.PersistData")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6">
                                                <RadzenBadge BadgeStyle="@(job.PersistJobDataAfterExecution ? BadgeStyle.Info : BadgeStyle.Light)" 
                                                             Text="@(job.PersistJobDataAfterExecution ? L("Actions.Yes") : L("Actions.No"))" Shade="Shade.Light"/>
                                            </RadzenColumn>
                                        </RadzenRow>
                                        <RadzenRow>
                                            <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.RequestsRecovery")</RadzenText></RadzenColumn>
                                            <RadzenColumn Size="6">
                                                <RadzenBadge BadgeStyle="@(job.RequestsRecovery ? BadgeStyle.Warning : BadgeStyle.Light)" 
                                                             Text="@(job.RequestsRecovery ? L("Actions.Yes") : L("Actions.No"))" Shade="Shade.Light"/>
                                            </RadzenColumn>
                                        </RadzenRow>
                                    </RadzenStack>
                                </RadzenColumn>

                                @* Last Error *@
                                @if (!string.IsNullOrEmpty(job.LastErrorMessage))
                                {
                                    <RadzenColumn Size="12">
                                        <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="false" Size="AlertSize.Small">
                                            <RadzenText TextStyle="TextStyle.Caption">
                                                <strong>@L("AdminJobs.LastError")</strong> (@(job.LastFailureTime?.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? L("AdminJobs.UnknownTime")))
                                            </RadzenText>
                                            <RadzenText TextStyle="TextStyle.Body2">@job.LastErrorMessage</RadzenText>
                                        </RadzenAlert>
                                    </RadzenColumn>
                                }

                                @* Job Data Map *@
                                @if (job.JobData != null && job.JobData.Count > 0)
                                {
                                    <RadzenColumn Size="12">
                                        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-2">
                                            <RadzenIcon Icon="data_object" class="rz-me-1"/>
                                            @L("AdminJobs.JobData")
                                        </RadzenText>
                                        <RadzenDataGrid TItem="KeyValuePair<string, object>" 
                                                        Data="@job.JobData" 
                                                        AllowPaging="false" 
                                                        Density="Density.Compact">
                                            <Columns>
                                                <RadzenDataGridColumn TItem="KeyValuePair<string, object>" Property="Key" Title="@L("AdminJobs.Key")" Width="200px"/>
                                                <RadzenDataGridColumn TItem="KeyValuePair<string, object>" Title="@L("AdminJobs.Value")">
                                                    <Template Context="kvp">@kvp.Value?.ToString()</Template>
                                                </RadzenDataGridColumn>
                                            </Columns>
                                        </RadzenDataGrid>
                                    </RadzenColumn>
                                }
                            </RadzenRow>
                        </RadzenCard>
                    </Template>
                    <Columns>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="JobName" Title="@L("AdminJobs.JobName")" Width="200px">
                            <Template Context="job">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    @if (job.IsCurrentlyExecuting)
                                    {
                                        <RadzenIcon Icon="sync" Style="color: var(--rz-info); animation: spin 1s linear infinite;"/>
                                    }
                                    <RadzenText Style="font-weight: 500;">@job.JobName</RadzenText>
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="TriggerState" Title="@L("Common.Status")" Width="90px">
                            <Template Context="job">
                                <RadzenBadge BadgeStyle="@GetBadgeStyle(job.TriggerState)" Text="@job.TriggerState" Shade="Shade.Light"/>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="TotalRunCount" Title="@L("AdminJobs.Runs")" Width="70px">
                            <Template Context="job">
                                <RadzenText TextStyle="TextStyle.Caption">@job.TotalRunCount.ToString("N0")</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="SuccessRate" Title="@L("AdminJobs.Success")" Width="80px" Sortable="true">
                            <Template Context="job">
                                @if (job.TotalRunCount > 0)
                                {
                                    <RadzenBadge BadgeStyle="@(job.SuccessRate >= 95 ? BadgeStyle.Success : job.SuccessRate >= 80 ? BadgeStyle.Warning : BadgeStyle.Danger)" 
                                                 Text="@job.SuccessRateDisplay" Shade="Shade.Light" Style="font-size: 0.75rem;"/>
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Caption">---</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="PreviousFireTimeUtc" Title="@L("AdminJobs.LastRun")" Width="140px">
                            <Template Context="job">
                                <RadzenText TextStyle="TextStyle.Caption">@job.PreviousFireTimeDisplay</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="NextFireTimeUtc" Title="@L("AdminJobs.NextRun")" Width="140px">
                            <Template Context="job">
                                <RadzenText TextStyle="TextStyle.Caption">@job.NextFireTimeDisplay</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Property="AverageDurationMs" Title="@L("AdminJobs.AvgTime")" Width="90px">
                            <Template Context="job">
                                <RadzenText TextStyle="TextStyle.Caption">@job.AverageDurationDisplay</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobStatusDetail" Title="@L("Data.Actions")" Width="250px" Sortable="false">
                            <Template Context="job">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem">
                                    <RadzenButton Icon="play_arrow" 
                                                  Text="@L("Actions.Run")" 
                                                  Size="ButtonSize.ExtraSmall" 
                                                  ButtonStyle="ButtonStyle.Success"
                                                  Disabled="@(job.IsCurrentlyExecuting)"
                                                  Click="@(() => TriggerJobClicked(job))"/>
                                    @if (job.TriggerState == "Paused")
                                    {
                                        <RadzenButton Icon="play_circle" 
                                                      Text="@L("Actions.Resume")" 
                                                      Size="ButtonSize.ExtraSmall" 
                                                      ButtonStyle="ButtonStyle.Info"
                                                      Click="@(() => ResumeJobClicked(job))"/>
                                    }
                                    else
                                    {
                                        <RadzenButton Icon="pause_circle" 
                                                      Text="@L("Actions.Pause")" 
                                                      Size="ButtonSize.ExtraSmall" 
                                                      ButtonStyle="ButtonStyle.Warning"
                                                      Disabled="@(job.IsCurrentlyExecuting)"
                                                      Click="@(() => PauseJobClicked(job))"/>
                                    }
                                    @if (job.IsCurrentlyExecuting)
                                    {
                                        <RadzenButton Icon="stop" 
                                                      Text="@L("Actions.Interrupt")" 
                                                      Size="ButtonSize.ExtraSmall" 
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => InterruptJobClicked(job))"/>
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }

        @* Scheduler Information *@
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.H6">
                <RadzenIcon Icon="info" class="rz-me-1"/>
                @L("AdminJobs.SchedulerInformation")
            </RadzenText>
            <RadzenRow Gap="1rem" class="rz-mt-2">
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.SchedulerName")</RadzenText>
                    <RadzenText>@_schedulerName</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.InstanceId")</RadzenText>
                    <RadzenText>@_schedulerInstanceId</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.SchedulerStarted")</RadzenText>
                    <RadzenText>@_schedulerStartTimeDisplay</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.QuartzVersion")</RadzenText>
                    <RadzenText>@_quartzVersion</RadzenText>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem" class="rz-mt-2">
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.ThreadPool")</RadzenText>
                    <RadzenText>@_threadPoolType (@_threadPoolSize @L("AdminJobs.Threads").ToLower())</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.JobStore")</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem" AlignItems="AlignItems.Center">
                        <RadzenText>@_jobStoreType</RadzenText>
                        @if (_jobStorePersistent)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@L("AdminJobs.Persistent")" Shade="Shade.Light" Style="font-size: 0.7rem;"/>
                        }
                        @if (_jobStoreClustered)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@L("AdminJobs.Clustered")" Shade="Shade.Light" Style="font-size: 0.7rem;"/>
                        }
                    </RadzenStack>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.JobsExecutedSession")</RadzenText>
                    <RadzenText>@_numberOfJobsExecuted.ToString("N0")</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="6" SizeMD="3">
                    <RadzenText TextStyle="TextStyle.Caption">@L("AdminJobs.StandbyMode")</RadzenText>
                    <RadzenBadge BadgeStyle="@(_schedulerInStandby ? BadgeStyle.Warning : BadgeStyle.Success)" 
                                 Text="@(_schedulerInStandby ? L("Actions.Yes") : L("Actions.No"))" Shade="Shade.Light"/>
                </RadzenColumn>
            </RadzenRow>
        </RadzenCard>
    }
</RadzenStack>

<style>
    @@keyframes spin {
        from { transform: rotate(360deg); }
        to { transform: rotate(0deg); }
    }
</style>

@code {
    private List<JobStatusDetail> _jobs = [];
    private RadzenDataGrid<JobStatusDetail>? _jobsGrid;
    private bool _isLoading;
    private bool _schedulerStarted;
    private bool _schedulerInStandby;
    private string _schedulerName = "---";
    private string _schedulerInstanceId = "---";
    private string _schedulerStartTimeDisplay = "---";
    private int _threadPoolSize;
    private int _currentlyExecutingCount;
    private int _pausedJobsCount;
    private int _totalHistoryRecords;
    private int _totalFailures24h;
    private string _quartzVersion = "---";
    private string _jobStoreType = "---";
    private bool _jobStorePersistent;
    private bool _jobStoreClustered;
    private int _numberOfJobsExecuted;
    private string _threadPoolType = "---";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await RefreshJobsAsync();
    }

    private async Task RefreshJobsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var newJobs = new List<JobStatusDetail>();
        
        try
        {
            var scheduler = await SchedulerFactory.GetScheduler();
            var metadata = await scheduler.GetMetaData();
            
            _schedulerStarted = metadata.Started && !metadata.Shutdown;
            _schedulerInStandby = metadata.InStandbyMode;
            _schedulerName = metadata.SchedulerName;
            _schedulerInstanceId = metadata.SchedulerInstanceId;
            _schedulerStartTimeDisplay = metadata.RunningSince?.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss") ?? L("AdminJobs.NotStarted");
            _threadPoolSize = metadata.ThreadPoolSize;
            _quartzVersion = metadata.Version;
            _jobStoreType = metadata.JobStoreType?.Name ?? "---";
            _jobStorePersistent = metadata.JobStoreSupportsPersistence;
            _jobStoreClustered = metadata.JobStoreClustered;
            _numberOfJobsExecuted = metadata.NumberOfJobsExecuted;
            _threadPoolType = metadata.ThreadPoolType?.Name ?? "---";

            var currentlyExecuting = await scheduler.GetCurrentlyExecutingJobs();
            var currentlyExecutingKeys = currentlyExecuting.Select(j => j.JobDetail.Key).ToHashSet();
            _currentlyExecutingCount = currentlyExecuting.Count;

            // Get comprehensive job history stats from database
            await using var dbContext = await DbContextFactory.CreateDbContextAsync();
            var jobHistoryStats = await dbContext.JobHistories
                .GroupBy(h => h.JobName)
                .Select(g => new
                {
                    JobName = g.Key,
                    TotalRunCount = g.Count(),
                    SuccessCount = g.Count(h => h.Success),
                    FailureCount = g.Count(h => !h.Success),
                    ManualTriggerCount = g.Count(h => h.WasManualTrigger),
                    AverageDurationMs = g.Where(h => h.DurationInMs.HasValue).Average(h => h.DurationInMs),
                    MinDurationMs = g.Where(h => h.DurationInMs.HasValue).Min(h => h.DurationInMs),
                    MaxDurationMs = g.Where(h => h.DurationInMs.HasValue).Max(h => h.DurationInMs),
                    LastRun = g.Max(h => h.CompletedAt),
                    LastDuration = g.OrderByDescending(h => h.CompletedAt).First().DurationInMs,
                    LastFailure = g.Where(h => !h.Success).OrderByDescending(h => h.CompletedAt).Select(h => new { h.CompletedAt, h.ErrorMessage }).FirstOrDefault()
                })
                .ToDictionaryAsync(x => x.JobName);

            // Get aggregate stats for summary cards
            _totalHistoryRecords = await dbContext.JobHistories.CountAsync();
            var twentyFourHoursAgo = SystemClock.Instance.GetCurrentInstant().Minus(Duration.FromHours(24));
            _totalFailures24h = await dbContext.JobHistories
                .CountAsync(h => !h.Success && h.StartedAt > twentyFourHoursAgo);

            var jobGroups = await scheduler.GetJobGroupNames();
            _pausedJobsCount = 0;
            
            Log.Debug("[Jobs UI] Scheduler started: {Started}, In standby: {Standby}, Job groups: {Groups}", 
                metadata.Started, metadata.InStandbyMode, string.Join(", ", jobGroups));

            foreach (var group in jobGroups)
            {
                var groupMatcher = GroupMatcher<JobKey>.GroupContains(group);
                var jobKeys = await scheduler.GetJobKeys(groupMatcher);
                
                foreach (var jobKey in jobKeys)
                {
                    var jobDetail = await scheduler.GetJobDetail(jobKey);
                    if (jobDetail == null) continue;

                    var triggers = await scheduler.GetTriggersOfJob(jobKey);
                    var trigger = triggers.FirstOrDefault();
                    
                    if (trigger == null) continue;

                    var triggerState = await scheduler.GetTriggerState(trigger.Key);
                    if (triggerState == TriggerState.Paused) _pausedJobsCount++;

                    string? cronExpression = null;
                    string? cronDescription = null;
                    if (trigger is ICronTrigger cronTrigger)
                    {
                        cronExpression = cronTrigger.CronExpressionString;
                        cronDescription = GetCronDescription(cronExpression);
                    }

                    var executingJob = currentlyExecuting.FirstOrDefault(j => j.JobDetail.Key.Equals(jobKey));
                    TimeSpan? runTime = null;
                    if (executingJob != null)
                    {
                        runTime = DateTimeOffset.UtcNow - executingJob.FireTimeUtc;
                    }

                    var jobData = jobDetail.JobDataMap.Count > 0 
                        ? jobDetail.JobDataMap.ToDictionary(k => k.Key, k => k.Value) 
                        : null;

                    // Get stats from JobHistory
                    DateTimeOffset? previousFireTime = null;
                    TimeSpan? lastRunDuration = null;
                    int totalRunCount = 0, successCount = 0, failureCount = 0, manualTriggerCount = 0;
                    double? avgDuration = null, minDuration = null, maxDuration = null;
                    string? lastErrorMessage = null;
                    DateTimeOffset? lastFailureTime = null;

                    if (jobHistoryStats.TryGetValue(jobKey.Name, out var stats))
                    {
                        if (stats.LastRun.HasValue)
                        {
                            previousFireTime = stats.LastRun.Value.ToDateTimeOffset();
                        }
                        lastRunDuration = stats.LastDuration.HasValue ? TimeSpan.FromMilliseconds(stats.LastDuration.Value) : null;
                        totalRunCount = stats.TotalRunCount;
                        successCount = stats.SuccessCount;
                        failureCount = stats.FailureCount;
                        manualTriggerCount = stats.ManualTriggerCount;
                        avgDuration = stats.AverageDurationMs;
                        minDuration = stats.MinDurationMs;
                        maxDuration = stats.MaxDurationMs;
                        if (stats.LastFailure != null)
                        {
                            lastErrorMessage = stats.LastFailure.ErrorMessage;
                            lastFailureTime = stats.LastFailure.CompletedAt?.ToDateTimeOffset();
                        }
                    }
                    else
                    {
                        // Fall back to trigger data for jobs without history (like NowPlayingCleanup)
                        previousFireTime = triggers
                            .Select(t => t.GetPreviousFireTimeUtc())
                            .Where(t => t.HasValue)
                            .OrderByDescending(t => t!.Value)
                            .FirstOrDefault();
                    }

                    newJobs.Add(new JobStatusDetail
                    {
                        JobName = jobKey.Name,
                        JobGroup = jobKey.Group,
                        JobKey = jobKey,
                        Description = jobDetail.Description,
                        TriggerState = triggerState.ToString(),
                        TriggerType = trigger.GetType().Name.Replace("Impl", "").Replace("Trigger", ""),
                        CronExpression = cronExpression,
                        CronDescription = cronDescription,
                        NextFireTimeUtc = trigger.GetNextFireTimeUtc(),
                        PreviousFireTimeUtc = previousFireTime,
                        StartTimeUtc = trigger.StartTimeUtc,
                        EndTimeUtc = trigger.EndTimeUtc,
                        TimesTriggered = trigger is ISimpleTrigger simpleTrigger ? simpleTrigger.TimesTriggered : 0,
                        IsCurrentlyExecuting = currentlyExecutingKeys.Contains(jobKey),
                        RunTime = runTime ?? lastRunDuration,
                        IsDurable = jobDetail.Durable,
                        DisallowConcurrentExecution = jobDetail.ConcurrentExecutionDisallowed,
                        PersistJobDataAfterExecution = jobDetail.PersistJobDataAfterExecution,
                        RequestsRecovery = jobDetail.RequestsRecovery,
                        JobData = jobData,
                        TotalRunCount = totalRunCount,
                        SuccessCount = successCount,
                        FailureCount = failureCount,
                        ManualTriggerCount = manualTriggerCount,
                        AverageDurationMs = avgDuration,
                        MinDurationMs = minDuration,
                        MaxDurationMs = maxDuration,
                        LastErrorMessage = lastErrorMessage,
                        LastFailureTime = lastFailureTime
                    });
                }
            }

            // Add known jobs from JobRegistry that aren't currently scheduled
            var scheduledJobNames = newJobs.Select(j => j.JobName).ToHashSet();
            foreach (var (jobKey, jobInfo) in JobRegistry.Jobs)
            {
                if (scheduledJobNames.Contains(jobKey.Name)) continue;

                // Check if this job has any history even though it's not currently scheduled
                jobHistoryStats.TryGetValue(jobKey.Name, out var stats);

                newJobs.Add(new JobStatusDetail
                {
                    JobName = jobKey.Name,
                    JobGroup = jobKey.Group,
                    JobKey = jobKey,
                    Description = jobInfo.Description,
                    TriggerState = "Not Scheduled",
                    TriggerType = "---",
                    CronExpression = null,
                    CronDescription = jobInfo.CronSettingKey != null ? $"Configure via: {jobInfo.CronSettingKey}" : "No configurable schedule",
                    NextFireTimeUtc = null,
                    PreviousFireTimeUtc = stats?.LastRun?.ToDateTimeOffset(),
                    StartTimeUtc = DateTimeOffset.MinValue,
                    EndTimeUtc = null,
                    TimesTriggered = 0,
                    IsCurrentlyExecuting = false,
                    RunTime = null,
                    IsDurable = false,
                    DisallowConcurrentExecution = false,
                    PersistJobDataAfterExecution = false,
                    RequestsRecovery = false,
                    JobData = null,
                    TotalRunCount = stats?.TotalRunCount ?? 0,
                    SuccessCount = stats?.SuccessCount ?? 0,
                    FailureCount = stats?.FailureCount ?? 0,
                    ManualTriggerCount = stats?.ManualTriggerCount ?? 0,
                    AverageDurationMs = stats?.AverageDurationMs,
                    MinDurationMs = stats?.MinDurationMs,
                    MaxDurationMs = stats?.MaxDurationMs,
                    LastErrorMessage = stats?.LastFailure?.ErrorMessage,
                    LastFailureTime = stats?.LastFailure?.CompletedAt?.ToDateTimeOffset()
                });
            }
            
            // Assign the new list to trigger change detection
            _jobs = newJobs;
            
            Log.Debug("[Jobs UI] Finished loading jobs. Total jobs loaded: {Count}", _jobs.Count);
        }
        catch (Exception ex)
        {
            Log.Error(ex, "[Jobs UI] Error loading jobs");
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("AdminJobs.ErrorLoadingJobs"),
                Detail = ex.Message,
                Duration = ToastTime
            });
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

