    private async Task TriggerJobClicked(JobStatusDetail job)
    {
        try
        {
            var scheduler = await SchedulerFactory.GetScheduler();
            
            // Log before triggering
            Log.Information("[Jobs UI] Manually triggering job {JobName}", job.JobName);
            
            await scheduler.TriggerJob(job.JobKey);
            
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = L("AdminJobs.JobTriggered", job.JobName),
                Duration = ToastTime
            });
            
            // Wait longer to allow fast jobs to complete
            await Task.Delay(1000);
            await RefreshJobsAsync();
        }
        catch (Exception ex)
        {
            Log.Error(ex, "[Jobs UI] Failed to trigger job {JobName}", job.JobName);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("AdminJobs.FailedToTriggerJob"),
                Detail = ex.Message,
                Duration = ToastTime
            });
        }
    }

