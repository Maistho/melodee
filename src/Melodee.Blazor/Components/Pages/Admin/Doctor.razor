@page "/admin/doctor"
@using System.Diagnostics
@using System.Reflection
@using System.Runtime.InteropServices
@using System.Text.Json
@using Melodee.Common.Constants
@using Melodee.Common.Data
@using Melodee.Common.Models.SearchEngines.ArtistSearchEngineServiceData
@using Melodee.Common.Plugins.SearchEngine.MusicBrainz.Data
@using Microsoft.Data.Sqlite
@using Microsoft.EntityFrameworkCore
@using Quartz
@using Serilog
@using Serilog.Core
@inherits MelodeeComponentBase

@inject IMelodeeConfigurationFactory MelodeeConfigurationFactory
@inject IDbContextFactory<MelodeeDbContext> DbContextFactory
@inject IDbContextFactory<MusicBrainzDbContext> MusicBrainzDbContextFactory
@inject IConfiguration AppConfiguration
@inject NotificationService NotificationService
@inject IWebHostEnvironment WebHostEnvironment
@inject ISchedulerFactory SchedulerFactory
@inject IDoctorService DoctorService

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>@L("AdminDoctor.PageTitle")</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">
                <RadzenIcon Icon="health_and_safety" class="rz-me-1"/>
                @L("AdminDoctor.PageTitle")
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary">
                @L("AdminDoctor.Description")
            </RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem" Wrap="FlexWrap.Wrap">
                <RadzenButton Icon="refresh" Text="@L("Actions.Refresh")" Click="@RunDiagnosticsAsync" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Primary" IsBusy="@_isLoading"/>
                <RadzenButton Icon="content_copy" Text="@L("AdminDoctor.CopyJson")" Click="@CopyJsonToClipboard" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary" Disabled="@_isLoading"/>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @if (_isLoading)
    {
        <RadzenCard>
            <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="width: 100%;"/>
                <RadzenText TextStyle="TextStyle.Body1">@L("AdminDoctor.RunningDiagnostics")</RadzenText>
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        @* Overall Status *@
        <RadzenCard class="@(_allChecksPassed ? "rz-background-color-success-lighter" : "rz-background-color-danger-lighter")">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                <RadzenIcon Icon="@(_allChecksPassed ? "check_circle" : "error")" Style="@($"font-size: 2rem; color: var(--rz-{(_allChecksPassed ? "success" : "danger")});")"/>
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H6" Style="@($"color: var(--rz-{(_allChecksPassed ? "success" : "danger")});")">
                        @(_allChecksPassed ? L("AdminDoctor.AllChecksPassed") : L("AdminDoctor.IssuesFound"))
                    </RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">
                        @L("AdminDoctor.CompletedIn", $"{_totalDuration.TotalSeconds:F2}")
                    </RadzenText>
                </RadzenStack>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" Style="margin-left: auto;" AlignItems="AlignItems.Center">
                    @foreach (var status in _quickStatusBadges)
                    {
                        <RadzenBadge BadgeStyle="@status.BadgeStyle" 
                                     IsPill="true"
                                     title="@status.Details">
                            <RadzenIcon Icon="@status.Icon" Style="font-size: 14px; margin-right: 4px;"/>
                            @status.Name
                        </RadzenBadge>
                    }
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        @* MusicBrainz Database Action Card - shown when DB is empty *@
        @if (_isMusicBrainzEmpty)
        {
            <RadzenCard class="rz-background-color-warning-lighter">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="1rem">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                        <RadzenIcon Icon="warning" Style="font-size: 2rem; color: var(--rz-warning);"/>
                        <RadzenStack Gap="0">
                            <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-warning-darker);">
                                @L("AdminDoctor.Check.MusicBrainzDatabase")
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">
                                @L("AdminDoctor.MusicBrainzDatabaseEmpty")
                            </RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                    <RadzenButton Icon="download" 
                                  Text="@L("AdminDoctor.GenerateMusicBrainzDatabase")" 
                                  ButtonStyle="ButtonStyle.Warning"
                                  IsBusy="@_isMusicBrainzJobRunning"
                                  Click="@TriggerMusicBrainzJobAsync"/>
                </RadzenStack>
            </RadzenCard>
        }

        @* System Checks *@
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.H6">
                <RadzenIcon Icon="checklist" class="rz-me-1"/>
                @L("AdminDoctor.SystemChecks")
            </RadzenText>
            <RadzenDataGrid Data="@_checks" TItem="CheckResult" AllowSorting="false" class="rz-mt-2">
                <Columns>
                    <RadzenDataGridColumn Title="@L("AdminDoctor.Status")" Width="80px">
                        <Template Context="check">
                            <RadzenIcon Icon="@(check.Success ? "check_circle" : "cancel")"
                                       Style="@($"color: var(--rz-{(check.Success ? "success" : "danger")});")"/>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn Property="@nameof(CheckResult.Name)" Title="@L("AdminDoctor.Check")" Width="200px"/>
                    <RadzenDataGridColumn Property="@nameof(CheckResult.Details)" Title="@L("AdminDoctor.Details")"/>
                    <RadzenDataGridColumn Title="@L("AdminDoctor.Duration")" Width="100px" TextAlign="TextAlign.Right">
                        <Template Context="check">
                            @($"{check.Duration.TotalMilliseconds:F0}ms")
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>

        @* Environment Information *@
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.H6">
                <RadzenIcon Icon="computer" class="rz-me-1"/>
                @L("AdminDoctor.EnvironmentInfo")
            </RadzenText>
            <RadzenRow Gap="1rem" class="rz-mt-2">
                @foreach (var env in _environmentInfo)
                {
                    <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
                        <RadzenStack Gap="0.25rem" class="rz-p-2 rz-border-radius-1" Style="background: var(--rz-base-background-color); border: 1px solid var(--rz-base-300);">
                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">@env.Key</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="word-break: break-all; color: var(--rz-text-color);">@env.Value</RadzenText>
                        </RadzenStack>
                    </RadzenColumn>
                }
            </RadzenRow>
        </RadzenCard>

        @* Library Paths *@
        @if (_libraryPaths.Any())
        {
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="folder" class="rz-me-1"/>
                    @L("AdminDoctor.LibraryPaths")
                </RadzenText>
                <RadzenDataGrid Data="@_libraryPaths" TItem="LibraryPathResult" AllowSorting="true" class="rz-mt-2">
                    <Columns>
                        <RadzenDataGridColumn Title="@L("AdminDoctor.Exists")" Width="70px">
                            <Template Context="lib">
                                <RadzenIcon Icon="@(lib.Exists ? "check_circle" : "cancel")"
                                           Style="@($"color: var(--rz-{(lib.Exists ? "success" : "danger")});")"/>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn Title="@L("AdminDoctor.Writable")" Width="70px">
                            <Template Context="lib">
                                <RadzenIcon Icon="@(lib.Writable ? "check_circle" : "cancel")"
                                           Style="@($"color: var(--rz-{(lib.Writable ? "success" : "danger")});")"/>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn Property="@nameof(LibraryPathResult.Name)" Title="@L("AdminDoctor.LibraryName")" Width="140px"/>
                        <RadzenDataGridColumn Property="@nameof(LibraryPathResult.Type)" Title="@L("AdminDoctor.LibraryType")" Width="100px"/>
                        <RadzenDataGridColumn Property="@nameof(LibraryPathResult.Path)" Title="@L("AdminDoctor.Path")"/>
                        <RadzenDataGridColumn Title="@L("AdminDoctor.DiskSpace")" Width="220px">
                            <Template Context="lib">
                                @if (lib.TotalBytes > 0)
                                {
                                    <RadzenStack Gap="0.25rem">
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                            <RadzenIcon Icon="@GetDiskSpaceIcon(lib.DiskStatus)" Style="@lib.DiskStatusStyle" />
                                            <RadzenText TextStyle="TextStyle.Caption">@FormatBytes(lib.AvailableBytes) @L("AdminDoctor.DiskAvailable").ToLower()</RadzenText>
                                        </RadzenStack>
                                        <RadzenProgressBar Value="@lib.UsedPercent" Max="100" ShowValue="false" Style="height: 6px;"
                                                          ProgressBarStyle="@(lib.DiskStatus.Contains(L("AdminDoctor.Critical")) ? ProgressBarStyle.Danger : lib.DiskStatus.Contains(L("AdminDoctor.Warning")) ? ProgressBarStyle.Warning : ProgressBarStyle.Success)"/>
                                    </RadzenStack>
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">—</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }

        @* Configurable Services *@
        @if (_configurableServices.Any())
        {
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="extension" class="rz-me-1"/>
                    @L("AdminDoctor.ConfigurableServices")
                </RadzenText>
                <RadzenDataGrid Data="@_configurableServices.OrderBy(s => s.Category).ThenBy(s => s.Name)" TItem="ConfigurableServiceResult" AllowSorting="true" class="rz-mt-2">
                    <Columns>
                        <RadzenDataGridColumn Title="@L("AdminDoctor.Status")" Width="80px">
                            <Template Context="service">
                                <RadzenBadge BadgeStyle="@(service.Enabled ? BadgeStyle.Success : BadgeStyle.Light)"
                                            Text="@(service.Enabled ? L("Status.Enabled") : L("Status.Disabled"))"/>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn Property="@nameof(ConfigurableServiceResult.Category)" Title="@L("AdminDoctor.Category")" Width="150px"/>
                        <RadzenDataGridColumn Property="@nameof(ConfigurableServiceResult.Name)" Title="@L("AdminDoctor.ServiceName")" Width="150px"/>
                        <RadzenDataGridColumn Property="@nameof(ConfigurableServiceResult.SettingKey)" Title="@L("AdminDoctor.SettingKey")"/>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        }

        @* Connection Strings (Masked) *@
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.H6">
                <RadzenIcon Icon="link" class="rz-me-1"/>
                @L("AdminDoctor.ConnectionStrings")
            </RadzenText>
            <RadzenStack Gap="0.5rem" class="rz-mt-2">
                @foreach (var cs in _connectionStrings)
                {
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" class="rz-p-2 rz-border-radius-1" Style="background: var(--rz-base-background-color); border: 1px solid var(--rz-base-300);">
                        <RadzenIcon Icon="@(cs.IsValid ? "check_circle" : "cancel")"
                                   Style="@($"color: var(--rz-{(cs.IsValid ? "success" : "danger")});")"/>
                        <RadzenStack Gap="0" Style="flex: 1;">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-color);"><strong>@cs.Name</strong></RadzenText>
                                @if (cs.IsFileBased && cs.FileExists.HasValue)
                                {
                                    <RadzenBadge BadgeStyle="@(cs.FileExists.Value ? BadgeStyle.Success : BadgeStyle.Danger)"
                                                Text="@(cs.FileExists.Value ? L("AdminDoctor.FileExists") : L("AdminDoctor.FileMissing"))"
                                                title="@cs.FilePath"/>
                                    @if (cs.FileWritable.HasValue)
                                    {
                                        <RadzenBadge BadgeStyle="@(cs.FileWritable.Value ? BadgeStyle.Success : BadgeStyle.Warning)"
                                                    Text="@(cs.FileWritable.Value ? L("AdminDoctor.Writable") : L("AdminDoctor.NotWritable"))"/>
                                    }
                                }
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Caption" Style="word-break: break-all; font-family: monospace; color: var(--rz-text-secondary-color);">@cs.MaskedValue</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                }
            </RadzenStack>
        </RadzenCard>

        @* Serilog Log Paths *@
        @if (_serilogLogPaths.Any())
        {
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="description" class="rz-me-1"/>
                    @L("AdminDoctor.SerilogLogPaths")
                </RadzenText>
                <RadzenStack Gap="0.5rem" class="rz-mt-2">
                    @foreach (var logPath in _serilogLogPaths)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" class="rz-p-2 rz-border-radius-1" Style="background: var(--rz-base-background-color); border: 1px solid var(--rz-base-300);">
                            <RadzenIcon Icon="@(logPath.DirectoryExists && logPath.Writable ? "check_circle" : "cancel")"
                                       Style="@($"color: var(--rz-{(logPath.DirectoryExists && logPath.Writable ? "success" : "danger")});")"/>
                            <RadzenStack Gap="0" Style="flex: 1;">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-color);"><strong>@logPath.SinkName</strong></RadzenText>
                                    <RadzenBadge BadgeStyle="@(logPath.DirectoryExists ? BadgeStyle.Success : BadgeStyle.Danger)"
                                                Text="@(logPath.DirectoryExists ? L("AdminDoctor.DirectoryExists") : L("AdminDoctor.DirectoryMissing"))"/>
                                    @if (logPath.DirectoryExists)
                                    {
                                        <RadzenBadge BadgeStyle="@(logPath.Writable ? BadgeStyle.Success : BadgeStyle.Warning)"
                                                    Text="@(logPath.Writable ? L("AdminDoctor.Writable") : L("AdminDoctor.NotWritable"))"/>
                                    }
                                </RadzenStack>
                                <RadzenText TextStyle="TextStyle.Caption" Style="word-break: break-all; font-family: monospace; color: var(--rz-text-secondary-color);">@logPath.Path</RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    }
                </RadzenStack>
            </RadzenCard>
        }

        @* Search Engine API Keys *@
        @if (_searchEngineApiKeys.Any())
        {
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="vpn_key" class="rz-me-1"/>
                    @L("AdminDoctor.SearchEngineApiKeys")
                </RadzenText>
                <RadzenStack Gap="0.5rem" class="rz-mt-2">
                    @foreach (var apiKey in _searchEngineApiKeys)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center" class="rz-p-2 rz-border-radius-1" Style="background: var(--rz-base-background-color); border: 1px solid var(--rz-base-300);">
                            <RadzenIcon Icon="@GetApiKeyIcon(apiKey.IsEnabled, apiKey.IsConfigured)" Style="@apiKey.StatusStyle"/>
                            <RadzenStack Gap="0" Style="flex: 1;">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-color);"><strong>@apiKey.EngineName</strong></RadzenText>
                                    @if (apiKey.IsEnabled && !apiKey.IsConfigured)
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@L("AdminDoctor.MissingApiKey")"/>
                                    }
                                    else if (apiKey.IsEnabled)
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("AdminDoctor.Enabled")"/>
                                    }
                                    else
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@L("AdminDoctor.Disabled")"/>
                                    }
                                </RadzenStack>
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">@apiKey.Status</RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    }
                </RadzenStack>
            </RadzenCard>
        }

        @* Environment Variables *@
        @if (_relevantEnvVars.Any())
        {
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="tune" class="rz-me-1"/>
                    @L("AdminDoctor.RelevantEnvVars")
                </RadzenText>
                <RadzenStack Gap="0.5rem" class="rz-mt-2">
                    @foreach (var envVar in _relevantEnvVars)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" class="rz-p-2 rz-border-radius-1" Style="background: var(--rz-base-background-color); border: 1px solid var(--rz-base-300);">
                            <RadzenIcon Icon="@(envVar.IsSet ? "check" : "remove")"
                                       Style="@($"color: var(--rz-{(envVar.IsSet ? "success" : "secondary")});")"/>
                            <RadzenStack Gap="0" Style="flex: 1;">
                                <RadzenText TextStyle="TextStyle.Body2" Style="font-family: monospace; color: var(--rz-text-color);">@envVar.Name</RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
                                    @(envVar.IsSet ? envVar.MaskedValue : L("AdminDoctor.NotSet"))
                                </RadzenText>
                            </RadzenStack>
                        </RadzenStack>
                    }
                </RadzenStack>
            </RadzenCard>
        }
    }
</RadzenStack>

@code {
    private bool _isLoading = true;
    private bool _allChecksPassed;
    private TimeSpan _totalDuration;
    private bool _isMusicBrainzEmpty;
    private bool _isMusicBrainzJobRunning;

    private List<CheckResult> _checks = [];
    private List<LibraryPathResult> _libraryPaths = [];
    private List<ConfigurableServiceResult> _configurableServices = [];
    private List<KeyValuePair<string, string>> _environmentInfo = [];
    private List<ConnectionStringInfo> _connectionStrings = [];
    private List<EnvironmentVariableInfo> _relevantEnvVars = [];
    private List<SerilogLogPathInfo> _serilogLogPaths = [];
    private List<SearchEngineApiKeyInfoLocal> _searchEngineApiKeys = [];
    private List<QuickStatusBadge> _quickStatusBadges = [];

    private static readonly DateTime StartTime = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await RunDiagnosticsAsync();
    }

    private async Task TriggerMusicBrainzJobAsync()
    {
        try
        {
            _isMusicBrainzJobRunning = true;
            StateHasChanged();

            var scheduler = await SchedulerFactory.GetScheduler();
            await scheduler.TriggerJob(JobKeyRegistry.MusicBrainzUpdateDatabaseJobKey);

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = L("AdminDoctor.JobStarted"),
                Detail = L("AdminDoctor.MusicBrainzJobDescription"),
                Duration = ToastTime * 3
            });
        }
        catch (Exception ex)
        {
            Log.Error(ex, "[Doctor] Failed to trigger MusicBrainz update job");
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("AdminDoctor.JobFailed"),
                Detail = ex.Message,
                Duration = ToastTime
            });
        }
        finally
        {
            _isMusicBrainzJobRunning = false;
            StateHasChanged();
        }
    }

    private async Task RunDiagnosticsAsync()
    {
        _isLoading = true;
        _isMusicBrainzEmpty = false;
        StateHasChanged();

        var stopwatch = Stopwatch.StartNew();

        _checks.Clear();
        _libraryPaths.Clear();
        _configurableServices.Clear();
        _environmentInfo.Clear();
        _connectionStrings.Clear();
        _relevantEnvVars.Clear();
        _serilogLogPaths.Clear();
        _searchEngineApiKeys.Clear();

        // Environment Information (UI-specific, kept local)
        LoadEnvironmentInfo();

        // Run all checks via DoctorService
        var results = await DoctorService.RunAllChecksAsync();
        
        // Map results to local types with localized names
        foreach (var check in results.Checks)
        {
            var localizedName = GetLocalizedCheckName(check.Name);
            var localizedDetails = GetLocalizedCheckDetails(check.Name, check.Details, check.Success);
            _checks.Add(new CheckResult(localizedName, check.Success, localizedDetails, check.Duration));
        }
        
        // Map library paths with localized details and disk space info
        foreach (var path in results.LibraryPaths)
        {
            var localizedDetails = GetLibraryPathDetails(path.Exists, path.Writable);
            
            // Find matching disk space info for this library path
            var diskInfo = results.DiskSpaceInfo.FirstOrDefault(d => d.Name == path.Name);
            var (diskStatus, diskStatusStyle) = diskInfo?.Status switch
            {
                Blazor.Services.DiskSpaceStatus.Critical => (L("AdminDoctor.Critical"), "color: var(--rz-danger);"),
                Blazor.Services.DiskSpaceStatus.Warning => (L("AdminDoctor.Warning"), "color: var(--rz-warning);"),
                Blazor.Services.DiskSpaceStatus.Ok => (L("AdminDoctor.Ok"), "color: var(--rz-success);"),
                _ => (L("AdminDoctor.Unknown"), "color: var(--rz-secondary);")
            };
            
            _libraryPaths.Add(new LibraryPathResult(
                path.Name, 
                path.Type, 
                path.Path, 
                path.Exists, 
                path.Writable, 
                localizedDetails,
                diskInfo?.TotalBytes ?? 0,
                diskInfo?.AvailableBytes ?? 0,
                diskInfo?.UsedPercent ?? 0,
                diskStatus,
                diskStatusStyle));
        }
        
        // Map configurable services
        foreach (var service in results.ConfigurableServices)
        {
            _configurableServices.Add(new ConfigurableServiceResult(service.Category, service.Name, service.SettingKey, service.Enabled));
        }
        
        // Map Serilog log paths
        foreach (var logPath in results.SerilogLogPaths)
        {
            _serilogLogPaths.Add(new SerilogLogPathInfo(logPath.SinkName, logPath.Path, logPath.DirectoryExists, logPath.Writable));
        }
        
        // Map connection strings
        foreach (var connStr in results.ConnectionStrings)
        {
            _connectionStrings.Add(new ConnectionStringInfo(connStr.Name, connStr.MaskedValue, connStr.IsValid, connStr.IsFileBased, connStr.FileExists, connStr.FileWritable, connStr.FilePath));
        }
        
        // Map environment variables
        foreach (var envVar in results.EnvironmentVariables)
        {
            _relevantEnvVars.Add(new EnvironmentVariableInfo(envVar.Name, envVar.MaskedValue, envVar.IsSet));
        }
        
        // Map search engine API keys
        foreach (var apiKey in results.SearchEngineApiKeys)
        {
            var statusStyle = (apiKey.IsEnabled, apiKey.IsConfigured) switch
            {
                (true, true) => "color: var(--rz-success);",
                (true, false) => "color: var(--rz-warning);",
                (false, true) => "color: var(--rz-secondary);",
                (false, false) => "color: var(--rz-secondary);"
            };
            _searchEngineApiKeys.Add(new SearchEngineApiKeyInfoLocal(apiKey.EngineName, apiKey.SettingKey, apiKey.IsEnabled, apiKey.IsConfigured, apiKey.Status, statusStyle));
        }
        
        _isMusicBrainzEmpty = results.IsMusicBrainzEmpty;

        // Build quick status badges for key services
        _quickStatusBadges.Clear();
        var dbCheck = _checks.FirstOrDefault(c => c.Name == L("AdminDoctor.Check.PostgresDatabase"));
        if (dbCheck != null)
        {
            _quickStatusBadges.Add(new QuickStatusBadge(
                L("AdminDoctor.Database"),
                dbCheck.Success ? "storage" : "error",
                dbCheck.Success ? BadgeStyle.Success : BadgeStyle.Danger,
                dbCheck.Details));
        }
        
        var mbCheck = _checks.FirstOrDefault(c => c.Name == L("AdminDoctor.Check.MusicBrainzDatabase"));
        if (mbCheck != null)
        {
            _quickStatusBadges.Add(new QuickStatusBadge(
                "MusicBrainz",
                mbCheck.Success ? "album" : (_isMusicBrainzEmpty ? "warning" : "error"),
                mbCheck.Success ? BadgeStyle.Success : (_isMusicBrainzEmpty ? BadgeStyle.Warning : BadgeStyle.Danger),
                mbCheck.Details));
        }
        
        var diskCheck = _checks.FirstOrDefault(c => c.Name == L("AdminDoctor.Check.DiskSpace"));
        if (diskCheck != null)
        {
            _quickStatusBadges.Add(new QuickStatusBadge(
                L("AdminDoctor.Storage"),
                diskCheck.Success ? "folder" : "folder_off",
                diskCheck.Success ? BadgeStyle.Success : BadgeStyle.Warning,
                diskCheck.Details));
        }

        stopwatch.Stop();
        _totalDuration = stopwatch.Elapsed;
        _allChecksPassed = _checks.All(c => c.Success);

        _isLoading = false;
        StateHasChanged();
    }
    
    private string GetLocalizedCheckName(string checkName) => checkName switch
    {
        "Configuration" => L("AdminDoctor.Check.Configuration"),
        "PostgresDatabase" => L("AdminDoctor.Check.PostgresDatabase"),
        "MusicBrainzDatabase" => L("AdminDoctor.Check.MusicBrainzDatabase"),
        "ArtistSearchEngineDatabase" => L("AdminDoctor.Check.ArtistSearchEngineDatabase"),
        "LibraryPaths" => L("AdminDoctor.Check.LibraryPaths"),
        "SerilogLogging" => L("AdminDoctor.Check.SerilogLogging"),
        "ConfigurableServices" => L("AdminDoctor.Check.ConfigurableServices"),
        "DiskSpace" => L("AdminDoctor.Check.DiskSpace"),
        "LibraryPathOverlap" => L("AdminDoctor.Check.LibraryPathOverlap"),
        "SearchEngineApiKeys" => L("AdminDoctor.Check.SearchEngineApiKeys"),
        "SmtpConfiguration" => L("AdminDoctor.Check.SmtpConfiguration"),
        "JwtTokenStrength" => L("AdminDoctor.Check.JwtTokenStrength"),
        "HttpsSecurity" => L("AdminDoctor.Check.HttpsSecurity"),
        "AdminPassword" => L("AdminDoctor.Check.AdminPassword"),
        _ => checkName
    };
    
    private string GetLocalizedCheckDetails(string checkName, string details, bool success)
    {
        // For MusicBrainz empty state, use localized message
        if (checkName == "MusicBrainzDatabase" && !success && details.Contains("empty"))
        {
            return L("AdminDoctor.MusicBrainzDatabaseEmpty");
        }
        
        // For library path issues
        if (checkName == "LibraryPaths" && !success)
        {
            if (details.Contains("missing") && details.Contains("writable"))
                return L("AdminDoctor.LibraryPathsMissingAndNotWritable");
            if (details.Contains("missing"))
                return L("AdminDoctor.LibraryPathsMissing");
            if (details.Contains("writable"))
                return L("AdminDoctor.LibraryPathsNotWritable");
        }
        
        if (checkName == "LibraryPaths" && success)
        {
            return L("AdminDoctor.AllLibraryPathsOk");
        }
        
        // For Serilog
        if (checkName == "SerilogLogging")
        {
            if (details.Contains("No file logging"))
                return L("AdminDoctor.NoFileLoggingConfigured");
            if (!success)
                return L("AdminDoctor.SerilogPathIssues");
            return L("AdminDoctor.SerilogPathsOk");
        }
        
        // For configurable services, format the message
        if (checkName == "ConfigurableServices" && details.Contains(" of "))
        {
            var parts = details.Split(' ');
            if (parts.Length >= 4 && int.TryParse(parts[0], out var enabled) && int.TryParse(parts[2], out var total))
            {
                return L("AdminDoctor.ServicesEnabled", enabled, total);
            }
        }
        
        // For disk space
        if (checkName == "DiskSpace")
        {
            if (details.Contains("Critical"))
                return L("AdminDoctor.DiskSpaceCritical");
            if (details.Contains("Warning"))
                return L("AdminDoctor.DiskSpaceWarning");
            return L("AdminDoctor.DiskSpaceOk");
        }
        
        // For library path overlap
        if (checkName == "LibraryPathOverlap")
        {
            if (!success)
                return L("AdminDoctor.LibraryPathOverlapDetected");
            return L("AdminDoctor.NoLibraryPathOverlap");
        }
        
        // For search engine API keys
        if (checkName == "SearchEngineApiKeys")
        {
            if (!success)
                return L("AdminDoctor.SearchEngineApiKeysMissing");
            return L("AdminDoctor.SearchEngineApiKeysOk");
        }
        
        return details;
    }
    
    private string GetLibraryPathDetails(bool exists, bool writable)
    {
        return (exists, writable) switch
        {
            (false, _) => L("AdminDoctor.PathMissing"),
            (true, false) => L("AdminDoctor.PathNotWritable"),
            (true, true) => L("AdminDoctor.PathOk")
        };
    }

    private void LoadEnvironmentInfo()
    {
        _environmentInfo =
        [
            new KeyValuePair<string, string>(L("AdminDoctor.DotNetVersion"), RuntimeInformation.FrameworkDescription),
            new KeyValuePair<string, string>(L("AdminDoctor.OSDescription"), RuntimeInformation.OSDescription),
            new KeyValuePair<string, string>(L("AdminDoctor.OSArchitecture"), RuntimeInformation.OSArchitecture.ToString()),
            new KeyValuePair<string, string>(L("AdminDoctor.ProcessArchitecture"), RuntimeInformation.ProcessArchitecture.ToString()),
            new KeyValuePair<string, string>(L("AdminDoctor.MelodeeVersion"), typeof(Program).Assembly.GetName().Version?.ToString() ?? "Unknown"),
            new KeyValuePair<string, string>(L("AdminDoctor.Environment"), WebHostEnvironment.EnvironmentName),
            new KeyValuePair<string, string>(L("AdminDoctor.ContentRootPath"), WebHostEnvironment.ContentRootPath),
            new KeyValuePair<string, string>(L("AdminDoctor.WebRootPath"), WebHostEnvironment.WebRootPath),
            new KeyValuePair<string, string>(L("AdminDoctor.ServerTimeUtc"), DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")),
            new KeyValuePair<string, string>(L("AdminDoctor.Uptime"), FormatUptime(DateTime.UtcNow - StartTime)),
            new KeyValuePair<string, string>(L("AdminDoctor.ProcessId"), Environment.ProcessId.ToString()),
            new KeyValuePair<string, string>(L("AdminDoctor.MachineName"), Environment.MachineName)
        ];
    }

    private async Task CopyJsonToClipboard()
    {
        var diagnosticData = new
        {
            // Metadata
            exportedAt = DateTime.UtcNow.ToString("o"),
            melodeeVersion = typeof(Program).Assembly.GetName().Version?.ToString() ?? "Unknown",
            diagnosticDurationSeconds = _totalDuration.TotalSeconds,
            overallStatus = _allChecksPassed ? "Passed" : "Issues Found",
            
            // System Environment
            system = new
            {
                dotNetVersion = RuntimeInformation.FrameworkDescription,
                osDescription = RuntimeInformation.OSDescription,
                osArchitecture = RuntimeInformation.OSArchitecture.ToString(),
                processArchitecture = RuntimeInformation.ProcessArchitecture.ToString(),
                machineName = Environment.MachineName,
                processId = Environment.ProcessId,
                processorCount = Environment.ProcessorCount,
                workingSetMb = Environment.WorkingSet / 1024 / 1024,
                is64BitProcess = Environment.Is64BitProcess,
                is64BitOperatingSystem = Environment.Is64BitOperatingSystem
            },
            
            // Application Environment
            application = new
            {
                environment = WebHostEnvironment.EnvironmentName,
                contentRootPath = WebHostEnvironment.ContentRootPath,
                webRootPath = WebHostEnvironment.WebRootPath,
                serverTimeUtc = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss"),
                uptime = FormatUptime(DateTime.UtcNow - StartTime),
                uptimeSeconds = (DateTime.UtcNow - StartTime).TotalSeconds
            },
            
            // All System Checks
            checks = _checks.Select(c => new 
            { 
                name = c.Name, 
                success = c.Success, 
                details = c.Details, 
                durationMs = (int)c.Duration.TotalMilliseconds 
            }),
            
            // Library Paths with Disk Space
            libraryPaths = _libraryPaths.Select(l => new 
            { 
                name = l.Name, 
                type = l.Type, 
                path = l.Path, 
                exists = l.Exists,
                writable = l.Writable,
                diskSpace = new
                {
                    totalBytes = l.TotalBytes,
                    totalFormatted = FormatBytes(l.TotalBytes),
                    availableBytes = l.AvailableBytes,
                    availableFormatted = FormatBytes(l.AvailableBytes),
                    usedPercent = l.UsedPercent,
                    status = l.DiskStatus
                }
            }),
            
            // Configurable Services
            configurableServices = _configurableServices
                .OrderBy(s => s.Category)
                .ThenBy(s => s.Name)
                .Select(s => new 
                { 
                    category = s.Category, 
                    name = s.Name, 
                    settingKey = s.SettingKey, 
                    enabled = s.Enabled 
                }),
            
            // Connection Strings (masked)
            connectionStrings = _connectionStrings.Select(c => new 
            { 
                name = c.Name, 
                maskedValue = c.MaskedValue,
                isValid = c.IsValid,
                isFileBased = c.IsFileBased,
                fileExists = c.FileExists,
                fileWritable = c.FileWritable
            }),
            
            // Serilog Log Paths
            serilogLogPaths = _serilogLogPaths.Select(l => new
            {
                sinkName = l.SinkName,
                path = l.Path,
                directoryExists = l.DirectoryExists,
                writable = l.Writable
            }),
            
            // Search Engine API Keys
            searchEngineApiKeys = _searchEngineApiKeys.Select(k => new
            {
                engineName = k.EngineName,
                settingKey = k.SettingKey,
                isEnabled = k.IsEnabled,
                isConfigured = k.IsConfigured,
                status = k.Status
            }),
            
            // Environment Variables (if any)
            environmentVariables = _relevantEnvVars.Select(e => new 
            { 
                name = e.Name, 
                isSet = e.IsSet,
                maskedValue = e.MaskedValue
            }),
            
            // MusicBrainz Status
            musicBrainz = new
            {
                isEmpty = _isMusicBrainzEmpty,
                status = _isMusicBrainzEmpty ? "Empty - needs population" : "Populated"
            },
            
            // Summary Statistics
            summary = new
            {
                totalChecks = _checks.Count,
                passedChecks = _checks.Count(c => c.Success),
                failedChecks = _checks.Count(c => !c.Success),
                totalLibraries = _libraryPaths.Count,
                librariesWithIssues = _libraryPaths.Count(l => !l.Exists || !l.Writable),
                enabledServices = _configurableServices.Count(s => s.Enabled),
                totalServices = _configurableServices.Count,
                searchEnginesWithIssues = _searchEngineApiKeys.Count(k => k.IsEnabled && !k.IsConfigured)
            }
        };

        var json = JsonSerializer.Serialize(diagnosticData, new JsonSerializerOptions { WriteIndented = true });

        // Use JavaScript interop to copy to clipboard
        await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", json);

        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Success,
            Summary = L("AdminDoctor.JsonCopied"),
            Duration = ToastTime
        });
    }

    private static string FormatUptime(TimeSpan uptime)
    {
        if (uptime.TotalDays >= 1)
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        if (uptime.TotalHours >= 1)
            return $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        return $"{uptime.Minutes}m {uptime.Seconds}s";
    }

    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;

