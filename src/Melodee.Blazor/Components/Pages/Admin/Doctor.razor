    private sealed record ConfigurableServiceResult(string Category, string Name, string SettingKey, bool Enabled);
    private sealed record ConnectionStringInfo(string Name, string MaskedValue, bool IsValid, bool IsFileBased, bool? FileExists, bool? FileWritable, string? FilePath);
    private sealed record EnvironmentVariableInfo(string Name, string MaskedValue, bool IsSet);
    private sealed record SerilogLogPathInfo(string SinkName, string Path, bool DirectoryExists, bool Writable);
    private sealed record SearchEngineApiKeyInfoLocal(string EngineName, string SettingKey, bool IsEnabled, bool IsConfigured, string Status, string StatusStyle);
    private sealed record QuickStatusBadge(string Name, string Icon, BadgeStyle BadgeStyle, string Details);

    private static string GetDiskSpaceIcon(string status) => status switch
    {
        _ when status.Contains("Critical", StringComparison.OrdinalIgnoreCase) => "error",
        _ when status.Contains("Warning", StringComparison.OrdinalIgnoreCase) => "warning",
        _ when status.Contains("Ok", StringComparison.OrdinalIgnoreCase) => "check_circle",
        _ => "help"
    };
    
    private static string GetApiKeyIcon(bool isEnabled, bool isConfigured) => (isEnabled, isConfigured) switch
    {
        (true, true) => "check_circle",
        (true, false) => "warning",
        (false, _) => "radio_button_unchecked"
    };
    
    private static string FormatBytes(long bytes)
    {
        string[] suffixes = ["B", "KB", "MB", "GB", "TB", "PB"];
        var counter = 0;
        var number = (double)bytes;
        while (Math.Round(number / 1024) >= 1)
        {
            number /= 1024;
            counter++;
        }
        return $"{number:F2} {suffixes[counter]}";
    }
