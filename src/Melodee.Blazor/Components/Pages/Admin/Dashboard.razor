@page "/admin/dashboard"
@using System.Runtime.InteropServices
@using Melodee.Blazor.Constants
@using Melodee.Common.Data
@using Melodee.Common.Enums
@using Melodee.Common.Models
@using Melodee.Common.Models.Scrobbling
@using Melodee.Common.Plugins.Scrobbling
@using Melodee.Common.Services.Caching
@using Microsoft.EntityFrameworkCore
@using NodaTime
@using Quartz
@using Quartz.Impl.Matchers
@inherits MelodeeComponentBase

@inject IMelodeeConfigurationFactory MelodeeConfigurationFactory
@inject ICacheManager CacheManager
@inject INowPlayingRepository NowPlayingRepository
@inject NotificationService NotificationService
@inject StatisticsService StatisticsService
@inject LibraryService LibraryService
@inject IDbContextFactory<MelodeeDbContext> DbContextFactory
@inject ISchedulerFactory SchedulerFactory
@inject NavigationManager NavigationManager

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>@L("AdminDashboard.PageTitle")</PageTitle>

<RadzenStack Gap="1rem">
    @* Header with quick actions *@
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">
                <RadzenIcon Icon="dashboard" class="rz-me-1"/>
                @L("AdminDashboard.PageTitle")
            </RadzenText>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem" Wrap="FlexWrap.Wrap">
                <RadzenButton Icon="refresh" Text="@L("Actions.Refresh")" Click="@RefreshDashboard" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Primary"/>
                <RadzenButton Icon="sweep" Text="@L("Actions.ClearCache")" Click="@ClearCacheClicked" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Warning"/>
                <RadzenButton Icon="stop_circle" Text="@L("Actions.ClearNowPlaying")" Click="@ClearNowPlayingClicked" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Warning"/>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    @* Quick Links *@
    <RadzenCard>
      <RadzenText TextStyle="TextStyle.H6">
        <RadzenIcon Icon="link" class="rz-me-1"/>
        @L("AdminDashboard.QuickLinks")
      </RadzenText>
      <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" Wrap="FlexWrap.Wrap" class="rz-mt-2">
        <RadzenButton Text="@L("Navigation.Settings")" Icon="settings" Click="@(() => NavigationManager.NavigateTo("/admin/settings"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
        <RadzenButton Text="@L("Navigation.Users")" Icon="group" Click="@(() => NavigationManager.NavigateTo("/data/users"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
        <RadzenButton Text="@L("Navigation.Libraries")" Icon="library_music" Click="@(() => NavigationManager.NavigateTo("/data/libraries"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
        <RadzenButton Text="@L("Navigation.Artists")" Icon="person" Click="@(() => NavigationManager.NavigateTo("/data/artists"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
        <RadzenButton Text="@L("Navigation.Albums")" Icon="album" Click="@(() => NavigationManager.NavigateTo("/data/albums"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
        <RadzenButton Text="@L("Navigation.Songs")" Icon="music_note" Click="@(() => NavigationManager.NavigateTo("/data/songs"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
        <RadzenButton Text="@L("AdminDashboard.APIDocs")" Icon="description" Click="@(() => NavigationManager.NavigateTo("/scalar/v1", forceLoad: true))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info"/>
      </RadzenStack>
    </RadzenCard>

    @* System Health Overview *@
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenCard class="rz-background-color-success-lighter" Style="height: 100%;">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenIcon Icon="check_circle" Style="font-size: 2rem; color: var(--rz-success);"/>
                    <RadzenText TextStyle="TextStyle.Overline">@L("AdminDashboard.SystemStatus")</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5" Style="color: var(--rz-success);">@L("Status.Online")</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenCard Style="height: 100%;">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenIcon Icon="headphones" Style="font-size: 2rem; color: var(--rz-info);"/>
                    <RadzenText TextStyle="TextStyle.Overline">@L("Navigation.NowPlaying")</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5">@_nowPlayingCount</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenCard Style="height: 100%;">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenIcon Icon="group" Style="font-size: 2rem; color: var(--rz-primary);"/>
                    <RadzenText TextStyle="TextStyle.Overline">@L("AdminDashboard.TotalUsers")</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5">@_userCount</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="3">
            <RadzenCard Style="height: 100%;">
                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                    <RadzenIcon Icon="schedule" Style="font-size: 2rem; color: var(--rz-secondary);"/>
                    <RadzenText TextStyle="TextStyle.Overline">@L("AdminDashboard.Uptime")</RadzenText>
                    <RadzenText TextStyle="TextStyle.H5">@_uptime</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    @* Library Statistics *@
    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6">
            <RadzenIcon Icon="library_music" class="rz-me-1"/>
            @L("AdminDashboard.LibraryOverview")
        </RadzenText>
        <RadzenRow Gap="1rem" class="rz-mt-2">
            @foreach (var stat in _libraryStats)
            {
                <RadzenColumn Size="6" SizeMD="3" SizeLG="2">
                    <RadzenStack Gap="0.25rem">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                            <RadzenIcon Icon="@stat.Icon" Style="font-size: 1.25rem;"/>
                            <RadzenText TextStyle="TextStyle.Caption">@stat.Title</RadzenText>
                        </RadzenStack>
                        <RadzenText TextStyle="TextStyle.H5">
                            @if (stat.Type == StatisticType.Count)
                            {
                                @($"{stat.DataAsInt:N0}")
                            }
                            else
                            {
                                @stat.Data
                            }
                        </RadzenText>
                    </RadzenStack>
                </RadzenColumn>
            }
        </RadzenRow>
    </RadzenCard>

    @* Charts Row *@
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="trending_up" class="rz-me-1"/>
                    @L("AdminDashboard.SongsAddedLast30Days")
                </RadzenText>
                @if (_songsAddedPerDay.Length > 0)
                {
                    <RadzenChart Style="height: 280px;">
                        <RadzenAreaSeries Data="@_songsAddedPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value" Title="@L("Navigation.Songs")" Fill="var(--rz-primary-light)" Stroke="var(--rz-primary)">
                            <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                                <RadzenAxisTitle Text="@L("AdminDashboard.Date")"/>
                            </RadzenCategoryAxis>
                            <RadzenValueAxis>
                                <RadzenAxisTitle Text="@L("Navigation.Songs")"/>
                            </RadzenValueAxis>
                        </RadzenAreaSeries>
                    </RadzenChart>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mt-4">@L("Messages.NoData")</RadzenText>
                }
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="search" class="rz-me-1"/>
                    @L("AdminDashboard.SearchActivityLast30Days")
                </RadzenText>
                @if (_searchesPerDay.Length > 0)
                {
                    <RadzenChart Style="height: 280px;">
                        <RadzenAreaSeries Data="@_searchesPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value" Title="@L("AdminDashboard.Searches")" Fill="var(--rz-info-light)" Stroke="var(--rz-info)">
                            <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                                <RadzenAxisTitle Text="@L("AdminDashboard.Date")"/>
                            </RadzenCategoryAxis>
                            <RadzenValueAxis>
                                <RadzenAxisTitle Text="@L("AdminDashboard.Searches")"/>
                            </RadzenValueAxis>
                        </RadzenAreaSeries>
                    </RadzenChart>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mt-4">@L("Messages.NoData")</RadzenText>
                }
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    @* Libraries and Jobs Row *@
    <RadzenRow Gap="1rem">
        @* Library Status *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H6">
                        <RadzenIcon Icon="folder" class="rz-me-1"/>
                        @L("AdminDashboard.LibraryStatus")
                    </RadzenText>
                    <RadzenButton Text="@L("Actions.Manage")" Icon="settings" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/data/libraries"))"/>
                </RadzenStack>
                <RadzenDataGrid TItem="LibraryInfo" Data="@_libraries" AllowPaging="false" AllowSorting="false" Density="Density.Compact" class="rz-mt-2">
                    <Columns>
                        <RadzenDataGridColumn TItem="LibraryInfo" Property="Name" Title="@L("Common.Name")" Width="180px"/>
                        <RadzenDataGridColumn TItem="LibraryInfo" Property="TypeLabel" Title="@L("Common.Type")" Width="100px"/>
                        <RadzenDataGridColumn TItem="LibraryInfo" Title="@L("AdminDashboard.LastScan")">
                            <Template Context="lib">
                                @if (lib.LastScanAt.HasValue)
                                {
                                    @lib.LastScanAt.Value.ToString("yyyy-MM-dd HH:mm", null)
                                }
                                else
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-warning);">@L("AdminDashboard.Never")</RadzenText>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="LibraryInfo" Title="@L("Common.Status")" Width="100px">
                            <Template Context="lib">
                                @if (lib.NeedsScanning)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@L("AdminDashboard.NeedsScan")" Shade="Shade.Light"/>
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("Data.OK")" Shade="Shade.Light"/>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenColumn>

        @* Scheduled Jobs *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H6">
                        <RadzenIcon Icon="schedule" class="rz-me-1"/>
                        @L("AdminDashboard.ScheduledJobs")
                    </RadzenText>
                    <RadzenButton Text="@L("Actions.Manage")" Icon="settings" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/admin/jobs"))"/>
                </RadzenStack>
                <RadzenDataGrid TItem="JobInfo" Data="@_jobs" AllowPaging="false" AllowSorting="false" Density="Density.Compact" class="rz-mt-2">
                    <Columns>
                        <RadzenDataGridColumn TItem="JobInfo" Property="Name" Title="@L("AdminDashboard.Job")" Width="200px"/>
                        <RadzenDataGridColumn TItem="JobInfo" Title="@L("AdminDashboard.LastRun")">
                            <Template Context="job">
                                <RadzenText TextStyle="TextStyle.Caption">@job.PreviousFireTime</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="JobInfo" Title="@L("AdminDashboard.NextRun")">
                            <Template Context="job">
                                <RadzenText TextStyle="TextStyle.Caption">@job.NextFireTime</RadzenText>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    @* Now Playing and Recent Activity *@
    <RadzenRow Gap="1rem">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenText TextStyle="TextStyle.H6">
                        <RadzenIcon Icon="headphones" class="rz-me-1"/>
                        @L("Navigation.NowPlaying")
                    </RadzenText>
                    <RadzenButton Text="@L("Actions.ViewAll")" Icon="open_in_new" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/activity/nowplaying"))"/>
                </RadzenStack>
                @if (_nowPlayingItems.Length == 0)
                {
                    <RadzenText TextStyle="TextStyle.Body2" class="rz-mt-2" Style="color: var(--rz-text-secondary-color);">@L("Message.NoActiveListeners")</RadzenText>
                }
                else
                {
                    <RadzenDataGrid TItem="NowPlayingInfo" Data="@_nowPlayingItems" AllowPaging="false" AllowSorting="false" Density="Density.Compact" class="rz-mt-2">
                        <Columns>
                            <RadzenDataGridColumn TItem="NowPlayingInfo" Title="@L("AdminDashboard.User")" Width="120px">
                                <Template Context="np">@np.User.UserName</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="NowPlayingInfo" Title="@L("Common.Song")">
                                <Template Context="np">@np.Scrobble.SongTitle</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="NowPlayingInfo" Title="@L("Common.Artist")">
                                <Template Context="np">@np.Scrobble.ArtistName</Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            </RadzenCard>
        </RadzenColumn>

        @* Missing Images *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="image_not_supported" class="rz-me-1"/>
                    @L("AdminDashboard.ContentHealth")
                </RadzenText>
                <RadzenDataGrid TItem="Statistic" Data="@_missingImages" AllowPaging="false" AllowSorting="false" Density="Density.Compact" class="rz-mt-2">
                    <Columns>
                        <RadzenDataGridColumn TItem="Statistic" Property="Title" Title="@L("Stats.ItemColumnTitle")"/>
                        <RadzenDataGridColumn TItem="Statistic" Title="@L("Stats.CountColumnTitle")" Width="100px">
                            <Template Context="stat">
                                @if (stat.DataAsInt > 0)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@stat.DataAsInt?.ToString("N0")" Shade="Shade.Light"/>
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="0" Shade="Shade.Light"/>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    @* System Info and Cache *@
    <RadzenRow Gap="1rem">
        @* System Information *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="info" class="rz-me-1"/>
                    @L("AdminDashboard.SystemInformation")
                </RadzenText>
                <RadzenStack Gap="0.5rem" class="rz-mt-2">
                    <RadzenRow>
                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminDashboard.ServerTimeUTC")</RadzenText></RadzenColumn>
                        <RadzenColumn Size="6"><RadzenText>@_serverTimeUtc</RadzenText></RadzenColumn>
                    </RadzenRow>
                    <RadzenRow>
                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminDashboard.DotNetVersion")</RadzenText></RadzenColumn>
                        <RadzenColumn Size="6"><RadzenText>@_dotNetVersion</RadzenText></RadzenColumn>
                    </RadzenRow>
                    <RadzenRow>
                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminDashboard.MelodeeVersion")</RadzenText></RadzenColumn>
                        <RadzenColumn Size="6"><RadzenText>@_melodeeVersion</RadzenText></RadzenColumn>
                    </RadzenRow>
                    <RadzenRow>
                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminDashboard.APIVersion")</RadzenText></RadzenColumn>
                        <RadzenColumn Size="6"><RadzenText>@_apiVersion</RadzenText></RadzenColumn>
                    </RadzenRow>
                    <RadzenRow>
                        <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.Caption">@L("AdminDashboard.OS")</RadzenText></RadzenColumn>
                        <RadzenColumn Size="6"><RadzenText>@_osDescription</RadzenText></RadzenColumn>
                    </RadzenRow>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>

        @* Cache Statistics *@
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard Style="height: 100%;">
                <RadzenText TextStyle="TextStyle.H6">
                    <RadzenIcon Icon="memory" class="rz-me-1"/>
                    @L("AdminDashboard.CacheStatistics")
                </RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" Wrap="FlexWrap.Wrap" class="rz-mt-2">
                    @if (_cacheStatistics != null)
                    {
                        @foreach (var stat in _cacheStatistics)
                        {
                            <RadzenCard Variant="Variant.Outlined" Style="min-width: 140px; flex: 1;">
                                <RadzenStack Gap="0.25rem" AlignItems="AlignItems.Center">
                                    <RadzenText TextStyle="TextStyle.Caption">@stat.Title</RadzenText>
                                    <RadzenText TextStyle="TextStyle.H6">@stat.Data</RadzenText>
                                </RadzenStack>
                            </RadzenCard>
                        }
                    }
                    else
                    {
                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate"/>
                    }
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {
    private IEnumerable<Statistic>? _cacheStatistics;
    private Statistic[] _libraryStats = [];
    private Statistic[] _missingImages = [];
    private TimeSeriesPoint[] _songsAddedPerDay = [];
    private TimeSeriesPoint[] _searchesPerDay = [];
    private LibraryInfo[] _libraries = [];
    private JobInfo[] _jobs = [];
    private NowPlayingInfo[] _nowPlayingItems = [];

    private int _nowPlayingCount;
    private int _userCount;
    private string _uptime = "---";
    private string _serverTimeUtc = "---";
    private string _dotNetVersion = "---";
    private string _melodeeVersion = "---";
    private string _apiVersion = "---";
    private string _osDescription = "---";

    private LocalDate _rangeStart;
    private LocalDate _rangeEnd;
    private static readonly DateTime StartTime = DateTime.UtcNow;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadDashboardDataAsync();
    }

    private async Task RefreshDashboard()
    {
        await LoadDashboardDataAsync();
        StateHasChanged();
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Info,
            Summary = L("Notification.DashboardRefreshed"),
            Duration = ToastTime
        });
    }

    private async Task LoadDashboardDataAsync()
    {
        var zone = DateTimeZone.Utc;
        var today = SystemClock.Instance.GetCurrentInstant().InZone(zone).Date;
        _rangeEnd = today;
        _rangeStart = today.PlusDays(-29);

        // Load system info
        _serverTimeUtc = SystemClock.Instance.GetCurrentInstant().InUtc().LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss", null);
        _dotNetVersion = RuntimeInformation.FrameworkDescription;
        _melodeeVersion = typeof(Program).Assembly.GetName().Version?.ToString() ?? "Unknown";
        _osDescription = RuntimeInformation.OSDescription;
        _uptime = FormatUptime(DateTime.UtcNow - StartTime);

        var config = await MelodeeConfigurationFactory.GetConfigurationAsync();
        _apiVersion = _melodeeVersion;

        // Load cache statistics
        _cacheStatistics = CacheManager.CacheStatistics();

        // Load all data in parallel
        var statsTask = StatisticsService.GetStatisticsAsync();
        var missingImagesTask = StatisticsService.GetMissingImagesAsync();
        var songsAddedTask = StatisticsService.GetSongsAddedPerDayAsync(_rangeStart, _rangeEnd, "UTC");
        var searchesTask = StatisticsService.GetSearchesPerDayAsync(_rangeStart, _rangeEnd, "UTC");
        var nowPlayingTask = NowPlayingRepository.GetNowPlayingAsync();
        var librariesTask = LoadLibrariesAsync();
        var jobsTask = LoadJobsAsync();

        await Task.WhenAll(statsTask, missingImagesTask, songsAddedTask, searchesTask, nowPlayingTask, librariesTask, jobsTask);

        _libraryStats = statsTask.Result.Data ?? [];
        _missingImages = missingImagesTask.Result.Data ?? [];
        _songsAddedPerDay = songsAddedTask.Result.Data ?? [];
        _searchesPerDay = searchesTask.Result.Data ?? [];
        _nowPlayingItems = nowPlayingTask.Result.Data ?? [];
        _nowPlayingCount = _nowPlayingItems.Length;
        _libraries = await librariesTask;
        _jobs = await jobsTask;

        // Extract user count from stats
        var userStat = _libraryStats.FirstOrDefault(s => s.Category == StatisticCategory.CountUsers);
        _userCount = userStat?.DataAsInt ?? 0;
    }

    private async Task<LibraryInfo[]> LoadLibrariesAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        var libraries = await context.Libraries
            .AsNoTracking()
            .OrderBy(l => l.Type)
            .ThenBy(l => l.Name)
            .ToListAsync();

        return libraries.Select(l => new LibraryInfo(
            l.Name,
            l.TypeValue.ToString(),
            l.LastScanAt?.ToDateTimeUtc(),
            l.NeedsScanning()
        )).ToArray();
    }

    private async Task<JobInfo[]> LoadJobsAsync()
    {
        var result = new List<JobInfo>();
        try
        {
            var scheduler = await SchedulerFactory.GetScheduler();
            var jobGroups = await scheduler.GetJobGroupNames();

            foreach (var group in jobGroups)
            {
                var groupMatcher = GroupMatcher<JobKey>.GroupContains(group);
                var jobKeys = await scheduler.GetJobKeys(groupMatcher);
                foreach (var jobKey in jobKeys)
                {
                    var triggers = await scheduler.GetTriggersOfJob(jobKey);
                    foreach (var trigger in triggers)
                    {
                        var nextFireTime = trigger.GetNextFireTimeUtc();
                        var previousFireTime = trigger.GetPreviousFireTimeUtc();
                        result.Add(new JobInfo(
                            jobKey.Name,
                            previousFireTime?.LocalDateTime.ToString("MM/dd HH:mm") ?? "---",
                            nextFireTime?.LocalDateTime.ToString("MM/dd HH:mm") ?? "---"
                        ));
                    }
                }
            }
        }
        catch
        {
            // Jobs may be disabled
        }

        return result.ToArray();
    }

    private static string FormatUptime(TimeSpan uptime)
    {
        if (uptime.TotalDays >= 1)
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        if (uptime.TotalHours >= 1)
            return $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        return $"{uptime.Minutes}m {uptime.Seconds}s";
    }

    private void ClearCacheClicked()
    {
        CacheManager.Clear();
        MelodeeConfigurationFactory.Reset();
        _cacheStatistics = CacheManager.CacheStatistics();
        NotificationService.Notify(NotificationMessageForResult(new OperationResult<bool> { Data = true }, L("Message.ClearedCache"), ToastTime));
    }

    private async Task ClearNowPlayingClicked()
    {
        await NowPlayingRepository.ClearNowPlayingAsync();
        _nowPlayingItems = [];
        _nowPlayingCount = 0;
        NotificationService.Notify(NotificationMessageForResult(new OperationResult<bool> { Data = true }, L("Message.ClearedNowPlaying"), ToastTime));
    }

    private record LibraryInfo(string Name, string TypeLabel, DateTime? LastScanAt, bool NeedsScanning);
    private record JobInfo(string Name, string PreviousFireTime, string NextFireTime);
}
