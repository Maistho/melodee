@page "/admin/dashboard"
@using Melodee.Common.Plugins.Scrobbling
@using Melodee.Common.Services.Caching
@using Melodee.Common.Services
@using Melodee.Common.Enums
@using Melodee.Common.Models
@using Melodee.Common.Models.Scrobbling
@using Melodee.Blazor.ViewModels
@using Melodee.Common.Data
@using Microsoft.EntityFrameworkCore
@inherits MelodeeComponentBase

@inject IMelodeeConfigurationFactory MelodeeConfigurationFactory
@inject ICacheManager CacheManager
@inject INowPlayingRepository NowPlayingInMemoryRepository
@inject NotificationService NotificationService
@inject StatisticsService StatisticsService
@inject IDbContextFactory<MelodeeDbContext> ContextFactory
@inject IServiceProvider ServiceProvider

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>Admin Dashboard</PageTitle>

<div class="dashboard-container">
    <h2 class="rz-typography rz-typography-h4 rz-mb-4">System Dashboard</h2>

    <!-- System Controls -->
    <RadzenCard class="rz-mb-4">
        <div class="rz-p-3">
            <h3 class="rz-typography rz-typography-h6 rz-mb-3">System Controls</h3>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" FlexWrap="FlexWrap.Wrap">
                <RadzenButton
                    Icon="cached"
                    Text="Clear Cache"
                    Click="@ClearCacheClicked"
                    Size="ButtonSize.Medium"
                    ButtonStyle="ButtonStyle.Warning"
                    class="rz-mb-2" />
                <RadzenButton
                    Icon="sweep"
                    Text="Clear Now Playing"
                    Click="@ClearNowPlayingClicked"
                    Size="ButtonSize.Medium"
                    ButtonStyle="ButtonStyle.Warning"
                    class="rz-mb-2" />
                <RadzenButton
                    Icon="refresh"
                    Text="Refresh Data"
                    Click="@RefreshData"
                    Size="ButtonSize.Medium"
                    ButtonStyle="ButtonStyle.Primary"
                    class="rz-mb-2" />
            </RadzenStack>
        </div>
    </RadzenCard>

    <!-- Key Statistics -->
    <RadzenCard class="rz-mb-4">
        <div class="rz-p-3">
            <h3 class="rz-typography rz-typography-h6 rz-mb-3">Library Statistics</h3>
            <RadzenRow class="rz-mb-3">
                @if (LibraryStatistics != null)
                {
                    @foreach (var stat in LibraryStatistics.Take(6))
                    {
                        <RadzenColumn Size="12" SizeMd="4" SizeLg="2">
                            <div class="stat-card rz-p-3 rz-text-center">
                                @if (!string.IsNullOrEmpty(stat.Icon))
                                {
                                    <RadzenIcon Icon="@stat.Icon" class="rz-mb-2 stat-icon" style="font-size: 2rem;" />
                                }
                                <div class="rz-typography rz-typography-body1 rz-text-secondary">@stat.Title</div>
                                <div class="rz-typography rz-typography-h4 rz-font-weight-bold">@stat.Data</div>
                            </div>
                        </RadzenColumn>
                    }
                }
                else
                {
                    <RadzenColumn Size="12">
                        <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                    </RadzenColumn>
                }
            </RadzenRow>
        </div>
    </RadzenCard>

    <!-- Cache and System Info -->
    <RadzenRow class="rz-mb-4">
        <RadzenColumn Size="12" SizeMd="6">
            <RadzenCard>
                <div class="rz-p-3">
                    <h3 class="rz-typography rz-typography-h6 rz-mb-3">Cache Statistics</h3>
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                        @if (CacheStatistics != null)
                        {
                            @foreach (var stat in CacheStatistics)
                            {
                                <div class="cache-stat-item">
                                    <div class="rz-typography rz-typography-body1 rz-text-secondary">@stat.Title</div>
                                    <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@stat.Data</div>
                                </div>
                            }
                        }
                        else
                        {
                            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                        }
                    </RadzenStack>
                </div>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="6">
            <RadzenCard>
                <div class="rz-p-3">
                    <h3 class="rz-typography rz-typography-h6 rz-mb-3">System Information</h3>
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                        <div class="cache-stat-item">
                            <div class="rz-typography rz-typography-body1 rz-text-secondary">Application Version</div>
                            <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@GetAppVersion()</div>
                        </div>
                        <div class="cache-stat-item">
                            <div class="rz-typography rz-typography-body1 rz-text-secondary">Database Provider</div>
                            <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@DatabaseProvider</div>
                        </div>
                        <div class="cache-stat-item">
                            <div class="rz-typography rz-typography-body1 rz-text-secondary">Server Time</div>
                            <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@DateTimeOffset.Now</div>
                        </div>
                        <div class="cache-stat-item">
                            <div class="rz-typography rz-typography-body1 rz-text-secondary">Cache Provider</div>
                            <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@CacheManager.GetType().Name</div>
                        </div>
                    </RadzenStack>
                </div>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Job Status and Now Playing -->
    <RadzenRow class="rz-mb-4">
        <RadzenColumn Size="12" SizeMd="6">
            <RadzenCard>
                <div class="rz-p-3">
                    <h3 class="rz-typography rz-typography-h6 rz-mb-3">Job Status</h3>
                    <RadzenDataGrid Data="@JobStatuses"
                                    TItem="JobStatus"
                                    AllowFiltering="false"
                                    AllowPaging="false"
                                    AllowSorting="false"
                                    class="rz-data-grid-sm">
                        <Columns>
                            <RadzenDataGridColumn TItem="JobStatus" Property="Name" Title="Job" />
                            <RadzenDataGridColumn TItem="JobStatus" Property="TriggerState" Title="Status" />
                            <RadzenDataGridColumn TItem="JobStatus" Property="NextFireTime" Title="Next Run" />
                        </Columns>
                    </RadzenDataGrid>
                </div>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="6">
            <RadzenCard>
                <div class="rz-p-3">
                    <h3 class="rz-typography rz-typography-h6 rz-mb-3">Now Playing</h3>
                    @if (NowPlayingItems != null && NowPlayingItems.Any())
                    {
                        <RadzenDataGrid Data="@NowPlayingItems"
                                        TItem="NowPlayingInfo"
                                        AllowFiltering="false"
                                        AllowPaging="false"
                                        AllowSorting="false"
                                        class="rz-data-grid-sm">
                            <Columns>
                                <RadzenDataGridColumn TItem="NowPlayingInfo" Property="Song.Title" Title="Song" />
                                <RadzenDataGridColumn TItem="NowPlayingInfo" Property="User.UserName" Title="User" />
                                <RadzenDataGridColumn TItem="NowPlayingInfo" Property="StartedPlayingAt" Title="Started" />
                            </Columns>
                        </RadzenDataGrid>
                    }
                    else
                    {
                        <div class="rz-text-center rz-py-4 rz-text-secondary">No one is currently playing music</div>
                    }
                </div>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <!-- Additional Statistics -->
    <RadzenRow class="rz-mb-4">
        <RadzenColumn Size="12" SizeMd="6">
            <RadzenCard>
                <div class="rz-p-3">
                    <h3 class="rz-typography rz-typography-h6 rz-mb-3">User Statistics</h3>
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                        @if (UserStatistics != null)
                        {
                            @foreach (var stat in UserStatistics)
                            {
                                <div class="cache-stat-item">
                                    <div class="rz-typography rz-typography-body1 rz-text-secondary">@stat.Title</div>
                                    <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@stat.Data</div>
                                </div>
                            }
                        }
                        else
                        {
                            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                        }
                    </RadzenStack>
                </div>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMd="6">
            <RadzenCard>
                <div class="rz-p-3">
                    <h3 class="rz-typography rz-typography-h6 rz-mb-3">Media Statistics</h3>
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem">
                        @if (MediaStatistics != null)
                        {
                            @foreach (var stat in MediaStatistics)
                            {
                                <div class="cache-stat-item">
                                    <div class="rz-typography rz-typography-body1 rz-text-secondary">@stat.Title</div>
                                    <div class="rz-typography rz-typography-body1 rz-font-weight-medium">@stat.Data</div>
                                </div>
                            }
                        }
                        else
                        {
                            <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                        }
                    </RadzenStack>
                </div>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</div>

<style>
    .dashboard-container {
        padding: 1rem;
    }

    .stat-card {
        background: var(--rz-card-background);
        border-radius: var(--rz-border-radius);
        border: 1px solid var(--rz-card-border);
        transition: all 0.3s ease;
    }

    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--rz-card-shadow);
    }

    .stat-icon {
        color: var(--rz-primary);
    }

    .cache-stat-item {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--rz-border-color);
    }

    .cache-stat-item:last-child {
        border-bottom: none;
    }

    .rz-data-grid-sm .rz-data-grid-table {
        font-size: 0.875rem;
    }

    .rz-data-grid-sm .rz-data-grid-header {
        background-color: var(--rz-gray-100);
    }

    .rz-data-grid-sm .rz-data-grid-cell {
        padding: 0.5rem 0.75rem;
    }
</style>

@code {
    private IEnumerable<Statistic>? LibraryStatistics;
    private IEnumerable<Statistic>? CacheStatistics;
    private IEnumerable<Statistic>? UserStatistics;
    private IEnumerable<Statistic>? MediaStatistics;
    private List<JobStatus>? JobStatuses;
    private NowPlayingInfo[]? NowPlayingItems;
    private string DatabaseProvider = "Loading...";

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        // Load all statistics in parallel
        var statsTask = StatisticsService.GetStatisticsAsync();
        var cacheStatsTask = Task.Run(() => CacheManager.CacheStatistics());
        var userStatsTask = GetUserStatisticsAsync();
        var mediaStatsTask = GetMediaStatisticsAsync();
        var jobsTask = GetJobStatusesAsync();
        var nowPlayingTask = NowPlayingInMemoryRepository.GetNowPlayingAsync();
        var dbProviderTask = GetDatabaseProviderAsync();

        await Task.WhenAll(statsTask, cacheStatsTask, userStatsTask, mediaStatsTask, jobsTask, nowPlayingTask, dbProviderTask);

        LibraryStatistics = (await statsTask).Data;
        CacheStatistics = await cacheStatsTask;
        UserStatistics = (await userStatsTask).Data;
        MediaStatistics = (await mediaStatsTask).Data;
        JobStatuses = await jobsTask;
        NowPlayingItems = (await nowPlayingTask).Data;
        DatabaseProvider = await dbProviderTask;
    }

    private async Task<OperationResult<Statistic[]>> GetUserStatisticsAsync()
    {
        var stats = new List<Statistic>();

        var usersCount = (await StatisticsService.GetStatisticsAsync()).Data?.FirstOrDefault(s => s.Category == StatisticCategory.CountUsers);
        if (usersCount != null)
        {
            stats.Add(usersCount);
        }

        // Add more user-related stats here
        return new OperationResult<Statistic[]> { Data = stats.ToArray() };
    }

    private async Task<OperationResult<Statistic[]>> GetMediaStatisticsAsync()
    {
        var stats = new List<Statistic>();

        // Get file size and duration from the main statistics
        var allStats = (await StatisticsService.GetStatisticsAsync()).Data;

        var fileSizeStat = allStats?.FirstOrDefault(s => s.Title.Contains("Total: Song Mb"));
        if (fileSizeStat != null)
        {
            stats.Add(fileSizeStat);
        }

        var durationStat = allStats?.FirstOrDefault(s => s.Title.Contains("Total: Song Duration"));
        if (durationStat != null)
        {
            stats.Add(durationStat);
        }

        // Add genres count
        var genresStat = allStats?.FirstOrDefault(s => s.Title.Contains("Genres"));
        if (genresStat != null)
        {
            stats.Add(genresStat);
        }

        return new OperationResult<Statistic[]> { Data = stats.ToArray() };
    }

    private async Task<List<JobStatus>> GetJobStatusesAsync()
    {
        var result = new List<JobStatus>();

        try
        {
            var scheduler = ServiceProvider.GetService<Quartz.IScheduler>();
            if (scheduler != null)
            {
                var jobGroups = await scheduler.GetJobGroupNames();

                foreach (var group in jobGroups)
                {
                    var groupMatcher = Quartz.Impl.Matchers.GroupMatcher<Quartz.JobKey>.GroupEquals(group);
                    var jobKeys = await scheduler.GetJobKeys(groupMatcher);

                    foreach (var jobKey in jobKeys)
                    {
                        var triggers = await scheduler.GetTriggersOfJob(jobKey);

                        foreach (var trigger in triggers)
                        {
                            var triggerState = await scheduler.GetTriggerState(trigger.Key);
                            var nextFireTime = trigger.GetNextFireTimeUtc()?.ToString("yyyy-MM-dd HH:mm:ss") ?? "None";
                            var previousFireTime = trigger.GetPreviousFireTimeUtc()?.ToString("yyyy-MM-dd HH:mm:ss") ?? "None";

                            result.Add(new JobStatus(
                                Group: group,
                                Name: jobKey.Name,
                                TriggerName: trigger.Key.Name,
                                TriggerGroup: trigger.Key.Group,
                                TriggerType: trigger.GetType().Name,
                                TriggerState: triggerState.ToString(),
                                NextFireTime: nextFireTime,
                                PreviousFireTime: previousFireTime
                            ));
                        }
                    }
                }
            }
        }
        catch
        {
            // If we can't get job statuses, return an empty list
        }

        return result;
    }

    private void ClearCacheClicked()
    {
        CacheManager.Clear();
        MelodeeConfigurationFactory.Reset();
        NotificationService.Notify(NotificationMessageForResult(new OperationResult<bool> { Data = true }, "Cleared cache successfully", ToastTime));
        _ = Task.Run(async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadDataAsync();
                StateHasChanged();
            });
        });
    }

    private async Task ClearNowPlayingClicked()
    {
        await NowPlayingInMemoryRepository.ClearNowPlayingAsync();
        NotificationService.Notify(NotificationMessageForResult(new OperationResult<bool> { Data = true }, "Cleared now playing list", ToastTime));
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task RefreshData()
    {
        await LoadDataAsync();
        StateHasChanged();
    }

    private string GetAppVersion()
    {
        return typeof(Program).Assembly.GetName().Version?.ToString() ?? "Unknown";
    }

    private async Task<string> GetDatabaseProviderAsync()
    {
        try
        {
            // Get database provider from the DbContext factory
            using var context = await ContextFactory.CreateDbContextAsync(CancellationToken.None);
            var providerName = context.Database.ProviderName;

            if (!string.IsNullOrEmpty(providerName))
            {
                if (providerName.Contains("Npgsql"))
                    return "PostgreSQL";
                if (providerName.Contains("Sqlite"))
                    return "SQLite";
                if (providerName.Contains("SqlServer"))
                    return "SQL Server";
                if (providerName.Contains("MySql"))
                    return "MySQL";
                return providerName; // return the raw provider name if not recognized
            }

            return "Unknown";
        }
        catch
        {
            return "Unknown";
        }
    }
}
