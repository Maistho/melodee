@inherits MelodeeComponentBase
@using System.Text.Json
@using Melodee.Common.Enums

@inject ChartService ChartService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject IJSRuntime JS
@inject HttpClient HttpClient
@inject ILogger Logger

<RadzenStack Gap="1rem">
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
        <RadzenText TextStyle="TextStyle.Subtitle2">@L("ChartImportDialog.JSONImportSchema")</RadzenText>
        <RadzenText TextStyle="TextStyle.Body2">
            <pre style="font-size: 0.75rem; margin: 0.5rem 0;">
{
  "title": "Best Albums of 2024",      // Required
  "sourceName": "Rolling Stone",       // Optional
  "sourceUrl": "https://...",          // Optional
  "year": 2024,                        // Optional
  "description": "Annual list...",     // Optional
  "tags": ["rock", "2024"],            // Optional
  "imageUrl": "https://...",           // Optional - URL to chart image
  "isVisible": true,                   // Optional (default: false)
  "isGeneratedPlaylistEnabled": true,  // Optional (default: false)
  "items": [                           // Required, at least 1 item
    {
      "rank": 1,                       // Required, unique per chart
      "artistName": "Artist Name",     // Required
      "albumTitle": "Album Title",     // Required
      "releaseYear": 2024              // Optional
    }
  ]
}
            </pre>
        </RadzenText>
    </RadzenAlert>

    <RadzenFormField Text="@L("ChartImportDialog.JSONContent")" Variant="Variant.Outlined" Style="width: 100%;">
        <RadzenTextArea @bind-Value="@_jsonContent" Rows="12" Style="width: 100%; font-family: monospace;" Placeholder="@L("ChartImportDialog.PasteJSON")"/>
    </RadzenFormField>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
        <InputFile OnChange="@OnFileSelected" accept=".json" style="display: none;" id="jsonFileInput"/>
        <RadzenButton Text="@L("ChartImportDialog.UploadFile")" Icon="upload_file" ButtonStyle="ButtonStyle.Secondary" Click="@TriggerFileInput"/>
        <RadzenText TextStyle="TextStyle.Caption" Style="align-self: center;">@_fileName</RadzenText>
    </RadzenStack>

    @if (_validationErrors.Any())
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="false">
            <RadzenText TextStyle="TextStyle.Subtitle2">@L("ChartImportDialog.ValidationErrors")</RadzenText>
            <ul style="margin: 0.5rem 0; padding-left: 1.5rem;">
                @foreach (var error in _validationErrors)
                {
                    <li><RadzenText TextStyle="TextStyle.Body2">@error</RadzenText></li>
                }
            </ul>
        </RadzenAlert>
    }

    @if (_previewChart != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Success" Shade="Shade.Lighter" AllowClose="false">
            <RadzenText TextStyle="TextStyle.Subtitle2">@L("Actions.Preview")</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">
                <strong>@L("Common.Title"):</strong> @_previewChart.Title<br/>
                <strong>@L("TableHeader.Source"):</strong> @(_previewChart.SourceName ?? "N/A")<br/>
                <strong>@L("Common.Year"):</strong> @(_previewChart.Year?.ToString() ?? "N/A")<br/>
                <strong>@L("TableHeader.Items"):</strong> @_previewChart.Items.Count<br/>
                @if (!string.IsNullOrWhiteSpace(_previewChart.ImageUrl))
                {
                    <strong>@L("ChartImportDialog.ImageUrl"):</strong> @_previewChart.ImageUrl<br/>
                }
            </RadzenText>
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="@L("Actions.Cancel")" ButtonStyle="ButtonStyle.Light" Click="@Cancel"/>
        <RadzenButton Text="@L("Actions.Validate")" Icon="check_circle" ButtonStyle="ButtonStyle.Secondary" Click="@ValidateJson" Disabled="@string.IsNullOrWhiteSpace(_jsonContent)"/>
        <RadzenButton Text="@L("Actions.Import")" Icon="download" ButtonStyle="ButtonStyle.Primary" Click="@ImportChart" Disabled="@(_previewChart == null)"/>
    </RadzenStack>
</RadzenStack>

@code {
    string _jsonContent = string.Empty;
    string _fileName = string.Empty;
    List<string> _validationErrors = [];
    ChartImportModel? _previewChart;

    async Task TriggerFileInput()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('jsonFileInput').click()");
    }

    async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            _fileName = file.Name;
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024);
            using var reader = new StreamReader(stream);
            _jsonContent = await reader.ReadToEndAsync();
            _validationErrors.Clear();
            _previewChart = null;
        }
    }

    void ValidateJson()
    {
        _validationErrors.Clear();
        _previewChart = null;

        if (string.IsNullOrWhiteSpace(_jsonContent))
        {
            _validationErrors.Add(L("ChartImportDialog.Error.JsonRequired"));
            return;
        }

        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var model = JsonSerializer.Deserialize<ChartImportModel>(_jsonContent, options);

            if (model == null)
            {
                _validationErrors.Add(L("ChartImportDialog.Error.ParseFailed"));
                return;
            }

            if (string.IsNullOrWhiteSpace(model.Title))
            {
                _validationErrors.Add(L("ChartImportDialog.Error.TitleRequired"));
            }

            if (model.Items == null || model.Items.Count == 0)
            {
                _validationErrors.Add(L("ChartImportDialog.Error.ItemsRequired"));
            }
            else
            {
                var ranks = new HashSet<int>();
                for (var i = 0; i < model.Items.Count; i++)
                {
                    var item = model.Items[i];
                    if (item.Rank <= 0)
                    {
                        _validationErrors.Add(string.Format(L("ChartImportDialog.Error.RankPositive"), i + 1));
                    }
                    else if (!ranks.Add(item.Rank))
                    {
                        _validationErrors.Add(string.Format(L("ChartImportDialog.Error.DuplicateRank"), i + 1, item.Rank));
                    }

                    if (string.IsNullOrWhiteSpace(item.ArtistName))
                    {
                        _validationErrors.Add(string.Format(L("ChartImportDialog.Error.ArtistRequired"), i + 1));
                    }

                    if (string.IsNullOrWhiteSpace(item.AlbumTitle))
                    {
                        _validationErrors.Add(string.Format(L("ChartImportDialog.Error.AlbumRequired"), i + 1));
                    }
                }
            }

            if (!_validationErrors.Any())
            {
                _previewChart = model;
            }
        }
        catch (JsonException ex)
        {
            _validationErrors.Add(string.Format(L("ChartImportDialog.Error.InvalidJson"), ex.Message));
        }
    }

    async Task ImportChart()
    {
        if (_previewChart == null) return;

        try
        {
            var createResult = await ChartService.CreateAsync(
                _previewChart.Title,
                _previewChart.SourceName,
                _previewChart.SourceUrl,
                _previewChart.Year,
                _previewChart.Description,
                _previewChart.Tags?.ToArray());

            if (!createResult.IsSuccess)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = L("ChartImportDialog.ImportFailed"),
                    Detail = createResult.Messages?.FirstOrDefault() ?? L("ChartImportDialog.UnknownError"),
                    Duration = 5000
                });
                return;
            }

            var chartId = createResult.Data!.Id;
            var chartApiKey = createResult.Data!.ApiKey;

            if (_previewChart.IsVisible || _previewChart.IsGeneratedPlaylistEnabled)
            {
                await ChartService.UpdateAsync(chartId, _previewChart.Title, _previewChart.SourceName,
                    _previewChart.SourceUrl, _previewChart.Year, _previewChart.Description,
                    _previewChart.Tags?.ToArray(), _previewChart.IsVisible, _previewChart.IsGeneratedPlaylistEnabled);
            }

            if (!string.IsNullOrWhiteSpace(_previewChart.ImageUrl))
            {
                await DownloadAndSaveImageAsync(chartApiKey, _previewChart.ImageUrl);
            }

            var csvLines = _previewChart.Items
                .OrderBy(i => i.Rank)
                .Select(i => $"{i.Rank},{EscapeCsv(i.ArtistName)},{EscapeCsv(i.AlbumTitle)},{i.ReleaseYear?.ToString() ?? ""}");
            var csv = string.Join("\n", csvLines);

            var parseResult = await ChartService.ParseCsvAsync(csv);
            if (!parseResult.IsSuccess)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = L("ChartImportDialog.ChartCreatedItemsFailed"),
                    Detail = parseResult.Messages?.FirstOrDefault() ?? L("ChartImportDialog.UnknownError"),
                    Duration = 5000
                });
                DialogService.Close(true);
                return;
            }

            var saveResult = await ChartService.SaveItemsAsync(chartId, parseResult.Data!.Items, doAutoLink: false);
            
            if (saveResult.IsSuccess)
            {
                var linkResult = await ChartService.LinkItemsAsync(chartId, overwriteManualLinks: false);
                var linkSummary = linkResult.IsSuccess && linkResult.Data != null 
                    ? string.Format(L("ChartImportDialog.LinkSummary"), linkResult.Data.LinkedCount, linkResult.Data.UnlinkedCount, linkResult.Data.AmbiguousCount)
                    : L("ChartImportDialog.LinkStatusUnavailable");
                
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = L("ChartImportDialog.ChartImported"),
                    Detail = string.Format(L("ChartImportDialog.ChartImportedDetail"), _previewChart.Title, _previewChart.Items.Count, linkSummary),
                    Duration = 8000
                });
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("ChartImportDialog.ImportFailed"),
                Detail = ex.Message,
                Duration = 5000
            });
        }
    }

    static string EscapeCsv(string value)
    {
        if (string.IsNullOrEmpty(value)) return value;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
        {
            return $"\"{value.Replace("\"", "\"\"")}\"";
        }
        return value;
    }

    async Task DownloadAndSaveImageAsync(Guid chartApiKey, string imageUrl)
    {
        try
        {
            Logger.Debug("Downloading chart image from {ImageUrl}", imageUrl);
            
            var response = await HttpClient.GetAsync(imageUrl);
            if (!response.IsSuccessStatusCode)
            {
                Logger.Warning("Failed to download image from {ImageUrl}: {StatusCode}", imageUrl, response.StatusCode);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = L("ChartImportDialog.ImageDownloadFailed"),
                    Detail = string.Format(L("ChartImportDialog.ImageDownloadFailedDetail"), response.StatusCode),
                    Duration = 4000
                });
                return;
            }

            var imageBytes = await response.Content.ReadAsByteArrayAsync();
            
            if (imageBytes.Length == 0)
            {
                Logger.Warning("Downloaded image is empty from {ImageUrl}", imageUrl);
                return;
            }

            Logger.Debug("Downloaded {ByteCount} bytes, uploading to chart {ChartApiKey}", imageBytes.Length, chartApiKey);
            
            var uploadResult = await ChartService.UploadChartImageAsync(chartApiKey, imageBytes);
            
            if (!uploadResult.IsSuccess)
            {
                Logger.Warning("Failed to save chart image: {Message}", uploadResult.Messages?.FirstOrDefault());
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = L("ChartImportDialog.ImageUploadFailed"),
                    Detail = uploadResult.Messages?.FirstOrDefault() ?? L("ChartImportDialog.ImageUploadFailedDetail"),
                    Duration = 4000
                });
            }
            else
            {
                Logger.Information("Successfully saved chart image from {ImageUrl}", imageUrl);
            }
        }
        catch (HttpRequestException ex)
        {
            Logger.Error(ex, "HTTP error downloading image from {ImageUrl}", imageUrl);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Summary = L("ChartImportDialog.ImageDownloadError"),
                Detail = L("ChartImportDialog.ImageDownloadErrorDetail"),
                Duration = 4000
            });
        }
        catch (Exception ex)
        {
            Logger.Error(ex, "Error processing chart image from {ImageUrl}", imageUrl);
        }
    }

    void Cancel()
    {
        DialogService.Close(false);
    }

    sealed class ChartImportModel
    {
        public string Title { get; set; } = string.Empty;
        public string? SourceName { get; set; }
        public string? SourceUrl { get; set; }
        public int? Year { get; set; }
        public string? Description { get; set; }
        public List<string>? Tags { get; set; }
        public string? ImageUrl { get; set; }
        public bool IsVisible { get; set; }
        public bool IsGeneratedPlaylistEnabled { get; set; }
        public List<ChartItemImportModel> Items { get; set; } = [];
    }

    sealed class ChartItemImportModel
    {
        public int Rank { get; set; }
        public string ArtistName { get; set; } = string.Empty;
        public string AlbumTitle { get; set; } = string.Empty;
        public int? ReleaseYear { get; set; }
    }
}
