@page "/charts/{ApiKey:guid}"

@inherits MelodeeComponentBase
@using Melodee.Common.Data.Models
@using Melodee.Common.Data.Models.Extensions
@using Melodee.Common.Enums

@inject MainLayoutProxyService MainLayoutProxyService
@inject ILogger Logger
@inject ChartService ChartService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject IAuthService AuthService
@inject DefaultImages DefaultImages

<PageTitle>@(_chart?.Title ?? L("ChartDetail.PageTitle"))</PageTitle>

<RadzenBreadCrumb Class="rz-pb-5">
    <RadzenBreadCrumbItem Path="/" Text="@L("Nav.Home")"/>
    <RadzenBreadCrumbItem Path="/charts" Icon="format_list_numbered" Text="@L("Nav.Charts")"/>
    <RadzenBreadCrumbItem Text="@(_chart?.Title ?? L("ChartDetail.Loading"))"/>
</RadzenBreadCrumb>

@if (_isLoading)
{
    <RadzenProgressBarCircular
        ProgressBarStyle="ProgressBarStyle.Primary"
        Value="100"
        ShowValue="false"
        Mode="ProgressBarMode.Indeterminate"/>
}
else if (_chart == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
        @L("ChartDetail.ChartNotFound")
    </RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn>
                <RadzenText Text="@_chart.Title" TextStyle="TextStyle.DisplayH5" TagName="TagName.H1" style="margin: 0"/>
                @if (!string.IsNullOrEmpty(_chart.SourceName))
                {
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-text-secondary-color">
                        @L("ChartDetail.Source", _chart.SourceName)
                        @if (!string.IsNullOrEmpty(_chart.SourceUrl))
                        {
                            <RadzenLink Path="@_chart.SourceUrl" Target="_blank" Text="@L("ChartDetail.Link")" class="rz-ml-2"/>
                        }
                    </RadzenText>
                }
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    @if (_unlinkedCount > 0)
                    {
                        <RadzenButton Text="@L("Charts.MissingReport")" Icon="report" ButtonStyle="ButtonStyle.Info" Click="@(() => NavigationManager.NavigateTo($"/charts/missing-report/{ApiKey}"))"/>
                    }
                    @if (AuthService.IsAdmin)
                    {
                        <RadzenButton Text="@L("Actions.Edit")" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@(() => NavigationManager.NavigateTo($"/charts/edit/{ApiKey}"))"/>
                    }
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenCard>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem" AlignItems="AlignItems.Center">
                            <RadzenStack Gap="0.25rem">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-text-secondary-color">@L("ChartDetail.TotalAlbums")</RadzenText>
                                <RadzenText TextStyle="TextStyle.H4" style="margin: 0">@_chartItems.Count</RadzenText>
                            </RadzenStack>

                            <RadzenStack Gap="0.25rem">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-text-secondary-color">@L("Status.Linked")</RadzenText>
                                <RadzenText TextStyle="TextStyle.H4" style="margin: 0">@_linkedCount</RadzenText>
                            </RadzenStack>

                            <RadzenStack Gap="0.25rem">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-text-secondary-color">@L("ChartDetail.Completion")</RadzenText>
                                <RadzenText TextStyle="TextStyle.H4" style="margin: 0">@_completionPercentage%</RadzenText>
                            </RadzenStack>
                        </RadzenStack>

                        <RadzenStack Gap="0.5rem" Style="min-width: 300px;">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenText TextStyle="TextStyle.Body2">
                                    @if (_isCompleted)
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("Status.Completed")" class="rz-mr-2"/>
                                        <span>@L("ChartDetail.AllAlbumsAvailable")</span>
                                    }
                                    else
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@L("ChartDetail.InProgress")" class="rz-mr-2"/>
                                        <span>@L("ChartDetail.AlbumsNotFound", _unlinkedCount)</span>
                                    }
                                </RadzenText>
                            </RadzenStack>
                            <RadzenProgressBar Value="@_completionPercentage" Max="100" ShowValue="false" ProgressBarStyle="@(_isCompleted ? ProgressBarStyle.Success : ProgressBarStyle.Info)"/>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12" SizeMD="3">
              <RadzenCard>
                @if (_isLoading)
                {
                  <RadzenImage
                    Path=@(DefaultImages.ChartImageBase64)
                    Style="margin:auto;display: block;width: 300px;height: 300px;"
                    AlternateText="@_chart.Title"/>
                }
                else if (_hasImage)
                {
                  <RadzenImage
                    Path=@($"/images/{_chart.ToApiKey()}/{ ImageSize.Small}")
                    Style="margin:auto;display: block;width: 300px;height: 300px;"
                    AlternateText="@_chart.Title"/>
                }
                else
                {
                  <RadzenImage
                    Path=@(DefaultImages.ChartImageBase64)
                    Style="margin:auto;display: block;width: 300px;height: 300px;"
                    AlternateText="@_chart.Title"/>
                }
                <RadzenStack class="rz-mt-4" Gap="0.5rem">
                  <RadzenRow>
                    <RadzenColumn Size="6">
                      <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">@L("Label.Year")</RadzenText>
                      <RadzenText TextStyle="TextStyle.Body1">@(_chart.Year?.ToString() ?? "—")</RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                      <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">@L("ChartDetail.Items")</RadzenText>
                      <RadzenText TextStyle="TextStyle.Body1">@_chart.Items.Count</RadzenText>
                    </RadzenColumn>
                  </RadzenRow>
                  <RadzenRow>
                    <RadzenColumn Size="6">
                      <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">@L("Label.Status")</RadzenText>
                      @if (_chart.IsVisible)
                      {
                        <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("Status.Visible")"/>
                      }
                      else
                      {
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@L("Status.Hidden")"/>
                      }
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                      <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">@L("ChartDetail.Playlist")</RadzenText>
                      @if (_chart.IsGeneratedPlaylistEnabled)
                      {
                        <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@L("Status.Enabled")"/>
                      }
                      else
                      {
                        <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@L("Status.Disabled")"/>
                      }
                    </RadzenColumn>
                  </RadzenRow>
                  @if (!string.IsNullOrWhiteSpace(_chart.Tags))
                  {
                    <RadzenRow>
                      <RadzenColumn Size="12">
                        <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">@L("Label.Tags")</RadzenText>
                        <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="0.25rem">
                          @foreach (var tag in _chart.Tags.Split('|', StringSplitOptions.RemoveEmptyEntries))
                          {
                            <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@tag"/>
                          }
                        </RadzenStack>
                      </RadzenColumn>
                    </RadzenRow>
                  }
                </RadzenStack>
              </RadzenCard>

                @if (!string.IsNullOrWhiteSpace(_chart.Description))
                {
                    <RadzenCard class="rz-mt-4">
                        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">@L("Label.Description")</RadzenText>
                        <Markdown Content="@_chart.Description"/>
                    </RadzenCard>
                }
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="9">
                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-4">
                        <RadzenIcon Icon="list" class="rz-mr-1"/> @L("ChartDetail.ChartItems", _chart.Items.Count)
                    </RadzenText>

                    <RadzenDataGrid Data="@_chartItems" TItem="ChartItem" AllowPaging="true" PageSize="25" Density="Density.Compact" AllowSorting="true">
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.Rank)" Title="@L("TableHeader.Hash")" Width="60px"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.ArtistName)" Title="@L("TableHeader.Artist")" Width="200px"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.AlbumTitle)" Title="@L("TableHeader.Album")" Width="250px"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.ReleaseYear)" Title="@L("TableHeader.Year")" Width="80px" Sortable="true"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.LinkStatusValue)" Title="@L("TableHeader.Status")" Width="100px" Sortable="true">
                                <Template Context="item">
                                    @switch (item.LinkStatusValue)
                                    {
                                        case ChartItemLinkStatus.Linked:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("Status.Linked")"/>
                                            break;
                                        case ChartItemLinkStatus.Ambiguous:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@L("Status.Ambiguous")"/>
                                            break;
                                        case ChartItemLinkStatus.Ignored:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@L("Status.Ignored")"/>
                                            break;
                                        default:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="@L("Status.Unlinked")"/>
                                            break;
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Title="@L("TableHeader.LinkedAlbum")" Width="200px">
                                <Template Context="item">
                                    @if (item.LinkedAlbum != null)
                                    {
                                        <RadzenLink Path="@($"/data/album/{item.LinkedAlbum.ApiKey}")" Text="@($"{item.LinkedArtist?.Name} - {item.LinkedAlbum.Name}")"/>
                                    }
                                    else
                                    {
                                        <RadzenText class="rz-text-secondary-color">—</RadzenText>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenStack>
}

@code {
  [Parameter] public Guid ApiKey { get; set; }

    Chart? _chart;
    List<ChartItem> _chartItems = [];
    bool _isLoading = true;
    bool _hasImage;
    string _imageVersion = DateTime.UtcNow.Ticks.ToString();

    int _linkedCount;
    int _unlinkedCount;
    int _completionPercentage;
    bool _isCompleted;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadChartAsync();
    }

    async Task LoadChartAsync()
    {
        _isLoading = true;
        MainLayoutProxyService.ToggleSpinnerVisible();
        try
        {
            var result = await ChartService.GetByApiKeyAsync(ApiKey);
            if (result.IsSuccess && result.Data != null)
            {
                _chart = result.Data;
                _chartItems = _chart.Items.OrderBy(i => i.Rank).ToList();

                var imageResult = await ChartService.GetChartImageBytesAndEtagAsync(_chart.ApiKey, null);
                _hasImage = imageResult.Bytes != null && imageResult.Bytes.Length > 0;

                CalculateStatistics();
            }
        }
        catch (Exception e)
        {
            Logger.Error(e, "Loading Chart [{ChartId}]", ApiKey);
        }
        finally
        {
            MainLayoutProxyService.ToggleSpinnerVisible();
            _isLoading = false;
        }
    }

    void CalculateStatistics()
    {
        if (_chartItems.Count == 0)
        {
            _linkedCount = 0;
            _unlinkedCount = 0;
            _completionPercentage = 0;
            _isCompleted = false;
            return;
        }

        _linkedCount = _chartItems.Count(i => i.LinkStatusValue == ChartItemLinkStatus.Linked);
        _unlinkedCount = _chartItems.Count - _linkedCount;
        _completionPercentage = (int)Math.Round((_linkedCount / (double)_chartItems.Count) * 100);
        _isCompleted = _linkedCount == _chartItems.Count;
    }
}
