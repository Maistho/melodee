@page "/charts/{ChartId:int}"

@inherits MelodeeComponentBase
@using Melodee.Common.Data.Models
@using Melodee.Common.Data.Models.Extensions
@using Melodee.Common.Enums

@inject MainLayoutProxyService MainLayoutProxyService
@inject ILogger Logger
@inject ChartService ChartService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject IAuthService AuthService

<PageTitle>@(_chart?.Title ?? "Chart Details")</PageTitle>

<RadzenBreadCrumb Class="rz-pb-5">
    <RadzenBreadCrumbItem Path="/" Text="Home"/>
    <RadzenBreadCrumbItem Path="/charts" Icon="format_list_numbered" Text="Charts"/>
    <RadzenBreadCrumbItem Text="@(_chart?.Title ?? "Loading...")"/>
</RadzenBreadCrumb>

@if (_isLoading)
{
    <RadzenProgressBarCircular
        ProgressBarStyle="ProgressBarStyle.Primary"
        Value="100"
        ShowValue="false"
        Mode="ProgressBarMode.Indeterminate"/>
}
else if (_chart == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
        Chart not found.
    </RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn>
                <RadzenText Text="@_chart.Title" TextStyle="TextStyle.DisplayH5" TagName="TagName.H1" style="margin: 0"/>
                @if (!string.IsNullOrEmpty(_chart.SourceName))
                {
                    <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-text-secondary-color">
                        Source: @_chart.SourceName
                        @if (!string.IsNullOrEmpty(_chart.SourceUrl))
                        {
                            <RadzenLink Path="@_chart.SourceUrl" Target="_blank" Text="(link)" class="rz-ml-2"/>
                        }
                    </RadzenText>
                }
            </RadzenColumn>
            <RadzenColumn>
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton Text="Back to List" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@(() => NavigationManager.NavigateTo("/charts"))"/>
                    @if (AuthService.IsAdmin)
                    {
                        <RadzenButton Text="Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@(() => NavigationManager.NavigateTo($"/charts/edit/{ChartId}"))"/>
                    }
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow>
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenCard>
                    @if (_hasImage)
                    {
                        <RadzenImage Path="@($"/api/v1/charts/{_chart.ApiKey}/image?v={_imageVersion}")" 
                                     Style="width: 100%; height: auto; border-radius: 8px;" 
                                     AlternateText="@_chart.Title"/>
                    }
                    else
                    {
                        <div style="width: 100%; aspect-ratio: 1; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; display: flex; align-items: center; justify-content: center;">
                            <RadzenIcon Icon="format_list_numbered" Style="font-size: 64px; color: white;"/>
                        </div>
                    }
                    
                    <RadzenStack class="rz-mt-4" Gap="0.5rem">
                        <RadzenRow>
                            <RadzenColumn Size="6">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">Year</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body1">@(_chart.Year?.ToString() ?? "—")</RadzenText>
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">Items</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body1">@_chart.Items.Count</RadzenText>
                            </RadzenColumn>
                        </RadzenRow>
                        <RadzenRow>
                            <RadzenColumn Size="6">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">Status</RadzenText>
                                @if (_chart.IsVisible)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Visible"/>
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Hidden"/>
                                }
                            </RadzenColumn>
                            <RadzenColumn Size="6">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">Playlist</RadzenText>
                                @if (_chart.IsGeneratedPlaylistEnabled)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="Enabled"/>
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Disabled"/>
                                }
                            </RadzenColumn>
                        </RadzenRow>
                        @if (!string.IsNullOrWhiteSpace(_chart.Tags))
                        {
                            <RadzenRow>
                                <RadzenColumn Size="12">
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-text-secondary-color">Tags</RadzenText>
                                    <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="0.25rem">
                                        @foreach (var tag in _chart.Tags.Split('|', StringSplitOptions.RemoveEmptyEntries))
                                        {
                                            <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@tag"/>
                                        }
                                    </RadzenStack>
                                </RadzenColumn>
                            </RadzenRow>
                        }
                    </RadzenStack>
                </RadzenCard>

                @if (!string.IsNullOrWhiteSpace(_chart.Description))
                {
                    <RadzenCard class="rz-mt-4">
                        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">Description</RadzenText>
                        <Markdown Content="@_chart.Description"/>
                    </RadzenCard>
                }
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="8">
                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-4">
                        <RadzenIcon Icon="list" class="rz-mr-1"/> Chart Items (@_chart.Items.Count)
                    </RadzenText>

                    <RadzenDataGrid Data="@_chartItems" TItem="ChartItem" AllowPaging="true" PageSize="25" Density="Density.Compact" AllowSorting="true">
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.Rank)" Title="#" Width="60px"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.ArtistName)" Title="Artist" Width="200px"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.AlbumTitle)" Title="Album" Width="250px"/>
                            <RadzenDataGridColumn Property="@nameof(ChartItem.ReleaseYear)" Title="Year" Width="80px"/>
                            <RadzenDataGridColumn Title="Status" Width="100px">
                                <Template Context="item">
                                    @switch (item.LinkStatusValue)
                                    {
                                        case ChartItemLinkStatus.Linked:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="Linked"/>
                                            break;
                                        case ChartItemLinkStatus.Ambiguous:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Ambiguous"/>
                                            break;
                                        case ChartItemLinkStatus.Ignored:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="Ignored"/>
                                            break;
                                        default:
                                            <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="Unlinked"/>
                                            break;
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Title="Linked Album" Width="200px">
                                <Template Context="item">
                                    @if (item.LinkedAlbum != null)
                                    {
                                        <RadzenLink Path="@($"/data/album/{item.LinkedAlbum.ApiKey}")" Text="@($"{item.LinkedArtist?.Name} - {item.LinkedAlbum.Name}")"/>
                                    }
                                    else
                                    {
                                        <RadzenText class="rz-text-secondary-color">—</RadzenText>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>
    </RadzenStack>
}

@code {
    [Parameter] public int ChartId { get; set; }

    Chart? _chart;
    List<ChartItem> _chartItems = [];
    bool _isLoading = true;
    bool _hasImage;
    string _imageVersion = DateTime.UtcNow.Ticks.ToString();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadChartAsync();
    }

    async Task LoadChartAsync()
    {
        _isLoading = true;
        MainLayoutProxyService.ToggleSpinnerVisible();
        try
        {
            var result = await ChartService.GetByIdAsync(ChartId);
            if (result.IsSuccess && result.Data != null)
            {
                _chart = result.Data;
                _chartItems = _chart.Items.OrderBy(i => i.Rank).ToList();
                
                var imageResult = await ChartService.GetChartImageBytesAndEtagAsync(_chart.ApiKey, null);
                _hasImage = imageResult.Bytes != null && imageResult.Bytes.Length > 0;
            }
        }
        catch (Exception e)
        {
            Logger.Error(e, "Loading Chart [{ChartId}]", ChartId);
        }
        finally
        {
            MainLayoutProxyService.ToggleSpinnerVisible();
            _isLoading = false;
        }
    }
}
