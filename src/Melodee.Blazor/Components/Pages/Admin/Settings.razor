@page "/admin/settings"
@inherits MelodeeComponentBase
@using Melodee.Blazor.Components.Dialogs
@using Melodee.Common.Constants
@using Melodee.Common.Data.Models
@using Melodee.Common.Extensions
@using Melodee.Common.Filtering
@using FilterOperator = Melodee.Common.Filtering.FilterOperator

@inject DialogService DialogService
@inject MainLayoutProxyService MainLayoutProxyService
@inject ILogger Logger
@inject SettingService SettingService
@inject NotificationService NotificationService

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>@L("AdminSettings.PageTitle")</PageTitle>

<RadzenStack Style="height: 100%">
    <RadzenBreadCrumb Class="rz-pb-5">
        <RadzenBreadCrumbItem Path="/" Text="@L("Navigation.Dashboard")"/>
        <RadzenBreadCrumbItem Icon="settings" Text="@L("AdminSettings.PageTitle")"/>
    </RadzenBreadCrumb>
    
    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
        <DebounceInput class="rz-textbox"
                       style="flex: 1"
                       autocomplete="off"
                       @bind-Value="@_debounceInputValue"
                       @bind-Value:event="OnInput"
                       DebounceTime="800"
                       MinLength="3"
                       OnValueChanged="@DoSearchAsync"
                       ForceNotifyByEnter="true"
                       ForceNotifyOnBlur="true"/>
        <RadzenButton 
            Text="@L("AdminSettings.AddNew")"
            Icon="add"
            ButtonStyle="ButtonStyle.Primary"
            Click="@OpenAddSettingDialog"/>
    </RadzenStack>

    <RadzenDataGrid
        @ref="_grid"
        Style="flex: 1; overflow: hidden;"
        IsLoading="@_isLoading"
        Count="@_count"
        Data="@_settings"
        LoadData="@LoadData"
        AllowSorting="true"
        AllowFiltering="true"
        AllowPaging="true"
        Page="OnPage"
        PageSize="@DefaultPageSize"
        PagerHorizontalAlign="HorizontalAlign.Center"
        ShowPagingSummary="true"
        PageSizeOptions="@PageSizeOptions"
        PagingSummaryFormat="@ViewConstants.PagingSummaryFormat"
        ColumnWidth="200px"
        TItem="Setting"
        EditMode="@DataGridEditMode.Single"
        RowUpdate="@OnUpdateRow">
        <Columns>
            <RadzenDataGridColumn Property="@nameof(Setting.Key)" Title="@L("AdminSettings.Key")" Width="150px"/>
            <RadzenDataGridColumn Property="@nameof(Setting.Value)" Title="@L("AdminSettings.Value")" Width="250px">
                <EditTemplate Context="setting">
                    <RadzenTextBox @bind-Value="setting.Value" Style="width:250px; display: block" Name="Value"
                                   aria-label="@L("AdminSettings.EditValue")"/>
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn Property="@nameof(Setting.Comment)" Title="@L("AdminSettings.Comment")" Width="400px"/>
            <RadzenDataGridColumn
                Context="setting"
                Filterable="false"
                Sortable="false"
                TextAlign="TextAlign.Right"
                Frozen="true"
                Width="75px"
                FrozenPosition="FrozenColumnPosition.Right">
                <Template Context="setting">
                    <RadzenButton
                        Icon="edit"
                        ButtonStyle="ButtonStyle.Light"
                        Variant="Variant.Flat"
                        Size="ButtonSize.Medium"
                        Click="@(_ => EditRow(setting))"
                        Disabled="@(MelodeeConfigurationFactory.IsSetViaEnvironmentVariable(setting.Key))"
                        @onclick:stopPropagation="true">
                    </RadzenButton>
                </Template>
                <EditTemplate Context="setting">
                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                  Size="ButtonSize.Medium" Click="@(_ => SaveRow(setting))" aria-label="@L("Actions.Save")">
                    </RadzenButton>
                    <RadzenButton
                        Icon="close"
                        ButtonStyle="ButtonStyle.Light"
                        Variant="Variant.Flat"
                        Size="ButtonSize.Medium"
                        class="rz-my-1 rz-ms-1"
                        Click="@(_ => CancelEdit(setting))"
                        aria-label="@L("Actions.Cancel")">
                    </RadzenButton>
                </EditTemplate>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    RadzenDataGrid<Setting> _grid = null!;
    int _count;
    IEnumerable<Setting> _settings = null!;
    bool _isLoading;
    int _currentPage = 1;
    IMelodeeConfiguration _configuration = new MelodeeConfiguration([]);

    string _debounceInputValue = "";

    private async Task OpenAddSettingDialog()
    {
        // Get all setting keys from SettingRegistry
        var allSettingKeys = typeof(SettingRegistry).GetAllPublicConstantValues<string>().OrderBy(x => x).ToList();
        
        // Get existing setting keys
        var existingKeys = await SettingService.GetAllKeysAsync();
        
        // Filter out keys that already have records
        var availableKeys = allSettingKeys.Where(k => !existingKeys.Contains(k, StringComparer.OrdinalIgnoreCase)).ToList();
        
        if (!availableKeys.Any())
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Warning,
                Duration = ToastTime,
                SummaryContent = _ => @<RadzenText TextStyle="TextStyle.H6">@L("AdminSettings.NoAvailableKeys")</RadzenText>,
                DetailContent = ns => @<RadzenStack>
                    <RadzenText TextStyle="TextStyle.Body2">@L("AdminSettings.AllKeysExist")</RadzenText>
                    <RadzenButton Text="@L("Actions.Close")" Click="@(_ => ns.Messages.Clear())"/>
                </RadzenStack>
            });
            return;
        }
        
        var result = await DialogService.OpenAsync<AddSettingDialog>(
            L("AdminSettings.AddNewSetting"),
            new Dictionary<string, object>
            {
                { "AvailableKeys", availableKeys }
            },
            new DialogOptions
            {
                Width = "600px",
                Resizable = true,
                Draggable = true
            });
        
        if (result is Setting newSetting)
        {
            var addResult = await SettingService.AddAsync(newSetting);
            if (addResult.IsSuccess && addResult.Data != null)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Duration = ToastTime,
                    SummaryContent = _ => @<RadzenText TextStyle="TextStyle.H6">@L("AdminSettings.SuccessfullyAdded")</RadzenText>,
                    DetailContent = ns => @<RadzenButton Text="@L("Actions.Close")" Click="@(_ => ns.Messages.Clear())"/>
                });
                
                // Reload data
                await LoadData(new LoadDataArgs { Sorts = [], Filters = [] });
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Duration = ToastTime * 3,
                    SummaryContent = _ => @<RadzenText TextStyle="TextStyle.H6">@L("AdminSettings.FailedToAdd")</RadzenText>,
                    DetailContent = ns => @<RadzenStack>
                        <RadzenText TextStyle="TextStyle.Body2">@string.Join(", ", addResult.Messages ?? [])</RadzenText>
                        <RadzenButton Text="@L("Actions.Close")" Click="@(_ => ns.Messages.Clear())"/>
                    </RadzenStack>
                });
            }
        }
    }

    async Task EditRow(Setting setting)
    {
        if (!_grid.IsValid) return;
        await _grid.EditRow(setting);
    }

    private async Task DoSearchAsync(string s)
    {
        await LoadData(new LoadDataArgs { Sorts = [], Filters = [] });
    }

    async Task OnUpdateRow(Setting setting)
    {
        var result = await SettingService.UpdateAsync(setting).ConfigureAwait(false);
        if (result.IsSuccess)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Duration = ToastTime,
                SummaryContent = _ => @<RadzenText TextStyle="TextStyle.H6">@L("AdminSettings.SuccessfullyUpdated")</RadzenText>,
                DetailContent = ns => @<RadzenButton Text="@L("Data.OK")" Click="@(_ => ns.Messages.Clear())"/>
            });
        }
    }

    async Task SaveRow(Setting setting)
    {
        await _grid.UpdateRow(setting);
    }

    void CancelEdit(Setting setting)
    {
        _grid.CancelEditRow(setting);
    }

    void OnPage(PagerEventArgs args)
    {
        _currentPage = args.PageIndex + 1;
    }

    async Task LoadData(LoadDataArgs args)
    {
        _isLoading = true;
        MainLayoutProxyService.ToggleSpinnerVisible();
        try
        {
            Dictionary<string, string>? sorting = null;
            if (args.Sorts.Any())
            {
                sorting = args.Sorts.ToDictionary(x => x.Property, x => x.SortOrder == SortOrder.Ascending ? PagedRequest.OrderAscDirection : PagedRequest.OrderDescDirection);
            }

            FilterOperatorInfo[]? filters = null;
            if (_debounceInputValue.Nullify() != null)
            {
                filters =
                [
                    new FilterOperatorInfo(nameof(Setting.Key), FilterOperator.Contains, _debounceInputValue),
                    new FilterOperatorInfo(nameof(Setting.Comment), FilterOperator.Contains, _debounceInputValue, FilterOperatorInfo.OrJoinOperator),
                    new FilterOperatorInfo(nameof(Setting.Value), FilterOperator.Contains, _debounceInputValue, FilterOperatorInfo.OrJoinOperator)
                ];
            }
            else if (args.Filters.Any())
            {
                filters = args.Filters.Select(x => new FilterOperatorInfo(x.Property,
                        SafeParser.ToEnum<FilterOperator>(x.FilterOperator.ToDictionary()),
                        x.FilterValue))
                    .ToArray();
            }

            var result = await SettingService.ListAsync(new PagedRequest
            {
                FilterBy = filters,
                Page = _currentPage,
                PageSize = SafeParser.ToNumber<short>(args.Top),
                OrderBy = sorting
            });
            _settings = result.Data;
            _count = SafeParser.ToNumber<int>(result.TotalCount);
        }
        catch (Exception e)
        {
            Logger.Error(e, "Loading Settings");
        }
        finally
        {
            MainLayoutProxyService.ToggleSpinnerVisible();
        }

        _isLoading = false;
    }

}


