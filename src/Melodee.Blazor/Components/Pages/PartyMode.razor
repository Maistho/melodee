@page "/party"
@using Melodee.Blazor.Services
@using Melodee.Common.Constants
@inherits MelodeeComponentBase

@inject PartyModeService PartyModeService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject ILogger<PartyMode> Logger

<PageTitle>@L("PartyMode.Title")</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H4">@L("PartyMode.Title")</RadzenText>

    @if (_isLoading)
    {
        <RadzenProgressBarCircular ShowValue="true" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large"/>
    }
    else if (!_partyModeEnabled)
    {
        <RadzenCard>
            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem" Style="padding: 2rem;">
                <RadzenIcon Icon="celebration" Style="font-size: 4rem; color: var(--rz-text-disabled-color);"/>
                <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-text-disabled-color);">@L("PartyMode.NotEnabled")</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-disabled-color);">@L("PartyMode.NotEnabledHint")</RadzenText>
            </RadzenStack>
        </RadzenCard>
    }
    else
    {
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenCard>
                    <RadzenStack Gap="1rem">
                        <RadzenText TextStyle="TextStyle.H6">@L("PartyMode.CreateSession")</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">@L("PartyMode.CreateSessionDescription")</RadzenText>
                        
                        <RadzenTextBox @bind-Value="_newSessionName" 
                                       Placeholder="@L("PartyMode.SessionNamePlaceholder")" 
                                       Style="width: 100%;" />
                        
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenCheckBox @bind-Value="_requireJoinCode" />
                            <RadzenLabel Text="@L("PartyMode.RequireJoinCode")" />
                        </RadzenStack>
                        
                        @if (_requireJoinCode)
                        {
                            <RadzenTextBox @bind-Value="_joinCode" 
                                           Placeholder="@L("PartyMode.JoinCodePlaceholder")" 
                                           Style="width: 100%;" />
                        }
                        
                        <RadzenButton Text="@L("PartyMode.CreateButton")" 
                                      Icon="add" 
                                      ButtonStyle="ButtonStyle.Primary" 
                                      Click="CreateSessionAsync"
                                      Disabled="@(string.IsNullOrWhiteSpace(_newSessionName) || _isCreating)" />
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
            
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenCard>
                    <RadzenStack Gap="1rem">
                        <RadzenText TextStyle="TextStyle.H6">@L("PartyMode.JoinSession")</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body2">@L("PartyMode.JoinSessionDescription")</RadzenText>
                        
                        <RadzenTextBox @bind-Value="_joinSessionCode" 
                                       Placeholder="@L("PartyMode.EnterSessionCode")" 
                                       Style="width: 100%;" />
                        
                        <RadzenButton Text="@L("PartyMode.JoinButton")" 
                                      Icon="login" 
                                      ButtonStyle="ButtonStyle.Secondary" 
                                      Click="JoinByCodeAsync"
                                      Disabled="@(string.IsNullOrWhiteSpace(_joinSessionCode) || _isJoining)" />
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        </RadzenRow>

        @if (_mySessions.Any())
        {
            <RadzenCard class="rz-mt-4">
                <RadzenStack Gap="1rem">
                    <RadzenText TextStyle="TextStyle.H6">@L("PartyMode.MySessions")</RadzenText>
                    
                    <RadzenDataGrid Data="@_mySessions" TItem="PartySessionDto" AllowSorting="false">
                        <Columns>
                            <RadzenDataGridColumn Title="@L("PartyMode.SessionName")" Width="200px">
                                <Template Context="session">
                                    <RadzenLink Path="@($"/party/{session.ApiKey}")" Text="@session.Name" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(PartySessionDto.Status)" Title="@L("PartyMode.Status")" Width="100px">
                                <Template Context="session">
                                    <RadzenBadge BadgeStyle="@(session.Status == "Active" ? BadgeStyle.Success : BadgeStyle.Light)" 
                                                 Text="@session.Status" IsPill="true" />
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Title="@L("PartyMode.Actions")" Width="120px">
                                <Template Context="session">
                                    <RadzenButton Icon="play_arrow" 
                                                  ButtonStyle="ButtonStyle.Light" 
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => NavigateToSession(session.ApiKey))"
                                                  title="@L("PartyMode.OpenSession")" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenStack>
            </RadzenCard>
        }

        @if (_activeSessions.Any())
        {
            <RadzenCard class="rz-mt-4">
                <RadzenStack Gap="1rem">
                    <RadzenText TextStyle="TextStyle.H6">@L("PartyMode.ActiveSessions")</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@L("PartyMode.ActiveSessionsDescription")</RadzenText>
                    
                    <RadzenDataGrid Data="@_activeSessions" TItem="PartySessionDto" AllowSorting="false">
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(PartySessionDto.Name)" Title="@L("PartyMode.SessionName")" Width="200px" />
                            <RadzenDataGridColumn Title="@L("PartyMode.Actions")" Width="120px">
                                <Template Context="session">
                                    <RadzenButton Text="@L("PartyMode.JoinButton")" 
                                                  Icon="login" 
                                                  ButtonStyle="ButtonStyle.Primary" 
                                                  Size="ButtonSize.Small"
                                                  Click="@(() => JoinSessionAsync(session.ApiKey))" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenStack>
            </RadzenCard>
        }
    }
</RadzenStack>

@code {
    private bool _isLoading = true;
    private bool _partyModeEnabled;
    private bool _isCreating;
    private bool _isJoining;
    
    private string _newSessionName = string.Empty;
    private bool _requireJoinCode;
    private string _joinCode = string.Empty;
    private string _joinSessionCode = string.Empty;
    
    private List<PartySessionDto> _mySessions = [];
    private List<PartySessionDto> _activeSessions = [];

    protected override async Task OnInitializedAsync()
    {
        Logger.LogDebug("[PartyMode] OnInitializedAsync starting");
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            Logger.LogDebug("[PartyMode] LoadDataAsync starting");
            
            var configuration = await ConfigurationFactory.GetConfigurationAsync();
            _partyModeEnabled = configuration.GetValue<bool>(SettingRegistry.PartyModeEnabled);
            
            Logger.LogDebug("[PartyMode] PartyModeEnabled={PartyModeEnabled}", _partyModeEnabled);
            
            if (_partyModeEnabled)
            {
                Logger.LogDebug("[PartyMode] Loading sessions...");
                var mySessionsTask = PartyModeService.GetMySessionsAsync();
                var activeSessionsTask = PartyModeService.GetActiveSessionsAsync();
                
                await Task.WhenAll(mySessionsTask, activeSessionsTask);
                
                _mySessions = (mySessionsTask.Result ?? []).ToList();
                _activeSessions = (activeSessionsTask.Result ?? [])
                    .Where(s => !_mySessions.Any(m => m.ApiKey == s.ApiKey))
                    .ToList();
                
                Logger.LogDebug("[PartyMode] Loaded {MySessionCount} user sessions, {ActiveSessionCount} active public sessions", 
                    _mySessions.Count, _activeSessions.Count);
            }
            else
            {
                Logger.LogDebug("[PartyMode] Party Mode is disabled, skipping session load");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[PartyMode] Error loading party mode data");
            NotificationService.Notify(NotificationSeverity.Error, L("Common.Error"), L("PartyMode.LoadError"));
        }
        finally
        {
            _isLoading = false;
            Logger.LogDebug("[PartyMode] LoadDataAsync completed, IsLoading={IsLoading}", _isLoading);
        }
    }

    private async Task CreateSessionAsync()
    {
        if (string.IsNullOrWhiteSpace(_newSessionName))
        {
            Logger.LogDebug("[PartyMode] CreateSessionAsync: Empty session name, aborting");
            return;
        }
        
        try
        {
            _isCreating = true;
            Logger.LogDebug("[PartyMode] Creating session: Name={SessionName}, RequireJoinCode={RequireJoinCode}", 
                _newSessionName, _requireJoinCode);
            
            var result = await PartyModeService.CreateSessionAsync(
                _newSessionName, 
                _requireJoinCode ? _joinCode : null);
            
            if (result?.IsSuccess == true && result.Data != null)
            {
                Logger.LogInformation("[PartyMode] Session created successfully: ApiKey={SessionApiKey}", result.Data.ApiKey);
                NotificationService.Notify(NotificationSeverity.Success, L("Common.Success"), L("PartyMode.SessionCreated"));
                NavigationManager.NavigateTo($"/party/{result.Data.ApiKey}");
            }
            else
            {
                Logger.LogWarning("[PartyMode] Session creation failed: {Messages}", 
                    result?.Messages != null ? string.Join(", ", result.Messages) : "No details");
                NotificationService.Notify(NotificationSeverity.Error, L("Common.Error"), L("PartyMode.CreateFailed"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[PartyMode] Exception creating party session");
            NotificationService.Notify(NotificationSeverity.Error, L("Common.Error"), L("PartyMode.CreateFailed"));
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task JoinByCodeAsync()
    {
        if (string.IsNullOrWhiteSpace(_joinSessionCode))
        {
            Logger.LogDebug("[PartyMode] JoinByCodeAsync: Empty session code, aborting");
            return;
        }
        
        Logger.LogDebug("[PartyMode] Attempting to join session by code: {JoinCode}", _joinSessionCode);
        
        if (!Guid.TryParse(_joinSessionCode, out var sessionApiKey))
        {
            Logger.LogWarning("[PartyMode] Invalid session code format: {JoinCode}", _joinSessionCode);
            NotificationService.Notify(NotificationSeverity.Warning, L("Common.Warning"), L("PartyMode.InvalidSessionCode"));
            return;
        }
        
        await JoinSessionAsync(sessionApiKey);
    }

    private async Task JoinSessionAsync(Guid sessionApiKey)
    {
        try
        {
            _isJoining = true;
            Logger.LogDebug("[PartyMode] Joining session: ApiKey={SessionApiKey}", sessionApiKey);
            
            var result = await PartyModeService.JoinSessionAsync(sessionApiKey);
            
            if (result?.IsSuccess == true)
            {
                Logger.LogInformation("[PartyMode] Successfully joined session: ApiKey={SessionApiKey}", sessionApiKey);
                NavigationManager.NavigateTo($"/party/{sessionApiKey}");
            }
            else
            {
                Logger.LogWarning("[PartyMode] Failed to join session: ApiKey={SessionApiKey}, Messages={Messages}", 
                    sessionApiKey, result?.Messages != null ? string.Join(", ", result.Messages) : "No details");
                NotificationService.Notify(NotificationSeverity.Error, L("Common.Error"), L("PartyMode.JoinFailed"));
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[PartyMode] Exception joining party session: ApiKey={SessionApiKey}", sessionApiKey);
            NotificationService.Notify(NotificationSeverity.Error, L("Common.Error"), L("PartyMode.JoinFailed"));
        }
        finally
        {
            _isJoining = false;
        }
    }

    private void NavigateToSession(Guid sessionApiKey)
    {
        Logger.LogDebug("[PartyMode] Navigating to session: ApiKey={SessionApiKey}", sessionApiKey);
        NavigationManager.NavigateTo($"/party/{sessionApiKey}");
    }
}
