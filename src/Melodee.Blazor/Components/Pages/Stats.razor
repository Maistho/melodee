@page "/stats"
@using Melodee.Common.Models
@using Melodee.Common.Models.Collection
@using Melodee.Blazor.Constants
@using Melodee.Common.Enums
@using NodaTime
@inherits MelodeeComponentBase

@inject StatisticsService StatisticsService
@inject NavigationManager NavigationManager

<PageTitle>@L("Stats.PageTitle")</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H4">@L("Stats.Statistics")</RadzenText>

    <RadzenRow>
        @foreach (var kpi in _userKpis)
        {
            <RadzenColumn Size="12" SizeMD="3" SizeLG="2">
                <RadzenCard>
                    <RadzenStack Gap="0.25rem">
                        <RadzenText TextStyle="TextStyle.Overline">@LocalizeStatisticTitle(kpi.Title)</RadzenText>
                        <RadzenText TextStyle="TextStyle.H5">@kpi.Data</RadzenText>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        }
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.H6" Text="@L("Stats.Summary")"/>
            <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap" Gap="8px" class="rz-p-2">
                @foreach (var statistic in _statistics)
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Info" Shade="Shade.Dark" Style="min-width: 200px;">
                        <RadzenIcon Icon="@statistic.Icon"/>
                        <div style="width:120px;display:inline-block;text-transform:none;text-align:left;">
                            @LocalizeStatisticTitle(statistic.Title)
                        </div>
                        <div style="width:100px;display:inline-block;text-align:right;" title="@statistic.Message">
                            @if (statistic.Type == StatisticType.Count)
                            {
                                @($"{((int)statistic.Data).ToStringPadLeft(ViewConstants.StatisticNumberPadLength)}")
                            }
                            else
                            {
                                @statistic.Data
                            }
                        </div>
                    </RadzenBadge>
                }
            </RadzenStack>
        </RadzenStack>
    </RadzenCard>

    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">@L("Stats.YourPlaysPerDayLast30d")</RadzenText>
                <RadzenChart Style="height:320px;">
                    <RadzenLineSeries Data="@_playsPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value" Title="@L("Stats.PlaysChartTitle")">
                        <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                            <RadzenAxisTitle Text="@L("Stats.DateAxisTitle")"/>
                        </RadzenCategoryAxis>
                        <RadzenValueAxis>
                            <RadzenAxisTitle Text="@L("Stats.PlaysChartTitle")"/>
                        </RadzenValueAxis>
                    </RadzenLineSeries>
                </RadzenChart>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">@L("Stats.SongsAddedPerDayLast30d")</RadzenText>
                <RadzenChart Style="height:320px;">
                    <RadzenLineSeries Data="@_songsAddedPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value" Title="@L("Stats.AddedChartTitle")">
                        <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                            <RadzenAxisTitle Text="@L("Stats.DateAxisTitle")"/>
                        </RadzenCategoryAxis>
                        <RadzenValueAxis>
                            <RadzenAxisTitle Text="@L("Stats.SongsAxisTitle")"/>
                        </RadzenValueAxis>
                    </RadzenLineSeries>
                </RadzenChart>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.H6" Text="@L("Stats.TopPlayedSongsYou")"/>
            <RadzenDataGrid TItem="TopItemStat" 
                            Data="@_topSongs" 
                            AllowPaging="false" 
                            AllowSorting="false" 
                            AllowFiltering="false" 
                            Density="Density.Compact"
                            RowClick="@OnTopSongRowClick">
                <Columns>
                    <RadzenDataGridColumn TItem="TopItemStat" Property="Label" Title="@L("Stats.SongColumnTitle")">
                        <Template Context="song">
                            <span style="cursor: pointer;">@song.Label</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="TopItemStat" Property="Value" Title="@L("Stats.PlaysColumnTitle")"/>
                </Columns>
            </RadzenDataGrid>
        </RadzenStack>
    </RadzenCard>

    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">@L("Stats.ReleasesByYear")</RadzenText>
                <RadzenChart Style="height:320px;">
                    <RadzenPieSeries Data="@_albumsByYear" CategoryProperty="Label" ValueProperty="Value" />
                </RadzenChart>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">@L("Stats.ReleasesByGenre")</RadzenText>
                <RadzenChart Style="height:320px;">
                    <RadzenPieSeries Data="@_albumsByGenre" CategoryProperty="Label" ValueProperty="Value" />
                </RadzenChart>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">@L("Stats.TopArtistsByAlbumCount")</RadzenText>
                <RadzenChart Style="height:320px;">
                    <RadzenColumnSeries Data="@_topArtistsByAlbumCount" CategoryProperty="Label" ValueProperty="Value" />
                    <RadzenCategoryAxis>
                        <RadzenAxisTitle Text="@L("Common.Artist")"/>
                    </RadzenCategoryAxis>
                    <RadzenValueAxis>
                        <RadzenAxisTitle Text="@L("Stats.CountColumnTitle")"/>
                    </RadzenValueAxis>
                </RadzenChart>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenText TextStyle="TextStyle.H6">@L("Stats.TopArtistsByPlays")</RadzenText>
                <RadzenChart Style="height:320px;">
                    <RadzenColumnSeries Data="@_topArtistsByPlays" CategoryProperty="Label" ValueProperty="Value" />
                    <RadzenCategoryAxis>
                        <RadzenAxisTitle Text="@L("Common.Artist")"/>
                    </RadzenCategoryAxis>
                    <RadzenValueAxis>
                        <RadzenAxisTitle Text="@L("Stats.PlaysColumnTitle")"/>
                    </RadzenValueAxis>
                </RadzenChart>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    @if (CurrentUser?.IsEditor() == true || CurrentUser?.IsAdmin() == true)
    {
        <RadzenCard>
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.H6" Text="@L("Stats.EditorMissingImages")"/>
                <RadzenDataGrid TItem="Statistic" Data="@_missingImages" AllowPaging="false" AllowSorting="false" Density="Density.Compact">
                    <Columns>
                        <RadzenDataGridColumn TItem="Statistic" Property="Title" Title="@L("Stats.ItemColumnTitle")"/>
                        <RadzenDataGridColumn TItem="Statistic" Property="Data" Title="@L("Stats.CountColumnTitle")"/>
                    </Columns>
                </RadzenDataGrid>
            </RadzenStack>
        </RadzenCard>
    }

    @if (CurrentUser?.IsAdmin() == true)
    {
        <RadzenCard>
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.H6" Text="@L("Stats.AdminActivity")"/>
                <RadzenRow>
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenText TextStyle="TextStyle.Subtitle1">@L("Stats.SearchesPerDay")</RadzenText>
                        <RadzenChart Style="height:240px;">
                            <RadzenLineSeries Data="@_searchesPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value">
                                <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                                    <RadzenAxisTitle Text=""/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis>
                                    <RadzenAxisTitle Text=""/>
                                </RadzenValueAxis>
                            </RadzenLineSeries>
                        </RadzenChart>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenText TextStyle="TextStyle.Subtitle1">@L("Stats.ShareViewsPerDay")</RadzenText>
                        <RadzenChart Style="height:240px;">
                            <RadzenLineSeries Data="@_shareViewsPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value">
                                <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                                    <RadzenAxisTitle Text=""/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis>
                                    <RadzenAxisTitle Text=""/>
                                </RadzenValueAxis>
                            </RadzenLineSeries>
                        </RadzenChart>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenText TextStyle="TextStyle.Subtitle1">@L("Stats.LibraryScansPerDay")</RadzenText>
                        <RadzenChart Style="height:240px;">
                            <RadzenLineSeries Data="@_libraryScansPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value">
                                <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
                                    <RadzenAxisTitle Text=""/>
                                </RadzenCategoryAxis>
                                <RadzenValueAxis>
                                    <RadzenAxisTitle Text=""/>
                                </RadzenValueAxis>
                            </RadzenLineSeries>
                        </RadzenChart>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenStack>
        </RadzenCard>
    }
</RadzenStack>

@code {
    Statistic[] _statistics = [];
    Statistic[] _userKpis = [];
    TimeSeriesPoint[] _playsPerDay = [];
    TimeSeriesPoint[] _songsAddedPerDay = [];
    TopItemStat[] _topSongs = [];
    TimeSeriesPoint[] _searchesPerDay = [];
    TimeSeriesPoint[] _shareViewsPerDay = [];
    TimeSeriesPoint[] _libraryScansPerDay = [];
    Statistic[] _missingImages = [];
    TopItemStat[] _albumsByYear = [];
    TopItemStat[] _albumsByGenre = [];
    TopItemStat[] _topArtistsByAlbumCount = [];
    TopItemStat[] _topArtistsByPlays = [];

    private LocalDate _rangeStart;
    private LocalDate _rangeEnd;
    private string _timeZoneId = "UTC";

    void OnTopSongRowClick(DataGridRowMouseEventArgs<TopItemStat> args)
    {
        if (!string.IsNullOrWhiteSpace(args.Data.Extra) && Guid.TryParse(args.Data.Extra, out var albumApiKey))
        {
            NavigationManager.NavigateTo($"/data/album/{albumApiKey}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _timeZoneId = CurrentUser?.TimeZoneId() ?? "UTC";
        var zone = DateTimeZoneProviders.Tzdb.GetZoneOrNull(_timeZoneId) ?? DateTimeZone.Utc;
        var today = SystemClock.Instance.GetCurrentInstant().InZone(zone).Date;
        _rangeEnd = today;
        _rangeStart = today.PlusDays(-29);

        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        var userApiKey = CurrentUser?.ToApiGuid() ?? Guid.Empty;

        var kpiTask = StatisticsService.GetUserKpisAsync(userApiKey, _rangeStart, _rangeEnd, _timeZoneId);
        var summaryTask = StatisticsService.GetStatisticsAsync();
        var playsTask = StatisticsService.GetUserSongPlaysPerDayAsync(userApiKey, _rangeStart, _rangeEnd, _timeZoneId);
        var addedTask = StatisticsService.GetSongsAddedPerDayAsync(_rangeStart, _rangeEnd, _timeZoneId);
        var topSongsTask = StatisticsService.GetUserTopPlayedSongsAsync(userApiKey, _rangeStart, _rangeEnd, _timeZoneId, 10);
        var albumsByYearTask = StatisticsService.GetAlbumsByYearAsync();
        var albumsByGenreTask = StatisticsService.GetAlbumsByGenreAsync();
        var topArtistsByAlbumCountTask = StatisticsService.GetTopArtistsByAlbumCountAsync(10);
        var topArtistsByPlaysTask = StatisticsService.GetTopArtistsByPlaysAsync(10);
        Task<OperationResult<Statistic[]>>? missingImagesTask = null;
        Task<OperationResult<TimeSeriesPoint[]>>? searchesTask = null;
        Task<OperationResult<TimeSeriesPoint[]>>? sharesTask = null;
        Task<OperationResult<TimeSeriesPoint[]>>? scansTask = null;

        if (CurrentUser?.IsEditor() == true || CurrentUser?.IsAdmin() == true)
        {
            missingImagesTask = StatisticsService.GetMissingImagesAsync();
        }
        if (CurrentUser?.IsAdmin() == true)
        {
            searchesTask = StatisticsService.GetSearchesPerDayAsync(_rangeStart, _rangeEnd, _timeZoneId);
            sharesTask = StatisticsService.GetShareViewsPerDayAsync(_rangeStart, _rangeEnd, _timeZoneId);
            scansTask = StatisticsService.GetLibraryScansPerDayAsync(_rangeStart, _rangeEnd, _timeZoneId);
        }

        await Task.WhenAll(new Task[]
        {
            kpiTask, summaryTask, playsTask, addedTask, topSongsTask,
            albumsByYearTask, albumsByGenreTask, topArtistsByAlbumCountTask, topArtistsByPlaysTask,
            missingImagesTask ?? Task.CompletedTask,
            searchesTask ?? Task.CompletedTask,
            sharesTask ?? Task.CompletedTask,
            scansTask ?? Task.CompletedTask
        });

        _userKpis = kpiTask.Result.Data ?? [];
        _statistics = summaryTask.Result.Data ?? [];
        _playsPerDay = playsTask.Result.Data ?? [];
        _songsAddedPerDay = addedTask.Result.Data ?? [];
        _topSongs = topSongsTask.Result.Data ?? [];
        _albumsByYear = albumsByYearTask.Result.Data ?? [];
        _albumsByGenre = albumsByGenreTask.Result.Data ?? [];
        _topArtistsByAlbumCount = topArtistsByAlbumCountTask.Result.Data ?? [];
        _topArtistsByPlays = topArtistsByPlaysTask.Result.Data ?? [];
        _missingImages = missingImagesTask?.Result.Data ?? [];
        _searchesPerDay = searchesTask?.Result.Data ?? [];
        _shareViewsPerDay = sharesTask?.Result.Data ?? [];
        _libraryScansPerDay = scansTask?.Result.Data ?? [];
    }
}
