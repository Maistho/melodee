@page "/data/album/{ApiKey:guid}/{FromUrl?}"
@inherits MelodeeComponentBase
@using Melodee.Blazor.ViewModels
@using Melodee.Common.Data.Models
@using Melodee.Common.Data.Models.Extensions
@using Melodee.Common.Enums
@using Melodee.Common.Models.Extensions
@using NodaTime
@using Album = Melodee.Common.Data.Models.Album
@using Artist = Melodee.Common.Data.Models.Artist
@using Song = Melodee.Common.Data.Models.Song
@using Melodee.Common.Services.Jukebox

@inject MainLayoutProxyService MainLayoutProxyService
@inject ISubsonicJukeboxService SubsonicJukeboxService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject AlbumService AlbumService
@inject UserService UserService
@inject SettingService SettingService
@inject LibraryService LibraryService
@inject ChartService ChartService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject DefaultImages DefaultImages
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JsRuntime
@inject ILogger Logger

<PageTitle>@_album.Name</PageTitle>

<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center" Class="rz-pb-5">
        <RadzenColumn Size="7" SizeMD="9">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                @if (FromUrl != null)
                {
                    <RadzenButton
                        Icon="arrow_back"
                        ButtonStyle="ButtonStyle.Info"
                        Text="@L("Nav.Back")"
                        title="@L("Nav.GoBack")"
                        Size="ButtonSize.Small"
                        Click="@(() => NavigationManager.NavigateTo(FromUrl, true))"/>
                }
                <RadzenBreadCrumb class="hide-below-480">
                    <RadzenBreadCrumbItem Path="/" Text="@L("Navigation.Dashboard")"/>
                    <RadzenBreadCrumbItem Path="@($"/data/artist/{_album.Artist.ApiKey}")" Text="@_album.Artist.Name"/>
                    <RadzenBreadCrumbItem Path="@($"/data/albums?filterToArtistApiKey={_album.Artist.ApiKey}")"
                                          Text="@L("Navigation.Albums")"/>
                    <RadzenBreadCrumbItem Icon="album" Text="@_album.Name"/>
                </RadzenBreadCrumb>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="5" SizeMD="3">
            <RadzenStack
                Orientation="Orientation.Horizontal"
                AlignItems="AlignItems.Center"
                JustifyContent="JustifyContent.End"
                Gap="0.5rem">
                <RadzenIcon Icon="@(_isPinned ? "keep" : "keep_off")" class="filled-icon"
                            IconColor="@(_isPinned ? "#99CCFF" : "#C9C9C7")"
                            @onclick="@TogglePinned" Style="cursor:pointer;"/>
                <RadzenIcon
                    Icon="play_arrow"
                    class="filled-icon"
                    IconColor="@Colors.Info"
                    title="@L("Actions.Play")"
                    @onclick="@(PlayAlbum)"
                    Style="cursor:pointer;font-size:14px;"/>
                <RadzenRating Value="@_userAlbum.Rating" Change="@UserRatingChange"/>
                <RadzenIcon Icon="thumb_down" class="filled-icon"
                            IconColor="@(_userAlbum.IsHated ? "#A2A415" : "#C9C9C7")"
                            @onclick="@IsHatedClicked" Style="cursor:pointer;"/>
                <RadzenIcon Icon="favorite" class="filled-icon"
                            IconColor="@(_userAlbum.IsStarred ? "#FA0202" : "#C9C9C7")"
                            @onclick="@IsStarredClicked" Style="cursor:pointer;"/>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@if (_alertMessages.Any())
{
    foreach (var alert in _alertMessages)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Icon="warning" Size="AlertSize.Small" AllowClose="false"
                     Text="@alert"/>
    }
}

<RadzenStack>
    <RadzenMenu>
        <RadzenMenuItem Text="@L("Actions.Delete")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_album.IsLocked"
                        Click="DeleteButtonClick" title="@L("AlbumDetail.DeleteAlbum")"
                        IconColor="@Colors.Danger" Icon="delete"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("Actions.Edit")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_album.IsLocked"
                        Click="EditButtonClick" title="@L("AlbumDetail.EditAlbum")" Icon="edit"></RadzenMenuItem>
        @if (_album.IsLocked)
        {
            <RadzenMenuItem Text="@L("Actions.Unlock")" Visible="CurrentUser?.IsEditor() ?? false" Click="UnlockButtonClick"
                            title="@L("AlbumDetail.UnlockAlbum")" IconColor="@Colors.Warning"
                            Icon="lock_open"></RadzenMenuItem>
        }
        else
        {
            <RadzenMenuItem Text="@L("Actions.Lock")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_album.IsLocked"
                            Click="LockButtonClick" title="@L("AlbumDetail.LockAlbum")"
                            IconColor="@Colors.Warning" Icon="lock"></RadzenMenuItem>
        }
        <RadzenMenuItem Text="@L("Actions.Rescan")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_album.IsLocked"
                        Click="RescanButtonClick" title="@L("AlbumDetail.RescanAlbum")"
                        Icon="refresh"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("AlbumDetail.SetCoverImage")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_album.IsLocked"
                        Click="SetCoverImageButtonClick" title="@L("AlbumDetail.SetAlbumCoverImage")"
                        Icon="image"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("Actions.WebSearch")" Icon="public">
            <RadzenMenuItem Text="@L("Label.Album")" Click="@(() => DoWebSearch(1))"></RadzenMenuItem>
            <RadzenMenuItem Text="@L("AlbumDetail.AlbumPlusYear")" Click="@(() => DoWebSearch(2))"></RadzenMenuItem>
            <RadzenMenuItem Text="@L("AlbumDetail.AlbumPlusArtist")" Click="@(() => DoWebSearch(3))"></RadzenMenuItem>
            <RadzenMenuItem Text="@L("AlbumDetail.AlbumPlusYearPlusArtist")" Click="@(() => DoWebSearch(4))"></RadzenMenuItem>
        </RadzenMenuItem>
    </RadzenMenu>
    <RadzenText Text="@($"[{_album.ReleaseDate.Year}] {_album.Name}")" TextStyle="TextStyle.DisplayH6"
                TagName="TagName.H1" style="margin: 0"/>
</RadzenStack>
<RadzenStack class="rz-mt-3">
    <RadzenRow>
        <RadzenColumn Size="4" SizeMD="2">
            <RadzenStack>
                <RadzenCard class="hide-below-480">
                    <RadzenTree Change="@OnShowItemChange">
                        <RadzenTreeItem Text="@L("Nav.Overview")" Selected="true">
                            <Template>
                                <RadzenIcon Icon="overview"/>
                                @context.Text
                            </Template>
                        </RadzenTreeItem>
                        <RadzenTreeItem Text="@L("Navigation.Charts")">
                            <Template>
                                <RadzenIcon Icon="format_list_numbered"/>
                                @($"{context.Text} ({_albumCharts.Count})")
                            </Template>
                        </RadzenTreeItem>
                        <RadzenTreeItem Text="@L("Nav.Files")">
                            <Template>
                                <RadzenIcon Icon="folder_data"/>
                                @($"{context.Text} ({_albumDirectoryFileCount})")
                            </Template>
                        </RadzenTreeItem>
                        <RadzenTreeItem Text="@L("Nav.Images")">
                            <Template>
                                <RadzenIcon Icon="image"/>
                                @($"{context.Text} ({_albumImageFiles?.Length ?? 0})")
                            </Template>
                        </RadzenTreeItem>
                    </RadzenTree>
                </RadzenCard>
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="info" class="rz-me-1"/>
                            @L("Label.Details")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack
                            Orientation="Orientation.Vertical"
                            JustifyContent="JustifyContent.Left"
                            class="rz-pt-1"
                            Gap="5px">
                            <CondensedStatistic Label="@L("Label.Status")" StatisticStyle="@AlbumStatusStyle"
                                                Statistic="@_album.AlbumStatusValue.ToString()"/>
                            @if (CurrentUser?.IsAdmin() ?? false)
                            {
                                <CondensedStatistic Label="@L("Label.Directory")" Statistic="@_album.Directory"/>
                            }
                            <CondensedStatistic Label="@L("Label.AlbumType")" Statistic="@_album.AlbumTypeValue.ToString()"/>
                            <CondensedStatistic Label="@L("Label.Genres")" Statistic="@_album.Genres?.ToCsv()"/>
                            @foreach (var albumContributor in _album.Contributors.Where(x => x.ContributorTypeValue.RestrictToOnePerAlbum()).OrderBy(x => x.ContributorTypeValue.ToString()))
                            {
                                <CondensedStatistic Label="@albumContributor.ContributorTypeValue.ToString()"
                                                    Statistic="@albumContributor.ContributorName"/>
                            }
                            @if (_album.AlternateNames.Nullify() != null)
                            {
                                <CondensedStatistic Label="@L("Label.AlternateNames")" Statistic="@_album.AlternateNames"/>
                            }
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
                <RadzenPanel Visible="@(_album.DoShowExternalLinks())">
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="link" class="rz-me-1"/>
                            @L("Label.ExternalLinks")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack
                            Orientation="Orientation.Vertical"
                            JustifyContent="JustifyContent.Left"
                            class="rz-pt-1"
                            Gap="5px">
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.Amg"
                                            Id="@_album.AmgId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.Deezer"
                                            Id="@_album.DeezerId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.Discogs"
                                            Id="@_album.DiscogsId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.ITunes"
                                            Id="@_album.ItunesId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.LastFm"
                                            Id="@_album.LastFmId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.MusicBrainz"
                                            Id="@_album.MusicBrainzId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.Spotify"
                                            Id="@_album.SpotifyId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Album"
                                            ThirdPartyIdType="ThirdPartyIdType.WikiData"
                                            Id="@_album.WikiDataId"/>
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="monitoring" class="rz-me-1"/>
                            @L("Label.Statistics")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack
                            Orientation="Orientation.Vertical"
                            JustifyContent="JustifyContent.Left"
                            class="rz-pt-1"
                            Gap="5px">
                            <CondensedStatistic Label="@L("Label.Duration")"
                                                Statistic="@(CurrentUser!.FormatDuration(_album.Duration.ToDuration()))"/>
                            <CondensedStatistic Label="@L("Label.Rating")" Rating="@(_album.CalculatedRating)"/>
                            <CondensedStatistic Label="@L("Label.SongCount")" Statistic="@(_album.SongCount.ToStringPadLeft(4))"/>
                            <CondensedStatistic Label="@L("Label.PlayedTotal")"
                                                Statistic="@(_album.PlayedCount.ToStringPadLeft(6))"/>
                            <CondensedStatistic Label="@L("Label.LastPlayed")"
                                                Statistic="@(CurrentUser?.FormatInstant(_album.LastPlayedAt))"/>
                            <CondensedStatistic Label="@L("Label.Created")"
                                                Statistic="@(CurrentUser?.FormatInstant(_album.CreatedAt))"/>
                            <CondensedStatistic Label="@L("Label.LastUpdated")"
                                                Statistic="@(CurrentUser?.FormatInstant(_album.LastUpdatedAt))"/>
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="8" SizeMD="10">
            @if (_showItem == ShowItem.Overview)
            {
                <RadzenRow class="rz-pb-3">
                    <RadzenColumn Size="12" SizeMD="6" SizeXL="8">
                        <RadzenPanel>
                            <HeaderTemplate>
                                <RadzenText TextStyle="TextStyle.H6"
                                            class="rz-display-flex rz-align-items-center rz-m-0">
                                    <RadzenIcon Icon="music_note" class="rz-me-1"/>
                                    @L("Navigation.Songs")
                                </RadzenText>
                            </HeaderTemplate>
                            <ChildContent>
                                <table class="rz-mt-1 hovertable">
                                    <thead>
                                    <tr>
                                        <th scope="col">@L("TableHeader.Hash")</th>
                                        <th scope="col" style="width:90%;">@L("TableHeader.Title")</th>
                                        <th scope="col">@L("Label.Duration")</th>
                                        <th scope="col" style="min-width:140px;">@L("TableHeader.Actions")</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var song in _album.Songs.OrderBy(x => x.SortOrder))
                                    {
                                        <tr class="highlight-on-hover">
                                            <td>@($"{song.SongNumber.ToStringPadLeft(3)}")</td>
                                            <td>@song.Title</td>
                                            <td>@CurrentUser!.FormatDuration(song.Duration.ToDuration())</td>
                                            <th scope="row" style="padding-top:2px;">
                                                <RadzenIcon
                                                    Icon="play_arrow"
                                                    class="filled-icon"
                                                    IconColor="@Colors.Info"
                                                    title="@L("AlbumDetail.PlaySong")"
                                                    @onclick="@(() => PlaySong(song))"
                                                    Style="cursor:pointer;font-size:14px;"/>
                                                @if (_jukeboxEnabled && CurrentUser?.IsAdmin() == true)
                                                {
                                                    <RadzenIcon
                                                        Icon="queue_music"
                                                        class="filled-icon"
                                                        IconColor="@Colors.Info"
                                                        title="@L("AlbumDetail.AddToJukebox")"
                                                        @onclick="@(() => AddSongToJukeboxAsync(song))"
                                                        Style="cursor:pointer;font-size:14px;"/>
                                                }
                                                <RadzenIcon
                                                    Icon="thumb_down"
                                                    class="filled-icon"
                                                    IconColor="@(IsSongHated(song) ? "#A2A415" : "#C9C9C7")"
                                                    title="@L("AlbumDetail.IHateThis")"
                                                    @onclick="@(() => IsSongHatedClicked(song))"
                                                    Style="cursor:pointer;font-size:14px;"/>
                                                <RadzenIcon
                                                    Icon="favorite"
                                                    class="filled-icon"
                                                    IconColor="@(IsSongStarred(song) ? "#FA0202" : "#C9C9C7")"
                                                    title="@L("AlbumDetail.ILikeThis")"
                                                    @onclick="@(() => IsSongStarredClicked(song))"
                                                    Style="cursor:pointer;font-size:14px;"/>
                                                <RadzenRating Style="font-size:14px;"
                                                              Value="@(_userSongs.FirstOrDefault(x => x.SongId == song.Id)?.Rating ?? 0)"
                                                              Change="@(args => UserSongRatingChange(song, args))"/>
                                            </th>
                                        </tr>
                                        @foreach (var songContributor in song.Contributors.GroupBy(x => x.ContributorTypeValue).OrderBy(x => x.Key))
                                        {
                                            <tr class="song-contributor-row">
                                                <td></td>
                                                <td>
                                                    <RadzenText style="color: var(--rz-text-color)"
                                                                TextStyle="TextStyle.Overline">@songContributor.Key.ToString()</RadzenText>
                                                    :
                                                    <RadzenText style="color: var(--rz-text-secondary-color)"
                                                                TextStyle="TextStyle.Subtitle2">@songContributor.Select(x => x.ContributorName).ToCsv(", ")</RadzenText>
                                                </td>
                                                <td></td>
                                                <td></td>
                                            </tr>
                                        }
                                    }
                                    </tbody>
                                </table>
                            </ChildContent>
                        </RadzenPanel>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6" SizeXL="4">
                        <ArtistDataInfoCardComponent
                            Style="width: 450px;margin-bottom: 10px;"
                            Artist="@_album.Artist.ToArtistDataInfo()"/>
                        @if (_isLoading)
                        {
                            <RadzenImage
                                Path=@(DefaultImages.AlbumCoverBase64)
                                Style="margin:auto;display: block;max-width: 600px;max-height: 600px;width: auto;height: auto;object-fit: contain;"
                                AlternateText="@_album.Name"/>
                        }
                        else if (_albumsImagesInByteBase64.Length < 2)
                        {
                            <RadzenImage
                                Path=@($"/images/{_album.ToApiKey()}/{ImageSize.Medium}{(_showItem == ShowItem.Images ? $"?v={_imageCacheBuster}" : "")}")
                                Style="margin:auto;display: block;max-width: 450px;max-height: 450px;width: auto;height: auto;object-fit: contain;"
                                AlternateText="@_album.Name"/>
                        }
                        else if (_albumsImagesInByteBase64.Length > 1)
                        {
                            <RadzenCarousel
                                Auto="false"
                                Style="height: 450px; width: 450px;"
                                class="rz-mx-auto"
                                ButtonStyle="ButtonStyle.Base"
                                ButtonSize="ButtonSize.Small"
                                ButtonVariant="Variant.Text">
                                <Items>
                                    @foreach (var image in _albumsImagesInByteBase64)
                                    {
                                        <RadzenCarouselItem>
                                            <RadzenImage Path="@image" Style="width: 100%;height: 100%;object-fit: contain;"/>
                                        </RadzenCarouselItem>
                                    }
                                </Items>
                            </RadzenCarousel>
                        }
                        <Markdown Content="@(_album.Description)"/>
                    </RadzenColumn>
                </RadzenRow>
            }
            else if (_showItem == ShowItem.Charts)
            {
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="format_list_numbered" class="rz-me-1"/>
                            @L("AlbumDetail.ChartsFeaturing")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        @if (_albumCharts.Count == 0)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter">
                                @L("AlbumDetail.NotFeaturedOnCharts")
                            </RadzenAlert>
                        }
                        else
                        {
                            <RadzenDataGrid TItem="AlbumChartInfo"
                                            Data="@_albumCharts"
                                            AllowPaging="false"
                                            AllowSorting="true"
                                            Density="Density.Compact">
                                <Columns>
                                    <RadzenDataGridColumn Property="@nameof(AlbumChartInfo.Rank)" Title="@L("TableHeader.Rank")" Width="100px" Sortable="true">
                                        <Template Context="item">
                                            <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@($"#{item.Rank}")" />
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn Property="@nameof(AlbumChartInfo.ChartTitle)" Title="@L("Label.Chart")" Width="300px" Sortable="true">
                                        <Template Context="item">
                                            <RadzenLink Path="@($"/charts/{item.ChartApiKey}")" Text="@item.ChartTitle"/>
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn Property="@nameof(AlbumChartInfo.SourceName)" Title="@L("Label.Source")" Width="200px" Sortable="true">
                                        <Template Context="item">
                                            @(item.SourceName ?? "—")
                                        </Template>
                                    </RadzenDataGridColumn>

                                    <RadzenDataGridColumn Property="@nameof(AlbumChartInfo.Year)" Title="@L("Label.Year")" Width="100px" Sortable="true">
                                        <Template Context="item">
                                            @(item.Year?.ToString() ?? "—")
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </RadzenDataGrid>
                        }
                    </ChildContent>
                </RadzenPanel>
            }
            else if (_showItem == ShowItem.Files)
            {
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="folder_data" class="rz-me-1"/>
                            @L("Nav.Files")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                            <InputFile multiple OnChange="@OnAlbumFilesUpload" />
                            <RadzenButton Icon="checklist" Size="ButtonSize.Small" Text="@L("Actions.SelectAll")" Click="@SelectAllFiles"/>
                            <RadzenButton Icon="check_box_outline_blank" Size="ButtonSize.Small" Text="@L("Actions.SelectNone")" Click="@SelectNoneFiles"/>
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Text="@L("Actions.DeleteSelected")"
                                          Disabled="@(!_selectedAlbumFilePaths.Any())"
                                          Visible="CurrentUser?.IsEditor() ?? false"
                                          Click="@DeleteSelectedAlbumFilesButtonClick" />
                        </RadzenStack>
                        <RadzenDataList Data="@_albumFileList" TItem="AlbumFileListItem" class="rz-mt-3">
                            <Template Context="item">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenCheckBox TValue="bool" Value="@_selectedAlbumFilePaths.Contains(item.File.FullName)"
                                                    Change="@(args => ToggleAlbumFileSelected(item.File.FullName, args))"/>
                                    <RadzenText Text="@item.File.Name"/>
                                    <RadzenText Text=@($"{item.File.Length/1024} KB") style="color:var(--rz-text-secondary-color)"/>
                                </RadzenStack>
                            </Template>
                        </RadzenDataList>
                    </ChildContent>
                </RadzenPanel>
            }
            else if (_showItem == ShowItem.Images)
            {
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="image" class="rz-me-1"/>
                            @L("Nav.Images")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                            <RadzenSwitch @bind-Value="@_replaceAllAlbumImages" Name="ReplaceAllAlbum"/>
                            <RadzenLabel Text="@L("ArtistDetail.ReplaceAllImages")" Component="ReplaceAllAlbum"/>
                            <InputFile multiple OnChange="@OnAlbumImageUpload" />
                            <RadzenButton Icon="checklist" Size="ButtonSize.Small" Text="@L("Actions.SelectAll")" Click="@SelectAllAlbumImages"/>
                            <RadzenButton Icon="check_box_outline_blank" Size="ButtonSize.Small" Text="@L("Actions.SelectNone")" Click="@SelectNoneAlbumImages"/>
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Text="@L("Actions.DeleteSelected")"
                                          Disabled="@(!_selectedAlbumImagePaths.Any())"
                                          Visible="CurrentUser?.IsEditor() ?? false"
                                          Click="@DeleteSelectedAlbumImagesButtonClick" />
                        </RadzenStack>
                        <RadzenDataList Data="@_albumImageList" TItem="AlbumImageListItem" class="rz-mt-3">
                            <Template Context="item">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenCheckBox TValue="bool" Value="@_selectedAlbumImagePaths.Contains(item.File.FullName)"
                                                    Change="@(args => ToggleAlbumImageSelected(item.File.FullName, args))"/>
                                    <RadzenImage Path="@item.ImageBase64" Style="width: 96px; height: 96px; object-fit:cover;"/>
                                    <RadzenText Text="@item.File.Name"/>
                                </RadzenStack>
                            </Template>
                        </RadzenDataList>
                    </ChildContent>
                </RadzenPanel>
            }
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>

@code {

    [Parameter] public Guid ApiKey { get; set; }

    /// <summary>
    ///     When this is set, is it used if the album gets deleted to return the user back (like viewing albums for an artist
    ///     return to the artist detail)
    /// </summary>
    [Parameter]
    public string? FromUrl { get; set; }

    string AlbumStatusStyle { get; set; } = string.Empty;

    ShowItem _showItem = ShowItem.Overview;

    bool _isLoading = true;
    bool _isPinned;
    bool _jukeboxEnabled;

    private enum ShowItem
    {
        Overview = 1,
        Contributors,
        Charts,
        Files,
        Images
    }

    UserAlbum _userAlbum = new()
    {
        UserId = 0,
        AlbumId = 0,
        CreatedAt = default
    };

    UserSong[] _userSongs = [];

    Album _album = new()
    {
        Artist = new Artist
        {
            Library = new Library
            {
                Name = string.Empty,
                Path = string.Empty,
                Type = 0,
                CreatedAt = default
            },
            Name = string.Empty,
            NameNormalized = string.Empty,
            Directory = string.Empty,
            LibraryId = 0,
            CreatedAt = default
        },
        Name = string.Empty,
        NameNormalized = string.Empty,
        Directory = string.Empty,
        CreatedAt = default
    };

    List<AlbumChartInfo> _albumCharts = [];

    string[] _albumsImagesInByteBase64 = [];
    long _imageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
    // Album Images (selection + listing)
    System.IO.FileInfo[] _albumImageFiles = [];
    class AlbumImageListItem { public required System.IO.FileInfo File { get; init; } public required string ImageBase64 { get; init; } }
    List<AlbumImageListItem> _albumImageList = [];
    HashSet<string> _selectedAlbumImagePaths = [];
    bool _replaceAllAlbumImages = false;

    // Album Files (non-image files)
    System.IO.FileInfo[] _albumFiles = [];
    class AlbumFileListItem { public required System.IO.FileInfo File { get; init; } }
    List<AlbumFileListItem> _albumFileList = [];
    HashSet<string> _selectedAlbumFilePaths = [];

    private long _albumDirectoryFileCount;
    private long _maxUploadSize;
    private Library? _library;

    private readonly List<string> _alertMessages = [];
    private FileSystemDirectoryInfo _albumDirectory = FileSystemDirectoryInfo.Blank();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _maxUploadSize = (await SettingService.GetValueAsync<long?>(SettingRegistry.SystemMaxUploadSize)).Data ?? (5 * 1024 * 1024);
        var libraryResult = await LibraryService.GetByApiKeyAsync(_album.Artist.Library.ApiKey);
        if (libraryResult.IsSuccess && libraryResult.Data != null)
        {
            _library = libraryResult.Data;
        }
        
        var configuration = await ConfigurationFactory.GetConfigurationAsync();
        _jukeboxEnabled = configuration.GetValue<bool>(SettingRegistry.JukeboxEnabled);
    }

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        _alertMessages.Clear();
        if (ApiKey != Guid.Empty)
        {
            var albumResult = await AlbumService.GetByApiKeyAsync(ApiKey);
            if (albumResult is { IsSuccess: true, Data: not null })
            {
                _album = albumResult.Data;
                _albumDirectory = Path.Combine(_album.Artist.Library.Path, _album.Artist.Directory, _album.Directory).ToFileSystemDirectoryInfo();
                _albumDirectoryFileCount = _albumDirectory.FileCount();
                switch (_album.AlbumStatusValue)
                {
                    case AlbumStatus.New:
                        AlbumStatusStyle = "color: var(--rz-info)";
                        break;
                    case AlbumStatus.Invalid:
                        AlbumStatusStyle = "color: var(--rz-warning)";
                        break;
                    default:
                        AlbumStatusStyle = "color: var(--rz-success)";
                        break;
                }

                _userAlbum = await UserService.UserAlbumAsync(CurrentUsersId, _album.ApiKey) ?? new UserAlbum
                {
                    UserId = 0,
                    AlbumId = 0,
                    CreatedAt = default
                };
                _userSongs = await UserService.UserSongsForAlbumAsync(CurrentUsersId, _album.ApiKey) ?? [];
                if (!_albumDirectory.Exists())
                {
                    _alertMessages.Add(L("AlbumDetail.AlbumDirectoryNotFound", (object)_albumDirectory.FullName()));
                }

                if (_album.ImageCount > 1)
                {
                    var albumsImagesInByteBase64 = new List<(int, string)>();
                    await Parallel.ForEachAsync(_albumDirectory.AllFileImageTypeFileInfos()
                        .OrderBy(x => x.Name)
                        .Select((x, i) => new
                        {
                            index = i,
                            file = x.ToFileSystemInfo()
                        }), CancellationToken.None, async (albumImage, token) =>
                    {
                        var imageBase64 = await albumImage.file.ImageBase64(_albumDirectory, token);
                        if (imageBase64 != null)
                        {
                            albumsImagesInByteBase64.Add((albumImage.index, imageBase64));
                        }
                    });
                    _albumsImagesInByteBase64 = albumsImagesInByteBase64.OrderBy(x => x.Item1).Select(x => x.Item2).ToArray();
                }

                _isPinned = await UserService.IsPinned(CurrentUsersId, UserPinType.Album, _album.Id);

                await RefreshAlbumImages();
                RefreshAlbumFiles();
                await LoadAlbumChartsAsync();

                _isLoading = false;
            }
        }
    }

    private async void OnShowItemChange(TreeEventArgs arg)
    {
        switch (arg.Text)
        {
            default:
                _showItem = ShowItem.Overview;
                break;
            case var text when text == L("Navigation.Charts"):
                _showItem = ShowItem.Charts;
                break;
            case var text when text == L("Nav.Files"):
                _showItem = ShowItem.Files;
                break;
            case var text when text == L("Nav.Images"):
                _showItem = ShowItem.Images;
                _imageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                await RefreshAlbumImages();
                break;
        }
    }

    private async Task OnAlbumImageUpload(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            await using var ms = new MemoryStream();
            await file.OpenReadStream(_maxUploadSize).CopyToAsync(ms);
            var save = await AlbumService.SaveImageAsAlbumImageAsync(_album.Id, _replaceAllAlbumImages, ms.ToArray());
            if (!save.IsSuccess)
            {
                NotificationService.Notify(NotificationMessageForResult(save, L("AlbumDetail.UploadAlbumImage"), ToastTime));
            }
            _replaceAllAlbumImages = false; // only first upload replaces all
        }
        await RefreshAlbumImages();
    }

    private async Task RefreshAlbumImages()
    {
        _imageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        _albumImageFiles = _albumDirectory
            .AllFileImageTypeFileInfos()
            .OrderBy(f => f.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        _albumImageList = [];
        var valid = _albumImageFiles.Select(f => f.FullName).ToHashSet();
        _selectedAlbumImagePaths.RemoveWhere(p => !valid.Contains(p));
        foreach (var fi in _albumImageFiles)
        {
            string base64;
            try
            {
                var bytes = await System.IO.File.ReadAllBytesAsync(fi.FullName);
                base64 = $"data:image;base64,{Convert.ToBase64String(bytes)}";
            }
            catch
            {
                base64 = DefaultImages.AlbumCoverBase64;
            }
            _albumImageList.Add(new AlbumImageListItem { File = fi, ImageBase64 = base64 });
        }
        StateHasChanged();
    }

