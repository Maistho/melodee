    private void UpdateLocalUserSong(int songId, Action<UserSong> updateAction)
    {
        var existingUserSong = _userSongs.FirstOrDefault(x => x.SongId == songId);
        if (existingUserSong != null)
        {
            updateAction(existingUserSong);
        }
        else
        {
            var newUserSong = new UserSong
            {
                UserId = CurrentUsersId,
                SongId = songId,
                CreatedAt = SystemClock.Instance.GetCurrentInstant()
            };
            updateAction(newUserSong);
            _userSongs = [.._userSongs, newUserSong];
        }
        StateHasChanged();
    }

