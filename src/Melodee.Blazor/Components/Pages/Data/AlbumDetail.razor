    private async Task AlbumSearchImageCallback(ImageSearchResult? selectedImageSearchResult)
    {
        MainLayoutProxyService.ToggleSpinnerVisible();

        DialogService.Close();

        try
        {
            if (selectedImageSearchResult != null)
            {
                OperationResult<bool>? saveResult = null;
                if (selectedImageSearchResult.ImageBytes != null)
                {
                    saveResult = await AlbumService.SaveImageAsAlbumImageAsync(_album.Id, selectedImageSearchResult.DoDeleteAllOtherImages, selectedImageSearchResult.ImageBytes);
                }
                else
                {
                    saveResult = await AlbumService.SaveImageUrlAsAlbumImageAsync(_album.Id, selectedImageSearchResult.Url, selectedImageSearchResult.DoDeleteAllOtherImages);
                }

                if (saveResult.IsSuccess)
                {
                    NavigationManager.Refresh(true);
                }
                else
                {
                    NotificationService.Notify(NotificationMessageForResult(saveResult, L("AlbumDetail.SavingArtistImage"), ToastTime));
                }
            }
        }
        finally
        {
            MainLayoutProxyService.ToggleSpinnerVisible();
        }
    }

