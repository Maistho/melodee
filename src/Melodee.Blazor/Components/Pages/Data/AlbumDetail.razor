    async Task LoadAlbumChartsAsync()
    {
        try
        {
            var chartsResult = await ChartService.ListAsync(new PagedRequest { Page = 1, PageSize = 10000 }, includeHidden: true);

            if (chartsResult.IsSuccess && chartsResult.Data != null)
            {
                _albumCharts = chartsResult.Data
                    .SelectMany(chart => chart.Items
                        .Where(item => item.LinkedAlbumId == _album.Id)
                        .Select(item => new AlbumChartInfo
                        {
                            Rank = item.Rank,
                            ChartApiKey = chart.ApiKey,
                            ChartTitle = chart.Title,
                            SourceName = chart.SourceName,
                            Year = chart.Year
                        }))
                    .OrderBy(c => c.Rank)
                    .ToList();
            }
        }
        catch (Exception e)
        {
            Logger.Error(e, "Loading album charts for [{AlbumApiKey}]", ApiKey);
        }
    }

    sealed class AlbumChartInfo
    {
        public int Rank { get; init; }
        public Guid ChartApiKey { get; init; }
        public string ChartTitle { get; init; } = string.Empty;
        public string? SourceName { get; init; }
        public int? Year { get; init; }
    }

    private async Task AddSongToJukeboxAsync(Song song)
    {
        try
        {
            Logger.Debug("[AlbumDetail] Adding song to Jukebox queue: {SongApiKey} - {SongTitle}", song.ApiKey, song.Title);
            
            var result = await SubsonicJukeboxService.AddAsync([song.ApiKey.ToString()]);
            
            if (result.IsSuccess)
            {
                Logger.Debug("[AlbumDetail] Successfully added song to Jukebox queue: {SongTitle}", song.Title);
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = L("AlbumDetail.AddedToJukebox"),
                    Detail = $"'{song.Title}' {L("AlbumDetail.AddedToQueue")}",
                    Duration = ToastTime
                });
            }
            else
            {
                Logger.Warning("[AlbumDetail] Failed to add song to Jukebox queue: {SongTitle}, Messages: {Messages}", 
                    song.Title, string.Join(", ", result.Messages ?? []));
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Warning,
                    Summary = L("AlbumDetail.JukeboxError"),
                    Detail = result.Messages?.FirstOrDefault() ?? L("Common.UnknownError"),
                    Duration = ToastTime
                });
            }
        }
        catch (Exception ex)
        {
            Logger.Error(ex, "[AlbumDetail] Error adding song to Jukebox queue: {SongTitle}", song.Title);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("Common.Error"),
                Detail = $"{L("AlbumDetail.JukeboxError")}: {ex.Message}",
                Duration = ToastTime
            });
        }
    }

