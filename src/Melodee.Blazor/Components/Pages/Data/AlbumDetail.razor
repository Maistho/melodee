    private async Task OnAlbumFilesUpload(InputFileChangeEventArgs e)
    {
        var dir = _albumDirectory.FullName();
        foreach (var file in e.GetMultipleFiles())
        {
            try
            {
                // Use SafePath to prevent path traversal attacks - file.Name could contain malicious path components
                var target = Melodee.Common.Utility.SafePath.ResolveUnderRoot(dir, file.Name);
                if (target == null)
                {
                    NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L("AlbumDetail.UploadFailed"), Detail = L("AlbumDetail.UploadFailedInvalidPath") });
                    continue;
                }
                await using var fs = File.Create(target);
                await file.OpenReadStream(_maxUploadSize).CopyToAsync(fs);
            }
            catch (Exception ex)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L("AlbumDetail.DeleteFailed"), Detail = ex.Message });
            }
        }
        RefreshAlbumFiles();
        await AlbumService.RescanAsync([_album.Id]);
    }

    private void RefreshAlbumFiles()
    {
        var all = _albumDirectory
            .AllFileInfos()
            .OrderBy(f => f.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        var images = _albumDirectory.AllFileImageTypeFileInfos().Select(f => f.FullName).ToHashSet();
        _albumFiles = all
            .Where(f => !images.Contains(f.FullName))
            .OrderBy(f => f.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();
        _albumFileList = _albumFiles
            .Select(f => new AlbumFileListItem { File = f })
            .ToList();
        var valid = _albumFiles.Select(f => f.FullName).ToHashSet();
        _selectedAlbumFilePaths.RemoveWhere(p => !valid.Contains(p));
        _albumDirectoryFileCount = _albumDirectory.FileCount();
        StateHasChanged();
    }

