@page "/charts"

@inherits MelodeeComponentBase
@using Melodee.Blazor.Components.Pages.Admin
@using Melodee.Common.Data.Models
@using Melodee.Common.Enums

@inject MainLayoutProxyService MainLayoutProxyService
@inject ILogger Logger
@inject ChartService ChartService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject TooltipService TooltipService
@inject NavigationManager NavigationManager
@inject IAuthService AuthService
@inject DefaultImages DefaultImages

<PageTitle>@L("Charts.PageTitle")</PageTitle>

<RadzenBreadCrumb Class="rz-pb-5">
    <RadzenBreadCrumbItem Path="/" Text="@L("Nav.Home")"/>
    <RadzenBreadCrumbItem Icon="format_list_numbered" Text="@L("Navigation.Charts")"/>
</RadzenBreadCrumb>

<RadzenStack Style="height: 100%">
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="@L("Charts.PageTitle")" TextStyle="TextStyle.DisplayH6" TagName="TagName.H1" style="margin: 0"/>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack
                Orientation="Orientation.Horizontal"
                AlignItems="AlignItems.Center"
                JustifyContent="JustifyContent.End"
                Gap="0.5rem">
                <RadzenButton Icon="trending_up" Text="@L("Charts.RankedReport")" Click="@(() => NavigationManager.NavigateTo("/charts/ranked-report"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Success"/>
                <RadzenButton Icon="report" Text="@L("Charts.MissingReport")" Click="@(() => NavigationManager.NavigateTo("/charts/missing-report"))" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Info"/>
                @if (AuthService.IsAdmin)
                {
                    <RadzenButton Icon="upload_file" Text="@L("Actions.ImportJSON")" Click="@ImportJsonClick" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Secondary"/>
                    <RadzenButton Icon="add_circle_outline" Text="@L("Actions.CreateChart")" Click="@CreateChartClick" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Primary"/>
                    <RadzenButton Icon="delete" Disabled="!_selectedCharts.Any()" Text="@L("Actions.Delete")" Click="@DeleteSelectedButtonClick" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Warning"/>
                }
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Style="flex: 1; overflow: hidden;">
        <RadzenDataGrid TItem="Chart"
            @ref="_grid"
            Style="height: 100%"
            IsLoading="@_isLoading"
            Count="@_count"
            Data="@_charts"
            LoadData="@LoadData"
            AllowSorting="true"
            AllowFiltering="false"
            AllowRowSelectOnRowClick="false"
            AllowPaging="true"
            Page="OnPage"
            PageSize="DefaultPageSize"
            PagerHorizontalAlign="HorizontalAlign.Center"
            ShowPagingSummary="true"
            PageSizeOptions="@PageSizeOptions"
            PagingSummaryFormat="@GridPagingSummaryFormat"
            PageSizeText="@GridPageSizeText"
            EmptyText="@GridEmptyText"
            ColumnWidth="200px"
            SelectionMode="@(AuthService.IsAdmin ? DataGridSelectionMode.Multiple : DataGridSelectionMode.Single)"
            @bind-Value="@_selectedCharts">
            <Columns>
                @if (AuthService.IsAdmin)
                {
                    <RadzenDataGridColumn Width="60px" Sortable="false" Filterable="false">
                        <HeaderTemplate>
                            <RadzenCheckBox
                                TabIndex="-1"
                                TriState="false"
                                TValue="bool?"
                                InputAttributes="@(new Dictionary<string, object> { { "aria-label", L("Charts.SelectAllItems") } })"
                                Value="@(_selectedCharts.Any() != true ? false : !_charts.All(i => _selectedCharts.Contains(i)) ? null : _charts.Any(i => _selectedCharts.Contains(i)))"
                                Change="@(args => _selectedCharts = args == true ? _charts.ToList() : [])"/>
                        </HeaderTemplate>
                        <Template Context="data">
                            <RadzenCheckBox
                                TabIndex="-1"
                                TriState="false"
                                Value="@(_selectedCharts.Contains(data))"
                                InputAttributes="@(new Dictionary<string, object> { { "aria-label", L("Charts.SelectItem") } })"
                                Change="@(_ => { _grid.SelectRow(data); })"
                                TValue="bool"/>
                        </Template>
                    </RadzenDataGridColumn>
                }

                <RadzenDataGridColumn Property="@nameof(Chart.Title)" Title="@L("Common.Title")" Width="250px">
                    <Template Context="data">
                        <RadzenLink Path="@($"/charts/{data.ApiKey}")" Text="@data.Title"/>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="@nameof(Chart.SourceName)" Title="@L("TableHeader.Source")" Width="150px"/>

                <RadzenDataGridColumn Property="@nameof(Chart.Year)" Title="@L("Common.Year")" Width="80px"/>

                <RadzenDataGridColumn Title="@L("TableHeader.Items")" Width="80px" Sortable="false">
                    <Template Context="data">
                        <RadzenText>@data.Items.Count</RadzenText>
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Title="@L("TableHeader.Completion")" Width="120px" Sortable="false">
                    <Template Context="data">
                        @{
                            var linkedCount = data.Items.Count(i => i.LinkStatusValue == ChartItemLinkStatus.Linked);
                            var totalCount = data.Items.Count;
                            var percentage = totalCount > 0 ? (int)Math.Round((linkedCount / (double)totalCount) * 100) : 0;
                            var isCompleted = linkedCount == totalCount && totalCount > 0;
                        }
                        @if (isCompleted)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@($"{percentage}%")" />
                        }
                        else if (percentage > 0)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@($"{percentage}%")" />
                        }
                        else
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="0%" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="@nameof(Chart.IsVisible)" Title="@L("Label.Visible")" Width="100px" Visible="@AuthService.IsAdmin">
                    <Template Context="data">
                        @if (data.IsVisible)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("Status.Visible")"/>
                        }
                        else
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@L("Status.Hidden")"/>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="@nameof(Chart.IsGeneratedPlaylistEnabled)" Title="@L("TableHeader.Playlist")" Width="100px">
                    <Template Context="data">
                        @if (data.IsGeneratedPlaylistEnabled)
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@L("Status.Enabled")"/>
                        }
                        else
                        {
                            <RadzenBadge BadgeStyle="BadgeStyle.Light" Text="@L("Status.Disabled")"/>
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn Property="@nameof(Chart.CreatedAt)" Title="@L("Common.Created")" Width="150px">
                    <Template Context="data">
                        <RadzenText Text="@CurrentUser?.FormatInstant(data.CreatedAt)"/>
                    </Template>
                </RadzenDataGridColumn>

                @if (AuthService.IsAdmin)
                {
                    <RadzenDataGridColumn Title="@L("Data.Actions")" Width="120px" Sortable="false">
                        <Template Context="data">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem">
                                <RadzenButton Icon="edit" Size="ButtonSize.Small" Click="@(() => EditChart(data))" ButtonStyle="ButtonStyle.Light" MouseEnter="@(args => ShowTooltip(args, L("Charts.EditChart")))"/>
                                <RadzenButton Icon="delete" Size="ButtonSize.Small" Click="@(() => DeleteChart(data))" ButtonStyle="ButtonStyle.Danger" MouseEnter="@(args => ShowTooltip(args, L("Charts.DeleteChart")))"/>
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                }
            </Columns>
        </RadzenDataGrid>
    </RadzenRow>
</RadzenStack>

@code {
    RadzenDataGrid<Chart> _grid = null!;
    int _count;
    IEnumerable<Chart> _charts = [];
    bool _isLoading;
    int _currentPage = 1;
    IList<Chart> _selectedCharts = [];

    void OnPage(PagerEventArgs args)
    {
        _currentPage = args.PageIndex + 1;
    }

    protected override async Task OnInitializedAsync()
    {
      await base.OnInitializedAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender && _grid != null)
        {
            await _grid.FirstPage(true);
        }
    }

    async Task LoadData(LoadDataArgs args)
    {
        _isLoading = true;
        MainLayoutProxyService.ToggleSpinnerVisible();
        try
        {
          var result = await ChartService.ListAsync(
            new PagedRequest
            {
              Page = _currentPage,
              PageSize = SafeParser.ToNumber<short>(args.Top)
            },
            includeHidden: AuthService.IsAdmin);
          _charts = result.Data;
          _count = result.TotalCount;
        }
        catch (Exception e)
        {
          Logger.Error(e, "Loading Charts");
        }
        finally
        {
          _isLoading = false;
          MainLayoutProxyService.ToggleSpinnerVisible();
        }
    }

    void CreateChartClick()
    {
        NavigationManager.NavigateTo("/charts/create");
    }

    async Task ImportJsonClick()
    {
        var result = await DialogService.OpenAsync<ChartImportDialog>(L("Charts.ImportChartFromJSON"),
            new Dictionary<string, object>(),
            new DialogOptions { Width = "600px", Height = "500px", Resizable = true, Draggable = true });

        if (result is true)
        {
            await _grid.RefreshDataAsync();
        }
    }

    void EditChart(Chart chart)
    {
        NavigationManager.NavigateTo($"/charts/edit/{chart.Id}");
    }

    async Task DeleteChart(Chart chart)
    {
        var confirm = await DialogService.Confirm(string.Format(L("Charts.ConfirmDeleteChart"), chart.Title), L("Charts.DeleteChart"), new ConfirmOptions { OkButtonText = L("Actions.Yes"), CancelButtonText = L("Actions.No") });
        if (confirm ?? false)
        {
            var result = await ChartService.DeleteAsync(chart.Id);
            NotificationService.Notify(NotificationMessageForResult(result, L("Charts.DeletingChart"), ToastTime));
            if (result.IsSuccess)
            {
                await _grid.RefreshDataAsync();
            }
        }
    }

    async Task DeleteSelectedButtonClick()
    {
        var confirm = await DialogService.Confirm(string.Format(L("Charts.ConfirmDeleteCharts"), _selectedCharts.Count), L("Charts.DeleteCharts"), new ConfirmOptions { OkButtonText = L("Actions.Yes"), CancelButtonText = L("Actions.No") });
        if (confirm ?? false)
        {
            foreach (var chart in _selectedCharts.ToList())
            {
                await ChartService.DeleteAsync(chart.Id);
            }
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = L("Charts.ChartsDeleted"),
                Duration = ToastTime
            });
            _selectedCharts.Clear();
            await _grid.RefreshDataAsync();
        }
    }

    void ShowTooltip(ElementReference elementReference, string message)
    {
        TooltipService.Open(elementReference, message);
    }
}
