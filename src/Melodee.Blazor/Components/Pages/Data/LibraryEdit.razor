@page "/data/libraryedit/{ApiKey:guid}"
@inherits MelodeeComponentBase
@using Melodee.Common.Enums
@using Library = Melodee.Common.Data.Models.Library

@inject LibraryService LibraryService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

@attribute [Authorize(Roles = "Administrator")]

<PageTitle>@(IsNew ? L("LibraryEdit.AddLibrary") : L("LibraryEdit.PageTitle"))</PageTitle>

<RadzenBreadCrumb Class="rz-pb-5">
    <RadzenBreadCrumbItem Path="/" Text="@L("Navigation.Dashboard")"/>
    <RadzenBreadCrumbItem Path="/data/libraries" Text="@L("Navigation.Libraries")"/>
    <RadzenBreadCrumbItem Icon="@(IsNew ? "add" : "edit")" Text="@(IsNew ? L("LibraryEdit.Adding") : L("LibraryEdit.Editing"))"/>
</RadzenBreadCrumb>

<RadzenTemplateForm TItem="Library" Data="@_library" Submit="@OnSubmit">
    <RadzenFieldset Text="@(IsNew ? L("LibraryEdit.NewLibrary") : L("LibraryEdit.EditLibraryTitle", _library.Name))">
        <RadzenStack Gap="1rem">
            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="@L("Label.Name")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="_library.Name" Placeholder="@L("LibraryEdit.LibraryNamePlaceholder")" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="@L("Label.Path")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="_library.Path" Placeholder="@L("LibraryEdit.FilesystemPathPlaceholder")" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="@L("Label.Type")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenDropDown @bind-Value="_library.Type" Data="@_libraryTypes" TextProperty="Text" ValueProperty="Value" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="@L("Label.Description")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextArea @bind-Value="_library.Description" Rows="3" Placeholder="@L("LibraryEdit.OptionalDescriptionPlaceholder")" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="@L("Label.Notes")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextArea @bind-Value="_library.Notes" Rows="3" Placeholder="@L("LibraryEdit.OptionalNotesPlaceholder")" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenFormField Text="@L("Label.Tags")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenTextBox @bind-Value="_library.Tags" Placeholder="@L("LibraryEdit.CommaSeparatedTagsPlaceholder")" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenFormField Text="@L("Label.SortOrder")" Variant="Variant.Outlined" Style="width:100%">
                        <RadzenNumeric @bind-Value="_library.SortOrder" Style="width:100%"/>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="height:100%">
                        <RadzenSwitch @bind-Value="_library.IsLocked" Name="IsLocked"/>
                        <RadzenLabel Text="@L("Status.Locked")" Component="IsLocked"/>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
                        <RadzenButton Text="@L("Actions.Cancel")" ButtonStyle="ButtonStyle.Secondary" Click="@(() => NavigationManager.NavigateTo("/data/libraries"))"/>
                        <RadzenButton Icon="save" Text="@L("Actions.Save")" ButtonType="ButtonType.Submit"/>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldset>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid ApiKey { get; set; }
    bool IsNew => ApiKey == Guid.Empty;

    Library _library = new()
    {
        Name = string.Empty,
        Path = string.Empty,
        Type = (int)LibraryType.Storage,
        CreatedAt = default
    };

    List<LibraryTypeOption> _libraryTypes = [];

    class LibraryTypeOption
    {
        public int Value { get; init; }
        public string Text { get; init; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _libraryTypes = Enum.GetValues<LibraryType>()
            .Where(t => t != LibraryType.NotSet)
            .Select(t => new LibraryTypeOption { Value = (int)t, Text = L($"LibraryType.{t}") })
            .ToList();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsNew)
        {
            var result = await LibraryService.GetByApiKeyAsync(ApiKey);
            if (result.Data != null)
            {
                _library = result.Data;
            }
        }
    }

    private async Task OnSubmit(Library _)
    {
        if (IsNew)
        {
            var result = await LibraryService.CreateAsync(_library);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error,
                Summary = result.IsSuccess ? L("Status.Created") : L("Status.Error"),
                Detail = result.IsSuccess ? L("Message.LibraryCreated") : string.Join(";", result.Messages ?? [])
            });
            if (result.IsSuccess)
            {
                NavigationManager.NavigateTo("/data/libraries", true);
            }
        }
        else
        {
            var result = await LibraryService.UpdateAsync(_library);
            NotificationService.Notify(new NotificationMessage
            {
                Severity = result.IsSuccess ? NotificationSeverity.Success : NotificationSeverity.Error,
                Summary = result.IsSuccess ? L("Status.Saved") : L("Status.Error"),
                Detail = result.IsSuccess ? L("Message.LibrarySaved") : string.Join(";", result.Messages ?? [])
            });
            if (result.IsSuccess)
            {
                NavigationManager.NavigateTo("/data/libraries", true);
            }
        }
    }
}
