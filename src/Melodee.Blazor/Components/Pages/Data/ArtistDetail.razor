    private async Task DeleteSelectedRelationshipsButtonClick()
    {
        if (!_selectedRelationships.Any()) return;
        var confirm = await DialogService.Confirm(L("Dialog.AreYouSure"), L("ArtistDetail.DeleteSelectedRelationships", _selectedRelationships.Count), new ConfirmOptions { OkButtonText = L("Actions.Yes"), CancelButtonText = L("Actions.No") });
        if (!(confirm ?? false)) return;

        foreach (var key in _selectedRelationships.ToArray())
        {
            var result = await ArtistService.DeleteArtistRelationAsync(key.OwnerArtistId, key.RelatedArtistId);
            if (!result.IsSuccess || !result.Data)
            {
                NotificationService.Notify(NotificationMessageForResult(result, L("ArtistDetail.RemovingRelationship"), ToastTime));
            }
        }
        _selectedRelationships.Clear();
        await RefreshRelationshipsAsync();
    }

