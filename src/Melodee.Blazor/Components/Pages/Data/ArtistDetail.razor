    private async Task DeleteSelectedArtistImagesButtonClick()
    {
        if (!_selectedImagePaths.Any()) return;
        var confirm = await DialogService.Confirm(L("Dialog.AreYouSure"), L("ArtistDetail.DeleteSelectedImages", _selectedImagePaths.Count), new ConfirmOptions { OkButtonText = L("Actions.Yes"), CancelButtonText = L("Actions.No") });
        if (!(confirm ?? false)) return;

        var deleteCount = 0;
        foreach (var path in _selectedImagePaths.ToArray())
        {
            try
            {
                if (System.IO.File.Exists(path))
                {
                    System.IO.File.Delete(path);
                    deleteCount++;
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L("ArtistDetail.DeleteFailed"), Detail = ex.Message });
            }
        }

        _selectedImagePaths.Clear();
        _artist.ImageCount = Math.Max(0, (_artist.ImageCount ?? 0) - deleteCount);
        await ArtistService.UpdateAsync(_artist);
        await RefreshArtistImages();
    }

    private async Task RefreshArtistImages()
    {
        _imageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        var artistDirectory = Path.Combine(_artist.Library.Path, _artist.Directory).ToFileSystemDirectoryInfo();
        _artistImageFiles = artistDirectory.FileInfosForExtension("jpg", false).ToArray();
        var list = new List<string>();
        _artistImageList = [];
        var validPaths = new HashSet<string>(_artistImageFiles.Select(f => f.FullName));
        _selectedImagePaths.RemoveWhere(p => !validPaths.Contains(p));
        foreach (var fi in _artistImageFiles)
        {
            string path;
            try
            {
                var bytes = await System.IO.File.ReadAllBytesAsync(fi.FullName);
                path = $"data:image;base64,{Convert.ToBase64String(bytes)}";
            }
            catch
            {
                path = DefaultImages.ArtistBase64;
            }
            list.Add(path);
            _artistImageList.Add(new ArtistImageListItem { File = fi, ImageBase64 = path });
        }
        _artistImagesInByteBase64 = list.ToArray();
        StateHasChanged();
    }

