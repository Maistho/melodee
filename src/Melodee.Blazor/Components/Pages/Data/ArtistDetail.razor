    protected override async Task OnParametersSetAsync()
    {
        _alertMessages.Clear();
        if (ApiKey != Guid.Empty)
        {
            var artistResult = await ArtistService.GetByApiKeyAsync(ApiKey);
            if (artistResult is { IsSuccess: true, Data: not null })
            {
                _artist = artistResult.Data;

                _userArtist = await UserService.UserArtistAsync(CurrentUsersId, _artist.ApiKey) ?? new UserArtist
                {
                    UserId = 0,
                    ArtistId = 0,
                    CreatedAt = default
                };

                var artistDirectory = Path.Combine(_artist.Library.Path, _artist.Directory).ToFileSystemDirectoryInfo();
                if (!artistDirectory.Exists())
                {
                    _alertMessages.Add(L("ArtistDetail.ArtistDirectoryNotFound", (object)artistDirectory.FullName()));
                }

                await LoadAlbums();

                if (_artist.ImageCount > 1)
                {
                    var artistImagesInBase64 = new List<(int, string)>();
                    await Parallel.ForEachAsync(artistDirectory.AllFileImageTypeFileInfos()
                        .OrderBy(x => x.Name)
                        .Select((x, i) => new
                        {
                            index = i,
                            file = x.ToFileSystemInfo()
                        }), CancellationToken.None, async (artistImage, token) =>
                    {
                        var imageBase64 = await artistImage.file.ImageBase64(artistDirectory, token);
                        if (imageBase64 != null)
                        {
                            artistImagesInBase64.Add((artistImage.index, imageBase64));
                        }
                    });
                    _artistImagesInByteBase64 = artistImagesInBase64.OrderBy(x => x.Item1).Select(x => x.Item2).ToArray();
                    _artistImageFiles = artistDirectory.FileInfosForExtension("jpg", false).ToArray();
                }
                else
                {
                    _artistImageFiles = artistDirectory.FileInfosForExtension("jpg", false).ToArray();
                }

                // Build image list items safely
                _artistImageList = [];
                for (var i = 0; i < _artistImageFiles.Length; i++)
                {
                    var fi = _artistImageFiles[i];
                    string path;
                    if (i < _artistImagesInByteBase64.Length)
                    {
                        path = _artistImagesInByteBase64[i];
                    }
                    else
                    {
                        try
                        {
                            var bytes = await System.IO.File.ReadAllBytesAsync(fi.FullName);
                            path = $"data:image;base64,{Convert.ToBase64String(bytes)}";
                        }
                        catch
                        {
                            path = DefaultImages.ArtistBase64;
                        }
                    }
                    _artistImageList.Add(new ArtistImageListItem { File = fi, ImageBase64 = path });
                }

                _isPinned = await UserService.IsPinned(CurrentUsersId, UserPinType.Artist, _artist.Id);
                var outCountTask2 = ArtistService.CountArtistRelationsAsync(_artist.Id);
                var inCountTask2 = ArtistService.CountArtistRelationsInboundAsync(_artist.Id);
                await Task.WhenAll(outCountTask2, inCountTask2);
                _relationshipCount = outCountTask2.Result.Data + inCountTask2.Result.Data;
                _selectedImagePaths.Clear();
                _selectedRelationships.Clear();
            }
        }
    }

    private async void OnShowItemChange(TreeEventArgs arg)
    {
        switch (arg.Text)
        {
            default:
                _showItem = ShowItem.Overview;
                break;
            case var text when text == L("Nav.Images"):
                _showItem = ShowItem.Images;
                _imageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                await RefreshArtistImages();
                break;
            case var text when text == L("Nav.Relationships"):
                _showItem = ShowItem.Relationships;
                await RefreshRelationshipsAsync();
                break;
        }
    }

    private async Task OnArtistImageUpload(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles())
        {
            await using var ms = new MemoryStream();
            await file.OpenReadStream(_maxUploadSize).CopyToAsync(ms);
            var save = await ArtistService.SaveImageAsArtistImageAsync(_artist.Id, _replaceAllImages, ms.ToArray());
            if (!save.IsSuccess)
            {
                NotificationService.Notify(NotificationMessageForResult(save, L("ArtistDetail.UploadArtistImage"), ToastTime));
            }
            _replaceAllImages = false; // only first upload replaces all
        }
        await RefreshArtistImages();
    }

    private async Task DeleteArtistImageAsync(System.IO.FileInfo file)
    {
        try
        {
            // optimistically remove from UI before deleting to avoid rendering stale file
            _artistImageList = _artistImageList.Where(x => x.File.FullName != file.FullName).ToList();
            _artistImageFiles = _artistImageFiles.Where(x => x.FullName != file.FullName).ToArray();
            StateHasChanged();

            file.Delete();
            // update count
            _artist.ImageCount = Math.Max(0, (_artist.ImageCount ?? 0) - 1);
            await ArtistService.UpdateAsync(_artist);
            await RefreshArtistImages();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L("ArtistDetail.DeleteFailed"), Detail = ex.Message });
        }
    }

