    {
        var confirm = await DialogService.Confirm(L("Dialog.AreYouSure"), L("ArtistDetail.RemoveRelationship"), new ConfirmOptions { OkButtonText = L("Actions.Yes"), CancelButtonText = L("Actions.No") });
