@page "/data/artist/{ApiKey:guid}/{FromUrl?}"
@inherits MelodeeComponentBase
@using Melodee.Common.Data.Models
@using Melodee.Common.Data.Models.Extensions
@using Melodee.Common.Enums
@using Melodee.Common.Filtering
@using Melodee.Common.Models.Collection
@using Melodee.Common.Models.Extensions
@using Melodee.Common.Serialization
@using Artist = Melodee.Common.Data.Models.Artist
@using FilterOperator = Melodee.Common.Filtering.FilterOperator

@inject ArtistService ArtistService
@inject AlbumService AlbumService
@inject UserService UserService
@inject SettingService SettingService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject NavigationManager NavigationManager
@inject DefaultImages DefaultImages
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject IJSRuntime JsRuntime
@inject ISerializer Serializer

<PageTitle>@_artist.Name</PageTitle>

<RadzenStack>
    <RadzenRow AlignItems="AlignItems.Center" Class="rz-pb-5">
        <RadzenColumn Size="7" SizeMD="9">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                @if (FromUrl != null)
                {
                    <RadzenButton
                        Icon="arrow_back"
                        ButtonStyle="ButtonStyle.Info"
                        Text="@L("Nav.Back")"
                        title="@L("Nav.GoBack")"
                        Size="ButtonSize.Small"
                        Click="@(() => NavigationManager.NavigateTo(FromUrl, true))"/>
                }
                <RadzenBreadCrumb>
                    <RadzenBreadCrumbItem Path="/" Text="@L("Navigation.Dashboard")"/>
                    <RadzenBreadCrumbItem Path="/data/artists" Text="@L("Navigation.Artists")"/>
                    <RadzenBreadCrumbItem Icon="artist" Text="@_artist.Name"/>
                </RadzenBreadCrumb>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="5" SizeMD="3">
            <RadzenStack
                Orientation="Orientation.Horizontal"
                AlignItems="AlignItems.Center"
                JustifyContent="JustifyContent.End"
                Gap="0.5rem">
                <RadzenIcon Icon="@(_isPinned ? "keep" : "keep_off")" class="filled-icon"
                            IconColor="@(_isPinned ? "#99CCFF" : "#C9C9C7")"
                            @onclick="@TogglePinned" Style="cursor:pointer;"/>
                <RadzenRating Value="@_userArtist.Rating" Change="@UserRatingChange"/>
                <RadzenIcon Icon="thumb_down" class="filled-icon"
                            IconColor="@(_userArtist.IsHated ? "#A2A415" : "#C9C9C7")"
                            @onclick="@IsHatedClicked" Style="cursor:pointer;"/>
                <RadzenIcon Icon="favorite" class="filled-icon"
                            IconColor="@(_userArtist.IsStarred ? "#FA0202" : "#C9C9C7")"
                            @onclick="@IsStarredClicked" Style="cursor:pointer;"/>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>
@if (_alertMessages.Any())
{
    foreach (var alert in _alertMessages)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Size="AlertSize.Small" Icon="warning" AllowClose="false"
                     Text="@alert"/>
    }
}
<RadzenStack>
    <RadzenMenu>
        <RadzenMenuItem Text="@L("Actions.Delete")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_artist.IsLocked"
                        Click="DeleteButtonClick"
                        title="@L("ArtistDetail.DeleteArtistWarning")"
                        IconColor="@Colors.Danger" Icon="delete"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("ArtistDetail.DeleteAlbumsCount", _selectedAlbums.Count)" Visible="CurrentUser?.IsEditor() ?? false"
                        Disabled="_selectedAlbums.Count == 0" Click="DeleteAlbumsButtonClick"
                        title="@L("ArtistDetail.DeleteAlbumsWarning")" IconColor="@Colors.Danger"
                        Icon="remove"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("Actions.Edit")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_artist.IsLocked"
                        Click="EditButtonClick" title="@L("ArtistDetail.EditArtist")" Icon="edit"></RadzenMenuItem>
        @if (_artist.IsLocked)
        {
            <RadzenMenuItem Text="@L("Actions.Unlock")" Visible="CurrentUser?.IsEditor() ?? false" Click="UnlockButtonClick"
                            title="@L("ArtistDetail.UnlockArtist")" IconColor="@Colors.Warning"
                            Icon="lock_open"></RadzenMenuItem>
        }
        else
        {
            <RadzenMenuItem Text="@L("Actions.Lock")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_artist.IsLocked"
                            Click="LockButtonClick" title="@L("ArtistDetail.LockArtist")"
                            IconColor="@Colors.Warning" Icon="lock"></RadzenMenuItem>
        }
        <RadzenMenuItem Text="@L("Actions.Rescan")" Visible="CurrentUser?.IsEditor() ?? false" Disabled="_artist.IsLocked"
                        Click="RescanButtonClick" title="@L("ArtistDetail.RescanArtist")"
                        Icon="refresh"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("Actions.Validate")" Visible="CurrentUser?.IsEditor() ?? false"
                        Click="ValidateAlbumsClick" title="@L("ArtistDetail.ValidateAlbums")"
                        Icon="verified"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("Actions.Json")" Visible="CurrentUser?.IsEditor() ?? false" Click="GenerateJsonClick"
                        title="@L("ArtistDetail.GenerateJson")" Icon="text_snippet"></RadzenMenuItem>
        <RadzenMenuItem Text="@L("Actions.WebSearch")" Click="OnInternetSearchClick" title="@L("ArtistDetail.WebSearch")"
                        Icon="public"></RadzenMenuItem>
    </RadzenMenu>
    <RadzenText Text="@_artist.Name" TextStyle="TextStyle.DisplayH6" TagName="TagName.H1" style="margin: 0"/>
</RadzenStack>
<RadzenStack class="rz-mt-3">
    <RadzenRow>
        <RadzenColumn Size="4" SizeMD="2">
            <RadzenStack>
                <RadzenCard>
                    <RadzenTree Change="@OnShowItemChange">
                        <RadzenTreeItem Text="@L("Nav.Overview")" Selected="true">
                            <Template>
                                <RadzenIcon Icon="overview"/>
                                @context.Text
                            </Template>
                        </RadzenTreeItem>
                        <RadzenTreeItem Text="@L("Nav.Images")">
                            <Template>
                                <RadzenIcon Icon="image"/>
                                @($"{context.Text} ({_artistImageFiles?.Length ?? 0})")
                            </Template>
                        </RadzenTreeItem>
                        <RadzenTreeItem Text="@L("Nav.Relationships")">
                            <Template>
                                <RadzenIcon Icon="partner_exchange"/>
                                @($"{context.Text} ({_relationshipCount})")
                            </Template>
                        </RadzenTreeItem>
                    </RadzenTree>
                </RadzenCard>
                @if (_artist.Description.Nullify() != null)
                {
                    <RadzenPanel>
                        <HeaderTemplate>
                            <RadzenText TextStyle="TextStyle.H6"
                                        class="rz-display-flex rz-align-items-center rz-m-0">
                                <RadzenIcon Icon="description" class="rz-me-1"/>
                                @L("Label.Description")
                            </RadzenText>
                        </HeaderTemplate>
                        <ChildContent>
                            <Markdown Content="@(_artist.Description ?? string.Empty)"/>
                        </ChildContent>
                    </RadzenPanel>
                }
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="info" class="rz-me-1"/>
                            @L("Label.Details")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack
                            Orientation="Orientation.Vertical"
                            JustifyContent="JustifyContent.Left"
                            class="rz-pt-1"
                            Gap="5px">
                            <CondensedStatistic Label="@L("Label.Library")" Statistic="@_artist.Library.Name"/>
                            @if (_artist.RealName.Nullify() != null)
                            {
                                <CondensedStatistic Label="@L("Label.RealName")" Statistic="@_artist.RealName"/>
                            }
                            @if (CurrentUser?.IsAdmin() ?? false)
                            {
                                <CondensedStatistic Label="@L("Label.Directory")" Statistic="@_artist.Directory"/>
                            }
                            @if (_artist.SortName.Nullify() != null)
                            {
                                <CondensedStatistic Label="@L("Label.SortName")" Statistic="@_artist.SortName"/>
                            }
                            @if (_artist.AlternateNames.Nullify() != null)
                            {
                                <CondensedStatistic Label="@L("Label.AlternateNames")" Statistic="@_artist.AlternateNames"/>
                            }
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="link" class="rz-me-1"/>
                            @L("Label.ExternalLinks")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack
                            Orientation="Orientation.Vertical"
                            JustifyContent="JustifyContent.Left"
                            class="rz-pt-1"
                            Gap="5px">
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.Amg"
                                            Id="@_artist.AmgId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.Deezer"
                                            Id="@_artist.DeezerId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.Discogs"
                                            Id="@_artist.DiscogsId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.ITunes"
                                            Id="@_artist.ItunesId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.LastFm"
                                            Id="@_artist.LastFmId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.MusicBrainz"
                                            Id="@_artist.MusicBrainzId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.Spotify"
                                            Id="@_artist.SpotifyId"/>
                            <ThirdPartyLink MelodeeDataType="MelodeeDataType.Artist"
                                            ThirdPartyIdType="ThirdPartyIdType.WikiData"
                                            Id="@_artist.WikiDataId"/>
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6"
                                    class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="monitoring" class="rz-me-1"/>
                            @L("Label.Statistics")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack
                            Orientation="Orientation.Vertical"
                            JustifyContent="JustifyContent.Left"
                            class="rz-pt-1"
                            Gap="5px">
                            <CondensedStatistic Label="@L("Label.Rating")"
                                                Rating="@(_artist.CalculatedRating)"/>
                            <CondensedStatistic Label="@L("Label.AlbumCount")"
                                                Statistic="@(_artist.AlbumCount.ToStringPadLeft(3))"/>
                            <CondensedStatistic Label="@L("Label.SongCount")" Statistic="@(_artist.SongCount.ToStringPadLeft(4))"/>
                            <CondensedStatistic Label="@L("Label.PlayedTotal")"
                                                Statistic="@(_artist.PlayedCount.ToStringPadLeft(6))"/>
                            <CondensedStatistic Label="@L("Label.LastPlayed")"
                                                Statistic="@(CurrentUser?.FormatInstant(_artist.LastPlayedAt))"/>
                            <CondensedStatistic Label="@L("Label.Created")"
                                                Statistic="@(CurrentUser?.FormatInstant(_artist.CreatedAt))"/>
                            <CondensedStatistic Label="@L("Label.LastUpdated")"
                                                Statistic="@(CurrentUser?.FormatInstant(_artist.LastUpdatedAt))"/>
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="8" SizeMD="10">
            @if (_showItem == ShowItem.Overview)
            {
                <RadzenRow class="rz-pb-3">
                    <RadzenColumn Size="12" SizeMD="6" SizeXL="8">
                        <RadzenPanel>
                            <HeaderTemplate>

                                <RadzenText TextStyle="TextStyle.H6"
                                            class="rz-display-flex rz-align-items-center rz-m-0">
                                    <RadzenIcon Icon="album" class="rz-me-1"/>
                                    @L("Navigation.Albums")
                                </RadzenText>
                                <RadzenStack orientation="Orientation.Horizontal" class="rz-ml-auto">
                                    <DebounceInput class="rz-textbox"
                                                   style="width:200px;"
                                                   autocomplete="off"
                                                   @bind-Value="@_debounceAlbumFilterValue"
                                                   @bind-Value:event="OnInput"
                                                   DebounceTime="1000"
                                                   MinLength="2"
                                                   OnValueChanged="@FilterAlbumsAsync"
                                                   ForceNotifyByEnter="true"
                                                   ForceNotifyOnBlur="true"/>
                                    <RadzenSplitButton Icon="sort" Text="@L("Actions.Sort")" Click="@(async args =>
                                                                                      {
                                                                                          _albumSort = SafeParser.ToEnum<AlbumSort>(args.Value);
                                                                                          await LoadAlbums();
                                                                                      })">
                                        <ChildContent>
                                            <RadzenSplitButtonItem Icon="date_range" Text="@L("ArtistDetail.ReleaseDateAsc")"
                                                                   Value="@AlbumSort.ReleaseDate.ToString()"/>
                                            <RadzenSplitButtonItem Icon="date_range" Text="@L("ArtistDetail.ReleaseDateDesc")"
                                                                   Value="@AlbumSort.ReleaseDateDesc.ToString()"/>
                                            <RadzenSplitButtonItem Icon="timelapse" Text="@L("ArtistDetail.DurationAsc")"
                                                                   Value="@AlbumSort.Duration.ToString()"/>
                                            <RadzenSplitButtonItem Icon="timelapse" Text="@L("ArtistDetail.DurationDesc")"
                                                                   Value="@AlbumSort.DurationDesc.ToString()"/>
                                            <RadzenSplitButtonItem Icon="music_note" Text="@L("ArtistDetail.SongCountAsc")"
                                                                   Value="@AlbumSort.SongCount.ToString()"/>
                                            <RadzenSplitButtonItem Icon="music_note" Text="@L("ArtistDetail.SongCountDesc")"
                                                                   Value="@AlbumSort.SongCountDesc.ToString()"/>
                                        </ChildContent>
                                    </RadzenSplitButton>
                                </RadzenStack>

                            </HeaderTemplate>
                            <ChildContent>
                                @if (_isLoading)
                                {
                                    <RadzenProgressBarCircular
                                        ProgressBarStyle="ProgressBarStyle.Primary"
                                        Value="100"
                                        ShowValue="false"
                                        Mode="ProgressBarMode.Indeterminate"/>
                                }
                                @foreach (var album in _albums)
                                {
                                    <AlbumDataInfoCardCompactComponent
                                        FromUrl=@($"/data/artist/{_artist.ApiKey}")
                                        Checked="@(_selectedAlbums.Any() && _albums.All(i => _selectedAlbums.Contains(album)) && _albums.Any(i => _selectedAlbums.Contains(album)))"
                                        CheckedChanged="@((bool arg) => ToggleAlbumSelected(arg, album))"
                                        Album="@album"/>
                                }
                                <RadzenPager
                                    ShowPagingSummary="true"
                                    PagingSummaryFormat="@L("Message.DisplayingPage")"
                                    HorizontalAlign="HorizontalAlign.Right"
                                    Count="_totalAlbumCount"
                                    PageSize="@((int)_pageSize)"
                                    PageNumbersCount="5"
                                    PageChanged="@PageChanged"/>

                            </ChildContent>
                        </RadzenPanel>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6" SizeXL="4">
                        <RadzenStack orientation="Orientation.Vertical">
                            @if (_isLoading)
                            {
                                <RadzenImage
                                    Path=@(DefaultImages.ArtistBase64)
                                    Style="margin:auto;display: block;max-width: 450px;max-height: 450px;width: auto;height: auto;object-fit: contain;"
                                    AlternateText="@_artist.Name"/>
                            }
                            else if (_artistImagesInByteBase64.Length < 2)
                            {
                                <RadzenImage
                                    Path=@($"/images/{_artist.ToApiKey()}/{ImageSize.Medium}{(_showItem == ShowItem.Images ? $"?v={_imageCacheBuster}" : "")}")
                                    Style="margin:auto;display: block;max-width: 450px;max-height: 450px;width: auto;height: auto;object-fit: contain;"
                                    AlternateText="@_artist.Name"/>
                            }
                            else if (_artistImagesInByteBase64.Length > 1)
                            {
                                <RadzenCarousel
                                    Auto="false"
                                    Style="height: 450px; width: 450px;"
                                    class="rz-mx-auto"
                                    ButtonStyle="ButtonStyle.Base"
                                    ButtonSize="ButtonSize.Small"
                                    ButtonVariant="Variant.Text">
                                    <Items>
                                        @foreach (var image in _artistImagesInByteBase64)
                                        {
                                            <RadzenCarouselItem>
                                                <RadzenImage Path="@image" Style="width: 100%;height: 100%;object-fit: contain;"/>
                                            </RadzenCarouselItem>
                                        }
                                    </Items>
                                </RadzenCarousel>
                            }
                            <Markdown Content="@(_artist.Biography ?? _biographyNoAvailablePlaceholder)"/>
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>
            }
            else if (_showItem == ShowItem.Images)
            {
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                            <RadzenIcon Icon="image" class="rz-me-1"/>
                            @L("Nav.Images")
                        </RadzenText>
                    </HeaderTemplate>
                    <ChildContent>
                        <div @ref="_dropZoneElement" class="file-drop-zone">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                                <RadzenSwitch @bind-Value="@_replaceAllImages" Name="ReplaceAll"/>
                                <RadzenLabel Text="@L("ArtistDetail.ReplaceAllImages")" Component="ReplaceAll"/>
                                <InputFile @ref="_inputFileElement" multiple OnChange="@OnArtistImageUpload" />
                                <RadzenButton Icon="checklist" Size="ButtonSize.Small" Text="@L("Actions.SelectAll")" Click="@SelectAllImages"/>
                                <RadzenButton Icon="check_box_outline_blank" Size="ButtonSize.Small" Text="@L("Actions.SelectNone")" Click="@SelectNoneImages"/>
                                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Text="@L("Actions.DeleteSelected")"
                                              Disabled="@(!_selectedImagePaths.Any())"
                                              Visible="CurrentUser?.IsEditor() ?? false"
                                              Click="@DeleteSelectedArtistImagesButtonClick" />
                            </RadzenStack>
                            <RadzenText TextStyle="TextStyle.Caption" class="rz-text-secondary">@L("Message.DragAndDropImages")</RadzenText>
                        </div>
                        <RadzenDataList Data="@_artistImageList" TItem="ArtistImageListItem" class="rz-mt-3">
                            <Template Context="item">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenCheckBox TValue="bool" Value="@_selectedImagePaths.Contains(item.File.FullName)"
                                                    Change="@(args => ToggleImageSelected(item.File.FullName, args))"/>
                                    <RadzenImage Path="@item.ImageBase64" Style="width: 96px; height: 96px; object-fit:cover;"/>
                                    <RadzenText Text="@item.File.Name"/>
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => DeleteArtistImageAsync(item.File))" />
                                </RadzenStack>
                            </Template>
                        </RadzenDataList>
                    </ChildContent>
                </RadzenPanel>
            }
            else if (_showItem == ShowItem.Relationships)
            {
                <RadzenPanel>
                    <HeaderTemplate>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
                                <RadzenIcon Icon="partner_exchange" class="rz-me-1"/>
                                @L("Nav.Relationships")
                            </RadzenText>
                            <RadzenButton Icon="add" Text="@L("Actions.AddRelationship")" Size="ButtonSize.Small" Click="@AddRelationshipClick" Visible="CurrentUser?.IsEditor() ?? false"/>
                            <RadzenButton Icon="checklist" Size="ButtonSize.Small" Text="@L("Actions.SelectAll")" Click="@SelectAllRelationships"/>
                            <RadzenButton Icon="check_box_outline_blank" Size="ButtonSize.Small" Text="@L("Actions.SelectNone")" Click="@SelectNoneRelationships"/>
                            <RadzenButton Icon="delete" Text="@L("Actions.DeleteSelected")" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                          Visible="CurrentUser?.IsEditor() ?? false" Disabled="@(!_selectedRelationships.Any())"
                                          Click="@DeleteSelectedRelationshipsButtonClick"/>
                        </RadzenStack>
                    </HeaderTemplate>
                    <ChildContent>
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                            @if (_relationshipItems?.Count > 0)
                            {
                                @foreach (var item in _relationshipItems)
                                {
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <RadzenCheckBox TValue="bool" Value="@_selectedRelationships.Contains((item.OwnerArtistId, item.RelatedArtistId))"
                                                        Change="@(args => ToggleRelationshipSelected((item.OwnerArtistId, item.RelatedArtistId), args))"/>
                                        <ArtistDataInfoCardComponent Artist="@item.Artist.ToArtistDataInfo()"/>
                                        <RadzenBadge Text="@($"{item.RelationType} {(item.IsInbound ? "←" : "→")}")" Style="min-width: 120px; text-align:center;"/>
                                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Text="@L("Actions.Remove")"
                                                      Visible="CurrentUser?.IsEditor() ?? false"
                                                      Click="@(() => RemoveRelationshipAsync(item.OwnerArtistId, item.RelatedArtistId))" />
                                    </RadzenStack>
                                }
                            }
                        </RadzenStack>
                    </ChildContent>
                </RadzenPanel>
            }
        </RadzenColumn>
    </RadzenRow>
</RadzenStack>


@code {

    int _totalAlbumCount;

    [Parameter] public Guid ApiKey { get; set; }

    /// <summary>
    ///     When this is set, is it used if the artist gets deleted to return the user back (like viewing artist for a library
    ///     return to the library detail)
    /// </summary>
    [Parameter]
    public string? FromUrl { get; set; }

    Artist _artist = new()
    {
        Library = new Library
        {
            Name = string.Empty,
            Path = string.Empty,
            Type = 0,
            CreatedAt = default
        },
        Name = string.Empty,
        NameNormalized = string.Empty,
        Directory = string.Empty,
        LibraryId = 0,
        CreatedAt = default
    };

    string[] _artistImagesInByteBase64 = [];
    System.IO.FileInfo[] _artistImageFiles = [];
    class ArtistImageListItem { public required System.IO.FileInfo File { get; init; } public required string ImageBase64 { get; init; } }
    List<ArtistImageListItem> _artistImageList = [];
    HashSet<string> _selectedImagePaths = [];
    long _imageCacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    string? _biographyNoAvailablePlaceholder = string.Empty;

    ShowItem _showItem = ShowItem.Overview;
    bool _replaceAllImages;
    Artist[] _relatedArtists = [];
    class RelationshipItem
    {
        public required Artist Artist { get; init; } // The other artist to display
        public required ArtistRelationType RelationType { get; init; }
        public required int OwnerArtistId { get; init; } // Relation's ArtistId
        public required int RelatedArtistId { get; init; } // Relation's RelatedArtistId
        public required bool IsInbound { get; init; } // True if points to current artist
    }
    List<RelationshipItem> _relationshipItems = [];
    HashSet<(int OwnerArtistId, int RelatedArtistId)> _selectedRelationships = [];
    int _relationshipCount = 0;

    bool _isPinned;

    IEnumerable<AlbumDataInfo> _albums = [];

    readonly IList<AlbumDataInfo> _selectedAlbums = [];

    AlbumSort _albumSort = AlbumSort.ReleaseDateDesc;

    private enum AlbumSort
    {
        ReleaseDate = 1,
        ReleaseDateDesc,
        Duration,
        DurationDesc,
        SongCount,
        SongCountDesc
    }

    private enum ShowItem
    {
        Overview = 1,
        Images,
        Relationships
    }

    UserArtist _userArtist = new()
    {
        UserId = 0,
        ArtistId = 0,
        CreatedAt = default
    };

    bool _isLoading = true;
    int? _currentPage = 1;
    readonly short _pageSize = 50;
    private long _maxUploadSize;
    private ElementReference _dropZoneElement;
    private InputFile? _inputFileElement;
    private IJSObjectReference? _dropZoneModule;

    private readonly List<string> _alertMessages = [];
    private string _debounceAlbumFilterValue = string.Empty;

    async Task PageChanged(PagerEventArgs args)
    {
        _currentPage = args.PageIndex + 1;
        await LoadAlbums();
    }

    private async Task LoadAlbums()
    {
        _isLoading = true;

        Dictionary<string, string> orderBy;
        switch (_albumSort)
        {
            case AlbumSort.Duration:
            case AlbumSort.DurationDesc:
                orderBy = new Dictionary<string, string>
                {
                    { nameof(AlbumDataInfo.Duration), _albumSort == AlbumSort.Duration ? PagedRequest.OrderAscDirection : PagedRequest.OrderDescDirection }
                };
                break;

            case AlbumSort.SongCount:
            case AlbumSort.SongCountDesc:
                orderBy = new Dictionary<string, string>
                {
                    { nameof(AlbumDataInfo.SongCount), _albumSort == AlbumSort.SongCount ? PagedRequest.OrderAscDirection : PagedRequest.OrderDescDirection }
                };
                break;

            default:
                orderBy = new Dictionary<string, string>
                {
                    { nameof(AlbumDataInfo.ReleaseDate), _albumSort == AlbumSort.ReleaseDate ? PagedRequest.OrderAscDirection : PagedRequest.OrderDescDirection }
                };
                break;
        }

        FilterOperatorInfo[]? filters = null;
        if (_debounceAlbumFilterValue.Nullify() != null)
        {
            filters =
            [
              new FilterOperatorInfo(nameof(AlbumDataInfo.Name), FilterOperator.Contains, _debounceAlbumFilterValue)
            ];
        }

        var albumListResult = await AlbumService.ListForArtistApiKeyAsync(new PagedRequest
        {
            FilterBy = filters,
            Page = _currentPage,
            PageSize = _pageSize,
            OrderBy = orderBy
        }, _artist.ApiKey);

