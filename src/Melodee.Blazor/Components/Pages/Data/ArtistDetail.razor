    private async Task RefreshRelationshipsAsync()
    {
        var outbound = await ArtistService.ListArtistRelationsAsync(_artist.Id, ArtistRelationType.NotSet, 100);
        var inbound = await ArtistService.ListArtistRelationsInboundAsync(_artist.Id, ArtistRelationType.NotSet, 100);

        var items = new List<RelationshipItem>();
        if (outbound.Data?.Length > 0)
        {
            items.AddRange(outbound.Data.Select(r => new RelationshipItem
            {
                Artist = r.RelatedArtist,
                RelationType = (ArtistRelationType)r.ArtistRelationType,
                OwnerArtistId = r.ArtistId,
                RelatedArtistId = r.RelatedArtistId,
                IsInbound = false
            }));
        }
        if (inbound.Data?.Length > 0)
        {
            items.AddRange(inbound.Data.Select(r => new RelationshipItem
            {
                Artist = r.Artist,
                RelationType = (ArtistRelationType)r.ArtistRelationType,
                OwnerArtistId = r.ArtistId,
                RelatedArtistId = r.RelatedArtistId,
                IsInbound = true
            }));
        }

        _relationshipItems = items
            .OrderBy(x => x.Artist.SortName ?? x.Artist.Name)
            .ToList();
        _relatedArtists = _relationshipItems.Select(x => x.Artist).ToArray();

        var outCountTask = ArtistService.CountArtistRelationsAsync(_artist.Id);
        var inCountTask = ArtistService.CountArtistRelationsInboundAsync(_artist.Id);
        await Task.WhenAll(outCountTask, inCountTask);
        _relationshipCount = (outCountTask.Result.Data) + (inCountTask.Result.Data);

        var validPairs = _relationshipItems.Select(i => (i.OwnerArtistId, i.RelatedArtistId)).ToHashSet();
        _selectedRelationships.RemoveWhere(pair => !validPairs.Contains(pair));
        StateHasChanged();
    }

