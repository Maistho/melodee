@page "/requests/new"

@inherits MelodeeComponentBase
@using Request = Melodee.Common.Data.Models.Request

@inject MainLayoutProxyService MainLayoutProxyService
@inject ILogger Logger
@inject RequestService RequestService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

<PageTitle>@L("RequestNew.PageTitle")</PageTitle>

<RadzenStack Style="height: 100%; overflow-y: auto;" Gap="1rem">
    <RadzenBreadCrumb Class="rz-pb-3">
        <RadzenBreadCrumbItem Path="/" Text="@L("Navigation.Dashboard")"/>
        <RadzenBreadCrumbItem Path="/requests" Icon="assignment" Text="@L("Navigation.Requests")"/>
        <RadzenBreadCrumbItem Text="@L("RequestNew.NewRequest")"/>
    </RadzenBreadCrumb>

    <RadzenCard>
        <RadzenText TextStyle="TextStyle.H5" Text="@L("RequestNew.CreateNewRequest")" Class="rz-mb-4"/>

        <RadzenTemplateForm TItem="RequestModel" Data="@_model" Submit="@OnSubmit">
            <RadzenStack Gap="1rem">
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="@L("Label.Category")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenDropDown @bind-Value="@_model.Category"
                                            Data="@_categoryOptions"
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            Style="width: 100%"
                                            Name="Category"/>
                        </RadzenFormField>
                        <RadzenRequiredValidator Component="Category" Text="@L("RequestNew.CategoryRequired")"/>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow>
                    <RadzenColumn Size="12">
                        <RadzenFormField Text="@L("Common.Description")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenTextArea @bind-Value="@_model.Description" Rows="4" Style="width: 100%" Name="Description"/>
                        </RadzenFormField>
                        <RadzenRequiredValidator Component="Description" Text="@L("RequestNew.DescriptionRequired")"/>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenText TextStyle="TextStyle.Subtitle1" Text="@L("Label.OptionalDetails")" Class="rz-mt-2"/>

                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="@L("Label.ArtistName")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenTextBox @bind-Value="@_model.ArtistName" Style="width: 100%"/>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="@L("Label.AlbumTitle")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenTextBox @bind-Value="@_model.AlbumTitle" Style="width: 100%"/>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="@L("Label.SongTitle")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenTextBox @bind-Value="@_model.SongTitle" Style="width: 100%"/>
                        </RadzenFormField>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFormField Text="@L("Label.ReleaseYear")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenNumeric @bind-Value="@_model.ReleaseYear" Style="width: 100%" Min="1900" Max="2100"/>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12">
                        <RadzenFormField Text="@L("Label.ExternalURL")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenTextBox @bind-Value="@_model.ExternalUrl" Style="width: 100%" Placeholder="https://..."/>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow>
                    <RadzenColumn Size="12">
                        <RadzenFormField Text="@L("Label.AdditionalNotes")" Variant="Variant.Outlined" Style="width: 100%">
                            <RadzenTextArea @bind-Value="@_model.Notes" Rows="3" Style="width: 100%"/>
                        </RadzenFormField>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow JustifyContent="JustifyContent.End" Gap="0.5rem" Class="rz-mt-4">
                    <RadzenButton Text="@L("Actions.Cancel")" ButtonStyle="ButtonStyle.Light" Click="@Cancel"/>
                    <RadzenButton Text="@L("Actions.CreateRequest")" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" Icon="add"/>
                </RadzenRow>
            </RadzenStack>
        </RadzenTemplateForm>
    </RadzenCard>
</RadzenStack>

@code {
    [SupplyParameterFromQuery(Name = "category")]
    public int? InitialCategoryInt { get; set; }

    [SupplyParameterFromQuery(Name = "targetArtistApiKey")]
    public Guid? TargetArtistApiKey { get; set; }

    [SupplyParameterFromQuery(Name = "artistName")]
    public string? InitialArtistName { get; set; }

    [SupplyParameterFromQuery(Name = "targetAlbumApiKey")]
    public Guid? TargetAlbumApiKey { get; set; }

    [SupplyParameterFromQuery(Name = "albumTitle")]
    public string? InitialAlbumTitle { get; set; }

    [SupplyParameterFromQuery(Name = "songTitle")]
    public string? InitialSongTitle { get; set; }

    [SupplyParameterFromQuery(Name = "releaseYear")]
    public int? InitialReleaseYear { get; set; }

    [SupplyParameterFromQuery(Name = "fromUrl")]
    public string? InitialExternalUrl { get; set; }

    [SupplyParameterFromQuery(Name = "notes")]
    public string? InitialNotes { get; set; }

    RequestModel _model = new();

    readonly List<object> _categoryOptions =
    [
        new { Text = "Add Album", Value = RequestCategory.AddAlbum },
        new { Text = "Add Song", Value = RequestCategory.AddSong },
        new { Text = "Artist Correction", Value = RequestCategory.ArtistCorrection },
        new { Text = "Album Correction", Value = RequestCategory.AlbumCorrection },
        new { Text = "General", Value = RequestCategory.General }
    ];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        RequestCategory? initialCategory = null;
        if (InitialCategoryInt.HasValue && Enum.IsDefined(typeof(RequestCategory), InitialCategoryInt.Value))
        {
            initialCategory = (RequestCategory)InitialCategoryInt.Value;
        }

        _model = new RequestModel
        {
            Category = initialCategory ?? RequestCategory.AddAlbum,
            ArtistName = InitialArtistName,
            AlbumTitle = InitialAlbumTitle,
            SongTitle = InitialSongTitle,
            ReleaseYear = InitialReleaseYear,
            ExternalUrl = InitialExternalUrl,
            TargetArtistApiKey = TargetArtistApiKey,
            TargetAlbumApiKey = TargetAlbumApiKey,
            Notes = InitialNotes
        };
    }

    async Task OnSubmit()
    {
        if (_model.Category == RequestCategory.NotSet)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("RequestNew.PleaseSelectCategory")
            });
            return;
        }

        if (string.IsNullOrWhiteSpace(_model.Description))
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("RequestNew.DescriptionRequired")
            });
            return;
        }

        MainLayoutProxyService.ToggleSpinnerVisible();
        try
        {
            var request = new Request
            {
                Category = (int)_model.Category,
                Description = _model.Description,
                ArtistName = _model.ArtistName,
                TargetArtistApiKey = _model.TargetArtistApiKey,
                AlbumTitle = _model.AlbumTitle,
                TargetAlbumApiKey = _model.TargetAlbumApiKey,
                SongTitle = _model.SongTitle,
                ReleaseYear = _model.ReleaseYear,
                ExternalUrl = _model.ExternalUrl,
                Notes = _model.Notes
            };

            var result = await RequestService.CreateAsync(request, CurrentUsersId);
            if (result.IsSuccess && result.Data != null)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = L("RequestNew.RequestCreated")
                });
                NavigationManager.NavigateTo($"/requests/{result.Data.ApiKey}");
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = L("RequestNew.ErrorCreatingRequest"),
                    Detail = result.Messages?.FirstOrDefault()
                });
            }
        }
        catch (Exception e)
        {
            Logger.Error(e, "Creating Request");
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("RequestNew.ErrorCreatingRequest")
            });
        }
        finally
        {
            MainLayoutProxyService.ToggleSpinnerVisible();
        }
    }

    void Cancel()
    {
        NavigationManager.NavigateTo("/requests");
    }

    class RequestModel
    {
        public RequestCategory Category { get; set; } = RequestCategory.AddAlbum;
        public string Description { get; set; } = "";
        public string? ArtistName { get; set; }
        public Guid? TargetArtistApiKey { get; init; }
        public string? AlbumTitle { get; set; }
        public Guid? TargetAlbumApiKey { get; init; }
        public string? SongTitle { get; set; }
        public int? ReleaseYear { get; set; }
        public string? ExternalUrl { get; set; }
        public string? Notes { get; set; }
    }
}
