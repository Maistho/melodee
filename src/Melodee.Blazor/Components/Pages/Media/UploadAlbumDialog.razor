@inherits MelodeeComponentBase
@using System.IO.Compression
@using Melodee.Common.Constants
@using Melodee.Common.Extensions
@using Melodee.Common.Enums
@using Melodee.Common.Jobs
@using Quartz

@inject DialogService DialogService
@inject NotificationService NotificationService
@inject LibraryService LibraryService
@inject ISchedulerFactory SchedulerFactory
@inject ILogger Logger
@inject IJSRuntime JS

<RadzenStack Gap="1rem">
    <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false">
        <RadzenText TextStyle="TextStyle.Body2">@L("UploadAlbum.Instructions")</RadzenText>
    </RadzenAlert>

    <RadzenFormField Text="@L("UploadAlbum.SelectFile")" Variant="Variant.Outlined" Style="width: 100%;">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
            <InputFile OnChange="@OnFilesSelected" accept=".zip" multiple style="display: none;" id="zipFileInput" />
            <RadzenButton Text="@L("UploadAlbum.Browse")" Icon="folder_open" ButtonStyle="ButtonStyle.Secondary" Click="@TriggerFileInput" Disabled="@_isProcessing" />
            <RadzenText TextStyle="TextStyle.Body2" Style="flex: 1;">
                @if (_selectedFiles.Count == 0)
                {
                    @L("UploadAlbum.NoFileSelected")
                }
                else if (_selectedFiles.Count == 1)
                {
                    @_selectedFiles[0].Name
                }
                else
                {
                    @($"{_selectedFiles.Count} {L("UploadAlbum.FilesSelected")}")
                }
            </RadzenText>
            @if (_selectedFiles.Count > 0)
            {
                <RadzenBadge Text="@_totalSize.FormatFileSize()" BadgeStyle="BadgeStyle.Info" />
            }
        </RadzenStack>
    </RadzenFormField>

    @if (_selectedFiles.Count > 1)
    {
        <RadzenCard Variant="Variant.Outlined">
            <RadzenText TextStyle="TextStyle.Subtitle2">@L("UploadAlbum.SelectedFiles")</RadzenText>
            <RadzenStack Gap="0.25rem" Style="max-height: 150px; overflow-y: auto;">
                @foreach (var file in _selectedFiles)
                {
                    <RadzenText TextStyle="TextStyle.Body2">• @file.Name (@file.Size.FormatFileSize())</RadzenText>
                }
            </RadzenStack>
        </RadzenCard>
    }

    @if (_isProcessing)
    {
        <RadzenCard Variant="Variant.Outlined">
            <RadzenStack Gap="0.5rem">
                <RadzenText TextStyle="TextStyle.Subtitle2">@_statusMessage</RadzenText>
                @if (_selectedFiles.Count > 1)
                {
                    <RadzenText TextStyle="TextStyle.Body2">
                        @L("UploadAlbum.ProcessingFile") @_currentFileIndex / @_selectedFiles.Count
                    </RadzenText>
                }
                <RadzenProgressBar Value="@_progress" ShowValue="true" Style="height: 24px;" />
            </RadzenStack>
        </RadzenCard>
    }

    @if (_isComplete && _results.Count > 0)
    {
        <RadzenCard Variant="Variant.Outlined">
            <RadzenText TextStyle="TextStyle.Subtitle2">
                @L("UploadAlbum.UploadResults"): @_results.Count(r => r.Success) / @_results.Count @L("UploadAlbum.Successful")
            </RadzenText>
            <RadzenStack Gap="0.5rem" Style="max-height: 200px; overflow-y: auto;" Class="rz-mt-2">
                @foreach (var result in _results)
                {
                    <RadzenAlert AlertStyle="@(result.Success ? AlertStyle.Success : AlertStyle.Danger)" 
                                 Shade="Shade.Lighter" AllowClose="false" Size="AlertSize.Small">
                        @if (result.Success)
                        {
                            <RadzenText TextStyle="TextStyle.Body2">
                                ✓ <strong>@result.FileName:</strong> @result.FolderName 
                                (@result.FileCount @L("UploadAlbum.Files"), @result.DirectoryCount @L("UploadAlbum.Directories"))
                            </RadzenText>
                        }
                        else
                        {
                            <RadzenText TextStyle="TextStyle.Body2">
                                ✗ <strong>@result.FileName:</strong> @result.ErrorMessage
                            </RadzenText>
                        }
                    </RadzenAlert>
                }
            </RadzenStack>
        </RadzenCard>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="@L("Actions.Cancel")" ButtonStyle="ButtonStyle.Light" Click="@Cancel" Disabled="@_isProcessing" />
        <RadzenButton Text="@L("Actions.Upload")" Icon="cloud_upload" ButtonStyle="ButtonStyle.Primary" Click="@ProcessUpload" Disabled="@(_selectedFiles.Count == 0 || _isProcessing)" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public Guid LibraryApiKey { get; set; }

    List<IBrowserFile> _selectedFiles = new();
    bool _isProcessing;
    bool _isComplete;
    double _progress;
    string _statusMessage = string.Empty;
    List<UploadResultInfo> _results = new();
    long _totalSize;
    int _currentFileIndex;

    async Task TriggerFileInput()
    {
        await JS.InvokeVoidAsync("eval", "document.getElementById('zipFileInput').click()");
    }

    void OnFilesSelected(InputFileChangeEventArgs e)
    {
        _selectedFiles = e.GetMultipleFiles(100).ToList(); // Allow up to 100 files
        _totalSize = _selectedFiles.Sum(f => f.Size);
        _isComplete = false;
        _results.Clear();
        StateHasChanged();
    }

    async Task ProcessUpload()
    {
        if (_selectedFiles.Count == 0) return;

        _isProcessing = true;
        _isComplete = false;
        _progress = 0;
        _results.Clear();
        _currentFileIndex = 0;
        _statusMessage = L("UploadAlbum.PreparingUpload");
        StateHasChanged();

        try
        {
            var libraryResult = await LibraryService.GetByApiKeyAsync(LibraryApiKey);
            if (!libraryResult.IsSuccess || libraryResult.Data == null)
            {
                _results.Add(new UploadResultInfo(false, "N/A", null, 0, 0, "Library not found."));
                return;
            }

            var library = libraryResult.Data;
            if (library.TypeValue != LibraryType.Inbound)
            {
                _results.Add(new UploadResultInfo(false, "N/A", null, 0, 0, "Uploads are only allowed to Inbound libraries."));
                return;
            }

            if (library.IsLocked)
            {
                _results.Add(new UploadResultInfo(false, "N/A", null, 0, 0, "Library is locked."));
                return;
            }

            // Process each file
            for (int i = 0; i < _selectedFiles.Count; i++)
            {
                _currentFileIndex = i + 1;
                var selectedFile = _selectedFiles[i];
                
                var fileProgress = (double)i / _selectedFiles.Count * 100;
                _progress = fileProgress;
                _statusMessage = $"{L("UploadAlbum.Processing")} {selectedFile.Name}";
                await InvokeAsync(StateHasChanged);

                try
                {
                    var folderName = Path.GetFileNameWithoutExtension(selectedFile.Name).ToDirectoryNameFriendly();
                    if (string.IsNullOrWhiteSpace(folderName))
                    {
                        folderName = $"upload_{DateTime.UtcNow:yyyyMMdd_HHmmss}";
                    }

                    var extractPath = Path.Combine(library.Path, folderName);
                    var counter = 1;
                    var originalExtractPath = extractPath;
                    while (Directory.Exists(extractPath))
                    {
                        extractPath = $"{originalExtractPath}_{counter++}";
                        folderName = Path.GetFileName(extractPath);
                    }

                    Directory.CreateDirectory(extractPath);

                    var tempZipPath = Path.GetTempFileName();
                    try
                    {
                        var maxAllowedSize = 500L * 1024 * 1024;
                        await using (var fileStream = new FileStream(tempZipPath, FileMode.Create))
                        {
                            await selectedFile.OpenReadStream(maxAllowedSize).CopyToAsync(fileStream);
                        }

                        _statusMessage = $"{L("UploadAlbum.Extracting")} {selectedFile.Name}";
                        await InvokeAsync(StateHasChanged);

                        ZipFile.ExtractToDirectory(tempZipPath, extractPath, overwriteFiles: true);

                        var extractedFiles = Directory.GetFiles(extractPath, "*", SearchOption.AllDirectories);
                        var extractedDirs = Directory.GetDirectories(extractPath, "*", SearchOption.AllDirectories);

                        Logger.Information(
                            "Uploaded and extracted [{FileName}] to [{Path}]. Files: {FileCount}, Directories: {DirCount}",
                            selectedFile.Name,
                            extractPath,
                            extractedFiles.Length,
                            extractedDirs.Length);

                        _results.Add(new UploadResultInfo(true, selectedFile.Name, folderName, extractedFiles.Length, extractedDirs.Length, null));
                    }
                    finally
                    {
                        if (File.Exists(tempZipPath))
                        {
                            File.Delete(tempZipPath);
                        }
                    }
                }
                catch (InvalidDataException ex)
                {
                    Logger.Warning(ex, "Invalid ZIP file uploaded: {FileName}", selectedFile.Name);
                    _results.Add(new UploadResultInfo(false, selectedFile.Name, null, 0, 0, L("UploadAlbum.InvalidZip")));
                }
                catch (Exception ex)
                {
                    Logger.Error(ex, "Error processing upload: {FileName}", selectedFile.Name);
                    _results.Add(new UploadResultInfo(false, selectedFile.Name, null, 0, 0, ex.Message));
                }
            }

            _progress = 100;
            _statusMessage = L("UploadAlbum.Complete");
            await InvokeAsync(StateHasChanged);
            
            // Trigger the inbound processing pipeline to automatically process the uploaded albums
            if (_results.Any(r => r.Success))
            {
                await TriggerInboundProcessingAsync();
            }
            
            // Close dialog on success - parent will show toast notification
            if (_results.All(r => r.Success))
            {
                DialogService.Close(true);
            }
        }
        finally
        {
            _isProcessing = false;
            _isComplete = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    async Task TriggerInboundProcessingAsync()
    {
        try
        {
            var scheduler = await SchedulerFactory.GetScheduler();
            var jobExists = await scheduler.CheckExists(JobKeyRegistry.LibraryInboundProcessJobKey);
            
            if (jobExists)
            {
                var jobDataMap = new JobDataMap
                {
                    { MelodeeJobExecutionContext.ChainOnComplete, true }
                };
                
                Logger.Information("Triggering inbound processing pipeline after upload with job chaining enabled");
                await scheduler.TriggerJob(JobKeyRegistry.LibraryInboundProcessJobKey, jobDataMap);
            }
            else
            {
                Logger.Warning("LibraryInboundProcessJob is not scheduled, cannot trigger processing pipeline");
            }
        }
        catch (Exception ex)
        {
            Logger.Warning(ex, "Failed to trigger inbound processing pipeline after upload");
        }
    }

    void Cancel()
    {
        DialogService.Close(_results.Any(r => r.Success));
    }

    sealed record UploadResultInfo(bool Success, string FileName, string? FolderName, int FileCount, int DirectoryCount, string? ErrorMessage);
}
