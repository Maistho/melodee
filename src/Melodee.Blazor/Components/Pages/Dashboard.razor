@page "/"

@using Melodee.Blazor.Security.Extensions
@using Melodee.Common.Data.Models
@using Melodee.Common.Enums
@using Melodee.Common.Models
@using Melodee.Common.Models.Collection
@using Melodee.Common.Models.Collection.Extensions
@using NodaTime
@using TextStyle = Radzen.Blazor.TextStyle
@using Request = Melodee.Common.Data.Models.Request
@inherits MelodeeComponentBase

@inject UserService UserService
@inject ArtistService ArtistService
@inject AlbumService AlbumService
@inject StatisticsService StatisticsService
@inject RequestActivityService RequestActivityService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject NavigationManager NavigationManager
@inject IDoctorService DoctorService

<PageTitle>@L("Navigation.Dashboard")</PageTitle>


<RadzenStack Gap="1rem">

  @* Admin Health Warning Banner *@
  @if (_showHealthWarning && CurrentUser?.IsAdmin() == true)
  {
    <RadzenCard class="rz-background-color-danger-lighter" Style="cursor: pointer;" @onclick="@(() => NavigationManager.NavigateTo("/admin/doctor"))">
      <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
        <RadzenIcon Icon="health_and_safety" Style="font-size: 2rem; color: var(--rz-danger);"/>
        <RadzenStack Gap="0" Style="flex: 1;">
          <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-danger-darker); margin: 0;">
            @L("Dashboard.IssuesDetected")
          </RadzenText>
        </RadzenStack>
        <RadzenIcon Icon="arrow_forward" Style="font-size: 1.5rem; color: var(--rz-danger);"/>
      </RadzenStack>
    </RadzenCard>
  }

  @if (_userPins.Length > 0)
  {
    <RadzenRow>
    <RadzenPanel AllowCollapse="true">
      <HeaderTemplate>
        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
          <RadzenIcon Icon="push_pin" class="rz-me-1"/>
          @L("Dashboard.YourPins")
        </RadzenText>
      </HeaderTemplate>
      <ChildContent>
        <RadzenStack
          Orientation="Orientation.Horizontal"
          Wrap="FlexWrap.Wrap"
          JustifyContent="JustifyContent.Left"
          class="rz-p-2"
          Gap="8px">
          @foreach (var pin in _userPins)
          {
            <UserPinCardComponent UserPin="@pin"/>
          }
        </RadzenStack>
      </ChildContent>
    </RadzenPanel>
    </RadzenRow>
  }

  <RadzenRow>
    @foreach (var kpi in _userKpis)
    {
      <RadzenColumn Size="6" SizeSM="4" SizeMD="3" SizeLG="2">
        <RadzenCard>
          <RadzenStack Gap="0.25rem">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
              <RadzenIcon Icon="@kpi.Icon" Style="font-size: 1.25rem; opacity: 0.7;"/>
              <RadzenText TextStyle="TextStyle.Overline" Style="margin: 0;">@LocalizeStatisticTitle(kpi.Title)</RadzenText>
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.H5" Style="margin: 0;">@kpi.Data</RadzenText>
          </RadzenStack>
        </RadzenCard>
      </RadzenColumn>
    }
  </RadzenRow>

  <RadzenRow>
    <RadzenColumn Size="12" SizeMD="6">
      <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6">@L("Dashboard.YourPlaysLast30Days")</RadzenText>
        <RadzenChart Style="height: 200px;">
          <RadzenLineSeries Data="@_playsPerDay" CategoryProperty="DayAsDateTime" ValueProperty="Value" Title="@L("Dashboard.Plays")" Smooth="true">
            <RadzenCategoryAxis Step="@TimeSpan.FromDays(7)" FormatString="{0:MM/dd}">
              <RadzenAxisTitle Text="@L("Dashboard.Date")"/>
            </RadzenCategoryAxis>
            <RadzenValueAxis>
              <RadzenAxisTitle Text="@L("Dashboard.Plays")"/>
            </RadzenValueAxis>
          </RadzenLineSeries>
        </RadzenChart>
      </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="6">
      <RadzenCard>
        <RadzenText TextStyle="TextStyle.H6">@L("Dashboard.TopPlayedSongsLast30Days")</RadzenText>
        @if (_topSongs.Length > 0)
        {
          <RadzenDataGrid TItem="TopItemStat"
                          Data="@_topSongs"
                          AllowPaging="false"
                          AllowSorting="false"
                          AllowFiltering="false"
                          Density="Density.Compact"
                          Style="max-height: 200px; overflow-y: auto;"
                          RowClick="@OnTopSongRowClick">
            <Columns>
              <RadzenDataGridColumn TItem="TopItemStat" Property="Label" Title="@L("Common.Song")" Width="70%">
                <Template Context="song">
                  <span style="cursor: pointer;">@song.Label</span>
                </Template>
              </RadzenDataGridColumn>
              <RadzenDataGridColumn TItem="TopItemStat" Property="Value" Title="@L("Dashboard.Plays")" Width="30%" TextAlign="TextAlign.Right"/>
            </Columns>
          </RadzenDataGrid>
        }
        else
        {
          <RadzenText TextStyle="TextStyle.Body2" Style="opacity: 0.7; padding: 1rem;">@L("Dashboard.NoPlayHistoryYet")</RadzenText>
        }
      </RadzenCard>
    </RadzenColumn>
  </RadzenRow>

  @if (_recentlyPlayed.Length > 0)
  {
    <RadzenPanel AllowCollapse="true">
      <HeaderTemplate>
        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
          <RadzenIcon Icon="history" class="rz-me-1"/>
          @L("Dashboard.RecentlyPlayed")
        </RadzenText>
      </HeaderTemplate>
      <ChildContent>
        <RadzenStack
          Orientation="Orientation.Horizontal"
          Wrap="FlexWrap.Wrap"
          JustifyContent="JustifyContent.Left"
          class="rz-p-2"
          Gap="8px">
          @foreach (var song in _recentlyPlayedSongs)
          {
            <SongDataInfoCardComponent Song="@song" Style="width: 280px;"/>
          }
        </RadzenStack>
      </ChildContent>
    </RadzenPanel>
  }

  @if (_unreadRequests.Length > 0)
  {
    <RadzenPanel AllowCollapse="true">
      <HeaderTemplate>
        <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-align-items-center rz-m-0">
          <RadzenIcon Icon="assignment" class="rz-me-1"/>
          @L("Dashboard.RequestActivity")
          <RadzenBadge BadgeStyle="BadgeStyle.Danger" IsPill="true" Text="@_unreadRequests.Length.ToString()" Class="rz-ms-2"/>
        </RadzenText>
      </HeaderTemplate>
      <ChildContent>
        <RadzenDataGrid TItem="Request"
                        Data="@_unreadRequests"
                        AllowPaging="false"
                        AllowSorting="false"
                        AllowFiltering="false"
                        Density="Density.Compact"
                        Style="max-height: 300px; overflow-y: auto;"
                        RowClick="@OnRequestRowClick">
          <Columns>
            <RadzenDataGridColumn TItem="Request" Property="CategoryValue" Title="@L("Dashboard.Category")" Width="120px">
              <Template Context="req">
                <RadzenBadge IsPill="true" BadgeStyle="@GetCategoryBadgeStyle(req.CategoryValue)" Text="@req.CategoryValue.ToString()"/>
              </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Request" Property="Description" Title="@L("Dashboard.Description")">
              <Template Context="req">
                <span style="cursor: pointer;">@(req.Description.Length > 80 ? req.Description[..80] + "..." : req.Description)</span>
              </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Request" Property="LastActivityTypeValue" Title="@L("Dashboard.Activity")" Width="120px">
              <Template Context="req">
                <RadzenText Text="@req.LastActivityTypeValue.ToString()"/>
              </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Request" Property="LastActivityAt" Title="@L("Dashboard.When")" Width="150px">
              <Template Context="req">
                <RadzenText Text="@CurrentUser?.FormatInstant(req.LastActivityAt)"/>
              </Template>
            </RadzenDataGridColumn>
          </Columns>
        </RadzenDataGrid>
      </ChildContent>
    </RadzenPanel>
  }

  <RadzenPanel AllowCollapse="true">
    <HeaderTemplate>
      <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-m-0">
        <RadzenIcon Icon="person" class="rz-me-1"/>
        @L("Dashboard.RecentlyAddedArtists")
      </RadzenText>
    </HeaderTemplate>
    <ChildContent>
      @if (_latestArtists.Length > 0)
      {
        <RadzenStack
          Orientation="Orientation.Horizontal"
          Wrap="FlexWrap.Wrap"
          JustifyContent="JustifyContent.Left"
          class="rz-p-1"
          Gap="10px">
          @foreach (var artist in _latestArtists)
          {
            <ArtistDataInfoCardComponent Artist="@artist"/>
          }
        </RadzenStack>
      }
      else
      {
        <RadzenText TextStyle="TextStyle.Body2" Style="opacity: 0.7; padding: 1rem;">@L("Dashboard.NoArtistsFound")</RadzenText>
      }
    </ChildContent>
  </RadzenPanel>
  <RadzenPanel AllowCollapse="true">
    <HeaderTemplate>
      <RadzenText TextStyle="TextStyle.H6" class="rz-display-flex rz-m-0">
        <RadzenIcon Icon="album" class="rz-me-1"/>
        @L("Dashboard.RecentlyAddedAlbums")
      </RadzenText>
    </HeaderTemplate>
    <ChildContent>
      @if (_latestAlbums.Length > 0)
      {
        <RadzenStack
          Orientation="Orientation.Horizontal"
          Wrap="FlexWrap.Wrap"
          JustifyContent="JustifyContent.Left"
          class="rz-p-1"
          Gap="10px">
          @foreach (var album in _latestAlbums)
          {
            <AlbumDataInfoCardComponent Album="@album"/>
          }
        </RadzenStack>
      }
      else
      {
        <RadzenText TextStyle="TextStyle.Body2" Style="opacity: 0.7; padding: 1rem;">@L("Dashboard.NoAlbumsFound")</RadzenText>
      }
    </ChildContent>
  </RadzenPanel>
</RadzenStack>

@code {

    private AlbumDataInfo[] _latestAlbums = [];
    private ArtistDataInfo[] _latestArtists = [];
    private UserPin[] _userPins = [];
    private Statistic[] _userKpis = [];
    private TimeSeriesPoint[] _playsPerDay = [];
    private TopItemStat[] _topSongs = [];
    private TopItemStat[] _recentlyPlayed = [];
    private SongDataInfo[] _recentlyPlayedSongs = [];
    private Request[] _unreadRequests = [];
    private bool _showHealthWarning;

    private short _latestPageSize;
    private LocalDate _rangeStart;
    private LocalDate _rangeEnd;
    private string _timeZoneId = "UTC";

    void OnTopSongRowClick(DataGridRowMouseEventArgs<TopItemStat> args)
    {
        if (!string.IsNullOrWhiteSpace(args.Data.Extra) && Guid.TryParse(args.Data.Extra, out var albumApiKey))
        {
            NavigationManager.NavigateTo($"/data/album/{albumApiKey}");
        }
    }

    void OnRequestRowClick(DataGridRowMouseEventArgs<Request> args)
    {
        NavigationManager.NavigateTo($"/requests/{args.Data.ApiKey}");
    }

    static BadgeStyle GetCategoryBadgeStyle(RequestCategory category) => category switch
    {
        RequestCategory.AddAlbum => BadgeStyle.Primary,
        RequestCategory.AddSong => BadgeStyle.Secondary,
        RequestCategory.ArtistCorrection => BadgeStyle.Info,
        RequestCategory.AlbumCorrection => BadgeStyle.Info,
        RequestCategory.General => BadgeStyle.Light,
        _ => BadgeStyle.Light
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        var configuration = await ConfigurationFactory.GetConfigurationAsync();
        _latestPageSize = configuration.GetValue<short?>(SettingRegistry.DefaultsDashboardLatestPageSize) ?? configuration.GetValue<short?>(SettingRegistry.DefaultsPageSize) ?? 50;

        _timeZoneId = CurrentUser?.TimeZoneId() ?? "UTC";
        var zone = DateTimeZoneProviders.Tzdb.GetZoneOrNull(_timeZoneId) ?? DateTimeZone.Utc;
        var today = SystemClock.Instance.GetCurrentInstant().InZone(zone).Date;
        _rangeEnd = today;
        _rangeStart = today.PlusDays(-29);

        var userApiKey = CurrentUser?.ToApiGuid() ?? Guid.Empty;

        var albumLatestTask = AlbumService.ListAsync(new PagedRequest
        {
            PageSize = _latestPageSize,
            OrderBy = new Dictionary<string, string>
            {
                { nameof(AlbumDataInfo.CreatedAt), PagedRequest.OrderDescDirection }
            }
        });

        var artistLatestTask = ArtistService.ListAsync(new PagedRequest
        {
            PageSize = _latestPageSize,
            OrderBy = new Dictionary<string, string>
            {
                { nameof(ArtistDataInfo.CreatedAt), PagedRequest.OrderDescDirection }
            }
        });

        var userTask = UserService.GetAsync(CurrentUser?.UserId() ?? 0);
        var kpiTask = StatisticsService.GetUserKpisAsync(userApiKey, _rangeStart, _rangeEnd, _timeZoneId);
        var playsTask = StatisticsService.GetUserSongPlaysPerDayAsync(userApiKey, _rangeStart, _rangeEnd, _timeZoneId);
        var topSongsTask = StatisticsService.GetUserTopPlayedSongsAsync(userApiKey, _rangeStart, _rangeEnd, _timeZoneId, 10);
        var recentlyPlayedTask = StatisticsService.GetUserRecentlyPlayedSongsAsync(userApiKey, 10);
        var unreadRequestsTask = RequestActivityService.GetUnreadRequestsAsync(CurrentUser?.UserId() ?? 0, new PagedRequest { PageSize = 10 });

        // Check system health for admin users
        Task<bool>? healthCheckTask = null;
        if (CurrentUser?.IsAdmin() == true)
        {
            healthCheckTask = DoctorService.NeedsAttentionAsync();
        }

        var tasksToAwait = new List<Task> { albumLatestTask, artistLatestTask, userTask, kpiTask, playsTask, topSongsTask, recentlyPlayedTask, unreadRequestsTask };
        if (healthCheckTask != null)
        {
            tasksToAwait.Add(healthCheckTask);
        }
        await Task.WhenAll(tasksToAwait);

        _latestAlbums = albumLatestTask.Result.Data.ToArray();
        _latestArtists = artistLatestTask.Result.Data.ToArray();
        _userKpis = kpiTask.Result.Data ?? [];
        _playsPerDay = playsTask.Result.Data ?? [];
        _topSongs = topSongsTask.Result.Data ?? [];
        _recentlyPlayed = recentlyPlayedTask.Result.Data ?? [];
        _unreadRequests = unreadRequestsTask.Result.Data.ToArray();
        _showHealthWarning = healthCheckTask?.Result ?? false;

        if (userTask.Result is { IsSuccess: true, Data: not null })
        {
            _userPins = userTask.Result.Data.Pins.ToArray();
        }

        if (_recentlyPlayed.Length > 0)
        {
            _recentlyPlayedSongs = _recentlyPlayed
                .Where(x => x.ApiKey.HasValue)
                .Select(x =>
                {
                    var parts = x.Extra?.Split('|') ?? [];
                    var albumApiKey = parts.Length > 0 && Guid.TryParse(parts[0], out var albumGuid) ? albumGuid : Guid.Empty;
                    var artistApiKey = parts.Length > 1 && Guid.TryParse(parts[1], out var artistGuid) ? artistGuid : Guid.Empty;
                    var albumName = parts.Length > 2 ? parts[2] : string.Empty;
                    var artistName = parts.Length > 3 ? parts[3] : string.Empty;
                    var songNumber = parts.Length > 4 && int.TryParse(parts[4], out var num) ? num : 0;
                    var duration = parts.Length > 5 && double.TryParse(parts[5], out var dur) ? dur : 0;

                    return new SongDataInfo(
                        x.Id ?? 0,
                        x.ApiKey!.Value,
                        false,
                        x.Label,
                        x.Label.ToNormalizedString() ?? string.Empty,
                        songNumber,
                        LocalDate.MinIsoValue,
                        albumName,
                        albumApiKey,
                        artistName,
                        artistApiKey,
                        0,
                        duration,
                        Instant.MinValue,
                        string.Empty,
                        false,
                        0);
                })
                .ToArray();
        }
    }

}
