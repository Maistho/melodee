@page "/about"
@using System.Globalization
@using System.Runtime.InteropServices
@using NodaTime
@inherits MelodeeComponentBase

@inject IMelodeeConfigurationFactory MelodeeConfigurationFactory
@inject NavigationManager NavigationManager
@inject IAppVersionProvider AppVersionProvider

<PageTitle>About</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.H4">About @_siteTitle</RadzenText>

    <RadzenRow>
      <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenButton Text="API Docs (Swagger OpenAPI)" Icon="description" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Style="margin-top: 0.5rem;" Click="@(() => NavigationManager.NavigateTo("/swagger", forceLoad: true))" />
      </RadzenStack>
    </RadzenRow>

    <RadzenRow>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Overline">Server Time</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">UTC</RadzenText>
                    <RadzenText TextStyle="TextStyle.H6">@_serverNowUtc.InUtc().LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss", CultureInfo.InvariantCulture)</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">Your Time (@CurrentUser?.TimeZoneId())</RadzenText>
                    <RadzenText TextStyle="TextStyle.H6">@(CurrentUser?.FormatInstant(_serverNowUtc) ?? MelodeeConfiguration.DefaultNoValuePlaceHolder)</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard>
                <RadzenStack Gap="0.25rem">
                    <RadzenText TextStyle="TextStyle.Overline">System Information</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">Platform</RadzenText>
                    <RadzenText TextStyle="TextStyle.H6">@RuntimeInformation.FrameworkDescription</RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption">Version</RadzenText>
                    <RadzenText TextStyle="TextStyle.H6">@AppVersionProvider.GetSemVerForDisplay()</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.H6" Text="Server Details"/>
            <RadzenDataGrid TItem="KeyValue"
                            Data="@_serverStats.OrderBy(x => x.Key)"
                            AllowPaging="false"
                            AllowSorting="false"
                            AllowFiltering="true"
                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            Density="Density.Compact">
                <Columns>
                    <RadzenDataGridColumn TItem="KeyValue" Property="Key" Title="Property" Width="320px" />
                    <RadzenDataGridColumn TItem="KeyValue" Title="Value">
                        <Template Context="kv">@((MarkupString)(kv.Value ?? string.Empty))</Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenStack>
    </RadzenCard>

    <RadzenCard>
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.H6" Text="About Melodee"/>
            <RadzenText TextStyle="TextStyle.Body1">
                Melodee is a modern music server system that provides a comprehensive solution for managing and streaming your music collection.
            </RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">
                For more information, visit the <RadzenLink Path="https://github.com/melodee-project" Text="Melodee GitHub Project" Target="_blank" />.
            </RadzenText>
        </RadzenStack>
    </RadzenCard>
</RadzenStack>

@code {

    string _siteTitle = string.Empty;
    Instant _serverNowUtc;
    readonly List<KeyValue> _serverStats = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _serverNowUtc = SystemClock.Instance.GetCurrentInstant();

        var configuration = await MelodeeConfigurationFactory.GetConfigurationAsync();
        _siteTitle = configuration.GetValue<string>(SettingRegistry.OpenSubsonicServerType) ?? string.Empty;

        _serverStats.Add(new KeyValue("Platform", RuntimeInformation.OSDescription));
        _serverStats.Add(new KeyValue("Architecture", RuntimeInformation.OSArchitecture.ToString()));
        _serverStats.Add(new KeyValue(".NET Runtime", RuntimeInformation.FrameworkDescription));
        _serverStats.Add(new KeyValue("Application", "Melodee Music System"));
        _serverStats.Add(new KeyValue("Version", AppVersionProvider.GetSemVerForDisplay()));
        _serverStats.Add(new KeyValue("GitHub", "<a target=\"_blank\" href=\"https://github.com/melodee-project\">melodee-project</a>"));
    }

}
