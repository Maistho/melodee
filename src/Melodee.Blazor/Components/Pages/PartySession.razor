@page "/party/{SessionApiKey:guid}"
@using Melodee.Blazor.Services
@using Melodee.Common.Models.PartyMode
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject PartyModeService PartyModeService
@inject NavigationManager NavigationManager
@inject ILogger<PartySession> Logger
@inject IStringLocalizer<SharedResources> Localizer
@inject IJSRuntime JSRuntime

<div class="party-session-page">
    @if (IsLoading)
    {
        <div class="loading-screen">
            <p>@Localizer["PartyMode.Loading"]</p>
        </div>
    }
    else if (Session != null)
    {
        <div class="party-session-header">
            <div class="session-info">
                <h1>🎉 @Session.Name</h1>
                <div class="session-status">
                    <span class="status-indicator @(Session.Status == "Active" ? "active" : "ended")"></span>
                    @Session.Status
                    @if (IsEndpointOffline)
                    {
                        <span class="offline-badge">@Localizer["PartyMode.Endpoint.Offline"]</span>
                    }
                </div>
            </div>
            <div class="session-actions">
                <button class="action-btn" @onclick="CopyInviteLink" title="@Localizer["PartyMode.CopyInviteLink"]">
                    📋
                </button>
                <button class="action-btn leave-btn" @onclick="LeaveSession" title="@Localizer["PartyMode.LeaveSession"]">
                    🚪
                </button>
            </div>
        </div>

        @if (IsEndpointOffline)
        {
            <div class="endpoint-offline-banner">
                <p>⚠️ @Localizer["PartyMode.Endpoint.OfflineMessage"]</p>
            </div>
        }
        else if (!HasActiveEndpoint)
        {
            <div class="no-endpoint-banner">
                <p>🎧 @Localizer["PartyMode.Endpoint.NoEndpointMessage"]</p>
                <button class="btn btn-primary" @onclick="ShowEndpointSelector">
                    @Localizer["PartyMode.Endpoint.Select"]
                </button>
            </div>
        }

        <div class="party-session-content">
            <div class="party-main">
                <PartyPlayer SessionApiKey="SessionApiKey" 
                            OnTrackChanged="OnTrackChanged"
                            Capabilities="EndpointCapabilities" />
            </div>
            
            <div class="party-sidebar">
                @if (ShowEndpointSelectorPanel)
                {
                    <div class="endpoint-selector-panel">
                        <div class="panel-header">
                            <h3>@Localizer["PartyMode.Endpoint.SelectTitle"]</h3>
                            <button class="close-btn" @onclick="HideEndpointSelector">✕</button>
                        </div>
                         <PartySessionEndpointSelector SessionApiKey="SessionApiKey"
                                         OnEndpointChanged="OnEndpointChanged"
                                         CanDetach="CanDetachEndpoint" />
                    </div>
                }
                else
                {
                    @if (ActiveEndpointName != null)
                    {
                        <div class="active-endpoint-info">
                            <h4>@Localizer["PartyMode.Endpoint.Active"]</h4>
                            <div class="endpoint-card">
                                <span class="endpoint-icon">🎵</span>
                                <span class="endpoint-name">@ActiveEndpointName</span>
                                @if (IsCurrentUserEndpointOwner)
                                {
                                    <button class="btn btn-sm btn-secondary" @onclick="ShowEndpointSelector">
                                        @Localizer["PartyMode.Endpoint.Change"]
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }

                <PartyQueue SessionApiKey="SessionApiKey" 
                            OnQueueChanged="OnQueueChanged"
                            OnItemSelected="OnItemSelected"
                            CurrentItemApiKey="CurrentItemApiKey"
                            IsQueueLocked="IsQueueLocked"
                            CanModifyQueue="CanModifyQueue" />
                
                <div class="participants-section">
                    <h3>👥 @Localizer["PartyMode.Participants"] (@Participants.Count)</h3>
                    <div class="participants-list">
                        @foreach (var participant in Participants)
                        {
                            <div class="participant">
                                <span class="participant-avatar">👤</span>
                                <span class="participant-name">@GetUserDisplayName(participant)</span>
                                <span class="participant-role" title="@participant.Role">@GetRoleIcon(participant.Role)</span>
                                @if (IsOwner && participant.UserId != CurrentUserId)
                                {
                                    <div class="participant-actions">
                                        <button class="btn btn-sm" @onclick="() => OpenParticipantMenu(participant)" title="@Localizer["PartyMode.Moderation.Manage"]">
                                            ⋮
                                        </button>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="error-screen">
            <p>@Localizer["PartyMode.SessionNotFound"]</p>
            <button class="btn btn-primary" @onclick="GoHome">@Localizer["PartyMode.GoHome"]</button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid SessionApiKey { get; set; }

    private PartySessionDto? Session { get; set; }
    private List<PartySessionParticipantDto> Participants { get; set; } = new();
    private List<SessionEndpointDto> Endpoints { get; set; } = new();
    private Guid? CurrentItemApiKey { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool ShowEndpointSelectorPanel { get; set; }
    private bool HasActiveEndpoint { get; set; }
    private bool IsEndpointOffline { get; set; }
    private bool IsQueueLocked { get; set; }
    private bool CanModifyQueue { get; set; }
    private bool IsOwner { get; set; }
    private bool IsCurrentUserEndpointOwner { get; set; }
    private bool CanDetachEndpoint { get; set; }
    private string? ActiveEndpointName { get; set; }
    private int CurrentUserId { get; set; }
    private PartySessionEndpointCapabilities? EndpointCapabilities { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadSession();
    }

    private async Task LoadSession()
    {
        try
        {
            IsLoading = true;
            
            var sessionResult = await PartyModeService.GetSessionAsync(SessionApiKey);
            if (sessionResult?.IsSuccess == true && sessionResult.Data != null)
            {
                Session = sessionResult.Data;
                await LoadParticipants();
                await LoadEndpoints();
            }
            else
            {
                Session = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading party session {ApiKey}", SessionApiKey);
            Session = null;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadParticipants()
    {
        try
        {
            var result = await PartyModeService.GetParticipantsAsync(SessionApiKey);
            if (result?.IsSuccess == true && result.Data != null)
            {
                Participants = result.Data.ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading participants");
        }
    }

    private async Task LoadEndpoints()
    {
        try
        {
            var result = await PartyModeService.GetEndpointsForSessionAsync(SessionApiKey);
            if (result?.IsSuccess == true && result.Data != null)
            {
                Endpoints = result.Data.ToList();
                var activeEndpoint = Endpoints.FirstOrDefault(e => e.IsActive);
                HasActiveEndpoint = activeEndpoint != null;
                IsEndpointOffline = activeEndpoint?.IsStale ?? false;
                ActiveEndpointName = activeEndpoint?.Name;
                IsCurrentUserEndpointOwner = activeEndpoint?.IsOwner ?? false;
                CanDetachEndpoint = activeEndpoint?.IsOwner ?? false;
                EndpointCapabilities = ParseCapabilities(activeEndpoint?.CapabilitiesJson);
            }
            else
            {
                HasActiveEndpoint = false;
                IsEndpointOffline = false;
                EndpointCapabilities = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading endpoints");
        }
    }

    private static PartySessionEndpointCapabilities? ParseCapabilities(string? capabilitiesJson)
    {
        if (string.IsNullOrEmpty(capabilitiesJson))
        {
            return null;
        }

        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<PartySessionEndpointCapabilities>(capabilitiesJson);
        }
        catch
        {
            return null;
        }
    }

    private void ShowEndpointSelector()
    {
        ShowEndpointSelectorPanel = true;
    }

    private void HideEndpointSelector()
    {
        ShowEndpointSelectorPanel = false;
    }

    private async Task OnEndpointChanged()
    {
        ShowEndpointSelectorPanel = false;
        await LoadEndpoints();
    }

    private async Task OnTrackChanged(PartyPlayer.TrackInfo track)
    {
        // Could update current item if needed
    }

    private async Task OnQueueChanged(IEnumerable<PartyQueueItemDto> queue)
    {
        // Queue updated - could show notification
    }

    private async Task OnItemSelected(PartyQueueItemDto item)
    {
        CurrentItemApiKey = item.ApiKey;
        // Could trigger playback of this item
    }

    private void OpenParticipantMenu(PartySessionParticipantDto participant)
    {
        // Open moderation menu for participant
    }

    private async Task CopyInviteLink()
    {
        var inviteUrl = $"{NavigationManager.BaseUri}party/{SessionApiKey}";
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", inviteUrl);
        // Could show toast notification
    }

    private async Task LeaveSession()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", Localizer["PartyMode.LeaveConfirm"].Value);
        if (confirmed)
        {
            await PartyModeService.LeaveSessionAsync(SessionApiKey);
            NavigationManager.NavigateTo("/");
        }
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private static string GetUserDisplayName(PartySessionParticipantDto participant)
    {
        return $"User {participant.UserId}";
    }

    private static string GetRoleIcon(string role)
    {
        return role switch
        {
            "Owner" => "👑",
            "DJ" => "🎧",
            _ => "🎵"
        };
    }
}
