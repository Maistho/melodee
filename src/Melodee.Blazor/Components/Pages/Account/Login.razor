@page "/account/login"
@using System.Diagnostics
@using System.Net.Http.Json
@using System.Text.Json
@using Melodee.Common.Data.Models.Extensions
@using Melodee.Common.Services.Security
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Options

@inject UserService UserService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager
@inject IAuthService AuthService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject LibraryService LibraryService
@inject IJSRuntime JsRuntime
@inject IOptions<GoogleAuthOptions> GoogleAuthOptions
@inject IHttpClientFactory HttpClientFactory
@inject ILocalizationService LocalizationService

@implements IAsyncDisposable

@attribute [AllowAnonymous]

@if (_isLoading)
{
    <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" Value="100" ShowValue="false"
                               Mode="ProgressBarMode.Indeterminate"/>
}
else
{
    <RadzenRow Gap="0" class="rz-my-12 rz-mx-auto rz-border-radius-6 rz-shadow-10"
               Style="width: 100%; max-width: 800px; overflow: hidden;">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard class="rz-shadow-0 rz-border-radius-0 rz-text-align-center rz-p-12"
                        Style="height: 100%; background: var(--rz-primary-light) no-repeat 100% 70% fixed url('data:image/svg+xml;base64,')">
                <RadzenText TextStyle="TextStyle.DisplayH3" TagName="TagName.H4" class="rz-color-white rz-mb-6">
                    @LocalizationService.Localize("Auth.Welcome")
                </RadzenText>
                <RadzenImage Path="images/melodee-logo-small.png" Style="width:100px;" AlternateText="melodee"/>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard class="rz-shadow-0 rz-border-radius-0 rz-p-12">
                <RadzenTemplateForm Data=@("Login")>
                    <RadzenLogin AllowRegister="true"
                                 AllowResetPassword="true"
                                 Username=@_userName
                                 Password=@_password
                                 AllowRememberMe="false"
                                 Login=@(args => OnLogin(args, "Login"))
                                 ResetPassword=@(args => OnResetPassword(args, "Login"))
                                 Register=@(args => OnRegister("Login"))/>
                </RadzenTemplateForm>
                
                @if (_googleAuthEnabled)
                {
                    <RadzenStack Gap="1rem" class="rz-mt-4">
                        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.5rem">
                            <RadzenColumn Size="5"><hr style="border-top: 1px solid var(--rz-text-disabled-color);"/></RadzenColumn>
                            <RadzenColumn Size="2" class="rz-text-align-center">
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-disabled-color);">@LocalizationService.Localize("Auth.Or")</RadzenText>
                            </RadzenColumn>
                            <RadzenColumn Size="5"><hr style="border-top: 1px solid var(--rz-text-disabled-color);"/></RadzenColumn>
                        </RadzenRow>
                        
                        <RadzenButton Click="@OnGoogleSignInClick" 
                                      ButtonStyle="ButtonStyle.Light" 
                                      Variant="Variant.Outlined"
                                      Style="width: 100%; justify-content: center;"
                                      Disabled="@_isGoogleSigningIn"
                                       aria-label="@LocalizationService.Localize("Auth.ContinueWithGoogle")">
                            @if (_isGoogleSigningIn)
                            {
                                <RadzenProgressBarCircular ProgressBarStyle="ProgressBarStyle.Primary" 
                                                           Value="100" 
                                                           ShowValue="false"
                                                           Mode="ProgressBarMode.Indeterminate" 
                                                           Size="ProgressBarCircularSize.Small"
                                                           Style="margin-right: 8px;"/>
                                <span>@LocalizationService.Localize("Auth.SigningIn")</span>
                            }
                            else
                            {
                                <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" style="margin-right: 8px;">
                                    <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
                                    <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
                                    <path fill="#FBBC05" d="M3.964 10.71c-.18-.54-.282-1.117-.282-1.71s.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
                                    <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
                                </svg>
                                <span>@LocalizationService.Localize("Auth.ContinueWithGoogle")</span>
                            }
                        </RadzenButton>
                        
                        @if (!string.IsNullOrEmpty(_googleAuthError))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="true" Close="@(() => _googleAuthError = null)">
                                @_googleAuthError
                            </RadzenAlert>
                        }
                        
                        <div id="google-signin-button-fallback" style="display: none;"></div>
                    </RadzenStack>
                }
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
}

@code {
    private readonly string _userName = string.Empty;
    private readonly string _password = string.Empty;
    private bool _isLoading = true;
    private bool _googleAuthEnabled;
    private bool _isGoogleSigningIn;
    private string? _googleAuthError;
    private DotNetObjectReference<Login>? _dotNetRef;
    private bool _googleInitialized;

    [SupplyParameterFromQuery] [Parameter] public string? ReturnUrl { get; set; }

    void ShowNotification(string title, string message)
    {
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Warning,
            Duration = 5000,
            SummaryContent = ns => @<RadzenText TextStyle="TextStyle.H6">@title</RadzenText>,
            DetailContent = ns => @<RadzenStack>
                                      <RadzenText TextStyle="TextStyle.Subtitle1">@message</RadzenText>
                                      <RadzenButton Text="@L("Actions.Close")" Click="@(args => ns.Messages.Clear())"></RadzenButton>
                                   </RadzenStack>
        });
    }
    
    string L(string key, params object[] args) => LocalizationService.Localize(key, args);
    
    void ShowSuccessNotification(string title, string message)
    {
        NotificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Success,
            Duration = 3000,
            SummaryContent = _ => @<RadzenText TextStyle="TextStyle.H6">@title</RadzenText>,
            DetailContent = _ => @<RadzenText TextStyle="TextStyle.Subtitle1">@message</RadzenText>
        });
    }

    protected override void OnInitialized()
    {
        _googleAuthEnabled = GoogleAuthOptions.Value.Enabled && !string.IsNullOrEmpty(GoogleAuthOptions.Value.ClientId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (string.IsNullOrEmpty(ReturnUrl))
        {
            var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
            if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("returnUrl", out var url))
            {
                ReturnUrl = url;
            }
        }

        if (firstRender && await AuthService.EnsureAuthenticatedAsync())
        {
            NavigationManager.NavigateTo(ReturnUrl ?? "/");
            return;
        }

        _isLoading = false;
        
        // Initialize Google Sign-In if enabled
        if (firstRender && _googleAuthEnabled && !_googleInitialized)
        {
            await InitializeGoogleSignInAsync();
        }
        
        StateHasChanged();
    }

    private async Task InitializeGoogleSignInAsync()
    {
        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("initializeGoogleSignIn", GoogleAuthOptions.Value.ClientId, _dotNetRef);
            _googleInitialized = true;
        }
        catch (Exception ex)
        {
            Trace.WriteLine($"Failed to initialize Google Sign-In: {ex.Message}");
            _googleAuthError = L("Auth.GoogleSignInUnavailable");
        }
    }

    private async Task OnGoogleSignInClick()
    {
        if (_isGoogleSigningIn) return;
        
        _isGoogleSigningIn = true;
        _googleAuthError = null;
        StateHasChanged();
        
        try
        {
            await JsRuntime.InvokeVoidAsync("promptGoogleSignIn");
        }
        catch (Exception ex)
        {
            Trace.WriteLine($"Error prompting Google Sign-In: {ex.Message}");
            _googleAuthError = L("Auth.FailedToOpenGoogleSignIn");
            _isGoogleSigningIn = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnGoogleSignInSuccess(string idToken)
    {
        try
        {
            _isGoogleSigningIn = true;
            StateHasChanged();
            
            // Exchange the Google ID token for Melodee tokens
            var httpClient = HttpClientFactory.CreateClient("MelodeeApi");
            var response = await httpClient.PostAsJsonAsync("/api/v1/auth/google", new { idToken });
            
            if (response.IsSuccessStatusCode)
            {
                var authResponse = await response.Content.ReadFromJsonAsync<GoogleAuthResponse>();
                if (authResponse?.User != null)
                {
                    var userImageLibrary = await LibraryService.GetUserImagesLibraryAsync();
                    var config = await ConfigurationFactory.GetConfigurationAsync();
                    
                    // Create claims principal from the response
                    var user = await UserService.GetByApiKeyAsync(Guid.Parse(authResponse.User.ApiKey!));
                    if (user.IsSuccess && user.Data != null)
                    {
                        await AuthService.Login(user.Data.ToUserInfo().ToClaimsPrincipal(config, userImageLibrary.Data?.Path ?? string.Empty));
                        ShowSuccessNotification(L("Auth.Welcome"), L("Auth.SignedInAs", authResponse.User.UserName ?? string.Empty));
                        NavigationManager.NavigateTo(ReturnUrl ?? "/");
                        return;
                    }
                }
                
                _googleAuthError = L("Auth.FailedToCompleteSignIn");
            }
            else
            {
                var errorResponse = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                _googleAuthError = MapGoogleAuthError(errorResponse?.Code, errorResponse?.Message);
            }
        }
        catch (Exception ex)
        {
            Trace.WriteLine($"Error during Google Sign-In: {ex.Message}");
            _googleAuthError = L("Auth.SignInErrorTryAgain");
        }
        finally
        {
            _isGoogleSigningIn = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnGoogleSignInError(string error)
    {
        _googleAuthError = error;
        _isGoogleSigningIn = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnGoogleSignInCancelled()
    {
        _isGoogleSigningIn = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private string MapGoogleAuthError(string? errorCode, string? message)
    {
        return errorCode switch
        {
            "invalid_google_token" => L("Auth.InvalidGoogleCredentials"),
            "expired_google_token" => L("Auth.GoogleSessionExpired"),
            "google_account_not_linked" => L("Auth.GoogleAccountNotLinked"),
            "signup_disabled" => L("Auth.SignupDisabled"),
            "forbidden_tenant" => L("Auth.ForbiddenTenant"),
            "account_disabled" => L("Auth.AccountDisabled"),
            _ => message ?? L("Auth.GoogleSignInError")
        };
    }

    private async Task OnLogin(LoginArgs args, string name)
    {
        _isLoading = true;

        try
        {
            var user = await UserService.LoginUserByUsernameAsync(args.Username, args.Password);
            if (user.Data == null || !user.IsSuccess)
            {
                ShowNotification(L("Auth.InvalidEmailOrPassword"), L("Auth.UnableToLogin"));
                return;
            }

            var userImageLibrary = await LibraryService.GetUserImagesLibraryAsync();
            await AuthService.Login(user.Data.ToUserInfo().ToClaimsPrincipal(await ConfigurationFactory.GetConfigurationAsync(), userImageLibrary.Data.Path));
            NavigationManager.NavigateTo(ReturnUrl ?? "/");
        }
        catch (Exception e)
        {
            Trace.WriteLine(e);
        }
        finally
        {
            _isLoading = false;
        }
    }

    void OnRegister(string name)
    {
        NavigationManager.NavigateTo("/account/register");
    }

    void OnResetPassword(string value, string name)
    {
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_googleInitialized)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("cleanupGoogleSignIn");
            }
            catch
            {
                // Ignore errors during disposal
            }
        }
        _dotNetRef?.Dispose();
    }

    // Response models for API calls
    private class GoogleAuthResponse
    {
        public UserModel? User { get; init; }
        public string? Token { get; init; }
        public string? RefreshToken { get; init; }
    }

    private class UserModel
    {
        public string? UserName { get; set; }
        public string? Email { get; set; }
        public string? ApiKey { get; set; }
    }

    private class ApiErrorResponse
    {
        public string? Code { get; init; }
        public string? Message { get; init; }
    }
}

