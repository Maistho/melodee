@page "/account/profile"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using Melodee.Common.Data.Models.Extensions
@using Melodee.Common.Services.Security
@using Microsoft.Extensions.Options
@using NodaTime
@inherits MelodeeComponentBase
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject UserService UserService
@inject LibraryService LibraryService
@inject IAuthService AuthService
@inject IMelodeeConfigurationFactory ConfigurationFactory
@inject IOptions<GoogleAuthOptions> GoogleAuthOptions
@inject IJSRuntime JsRuntime
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject ILocalizationService ProfileLocalizationService

@implements IAsyncDisposable

<RadzenCard class="profile-card">
    <div class="profile-container">
        <h1 class="rz-text-title">@L("Profile.YourProfile")</h1>

        <div class="profile-grid">
            <div class="profile-image-section">
                <div class="profile-image-container">
                    @if (_newSelectedProfileImage != null)
                    {
                        <RadzenImage Path="@_newSelectedProfileImage.ImageBase64"
                                     Style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%;"/>
                    }
                    else if (!string.IsNullOrEmpty(UserProfile.ProfilePicturePath))
                    {
                        <RadzenImage Path="@(UserProfile.ProfilePicturePath + $"?v={DateTime.Now.Ticks}")"
                                     Style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%;"/>
                    }
                    else
                    {
                        <RadzenIcon Icon="account_circle" IconStyle="IconStyle.Primary" Style="font-size: 8rem;"/>
                    }
                </div>

                <RadzenButton
                    Text="@L("Profile.ChangeProfilePicture")"
                    class="rz-my-2"
                    Icon="photo_camera"
                    ButtonStyle="ButtonStyle.Secondary"
                    Click="@OpenFileUploadDialog"/>
            </div>

            <div class="profile-info-section">
                <RadzenTemplateForm TItem="UserProfileModel" Data="@UserProfile" Submit="@SaveProfileAsync">
                    <RadzenStack Gap="1rem">
                        <RadzenFieldset Text="@L("Profile.ProfileInformation")">
                            <RadzenStack Gap="1rem">
                                <RadzenFormField Text="@L("Profile.Username")" Variant="Variant.Outlined">
                                    <RadzenTextBox @bind-Value="@UserProfile.Username" Name="Username"/>
                                    <RadzenRequiredValidator Text="@L("Profile.UsernameRequired")" Component="Username"/>
                                </RadzenFormField>

                                <RadzenFormField Text="@L("Profile.Email")" Variant="Variant.Outlined">
                                    <RadzenTextBox @bind-Value="@UserProfile.Email" Name="Email"/>
                                    <RadzenRequiredValidator Text="@L("Profile.EmailRequired")" Component="Email"/>
                                    <RadzenEmailValidator Text="@L("Profile.EmailInvalid")" Component="Email"/>
                                </RadzenFormField>

                                <RadzenFormField Text="@L("Profile.Bio")" Variant="Variant.Outlined">
                                    <RadzenTextArea @bind-Value="@UserProfile.Bio" Name="Bio" Rows="4" MaxLength="500"/>
                                </RadzenFormField>

                                <RadzenFormField Text="@L("Profile.TimeZone")" Variant="Variant.Outlined">
                                    <RadzenDropDown @bind-Value="@UserProfile.TimeZoneId"
                                                    Name="TimeZoneId"
                                                    Data="@_timeZoneIds"
                                                    AllowFiltering="true"
                                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                    Style="width: 100%"/>
                                    <RadzenText TextStyle="TextStyle.Caption">@L("Profile.DefaultsToUTC")</RadzenText>
                                </RadzenFormField>

                                <RadzenFormField Text="@L("Profile.Language")" Variant="Variant.Outlined">
                                    <RadzenDropDown @bind-Value="@UserProfile.PreferredLanguage"
                                                    Name="PreferredLanguage"
                                                    Data="@ProfileLocalizationService.SupportedCultures"
                                                    TextProperty="DisplayName"
                                                    ValueProperty="Name"
                                                    AllowClear="true"
                                                    Placeholder="@L("Profile.LanguageDefault")"
                                                    Style="width: 100%"/>
                                    <RadzenText TextStyle="TextStyle.Caption">@L("Profile.LanguageHelp")</RadzenText>
                                </RadzenFormField>
                            </RadzenStack>
                        </RadzenFieldset>

                        <RadzenButton Text="@L("Profile.SaveChanges")"
                                      Icon="save"
                                      ButtonStyle="ButtonStyle.Primary"
                                      ButtonType="ButtonType.Submit"
                                      IsBusy="@_isSaving"
                                      BusyText="@L("Profile.Saving")"/>
                    </RadzenStack>
                </RadzenTemplateForm>
                
                @if (_googleAuthEnabled)
                {
                    <RadzenFieldset Text="@L("Profile.LinkedAccounts")" class="rz-mt-4">
                        <RadzenStack Gap="1rem">
                            <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenColumn>
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <svg width="24" height="24" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
                                            <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
                                            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
                                            <path fill="#FBBC05" d="M3.964 10.71c-.18-.54-.282-1.117-.282-1.71s.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
                                            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
                                        </svg>
                                        <RadzenText TextStyle="TextStyle.Body1">@L("Profile.Google")</RadzenText>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn>
                                    @if (_isGoogleLinked)
                                    {
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                            <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="@L("Profile.Linked")" />
                                            @if (!string.IsNullOrEmpty(_linkedGoogleEmail))
                                            {
                                                <RadzenText TextStyle="TextStyle.Caption">@_linkedGoogleEmail</RadzenText>
                                            }
                                            <RadzenButton Text="@L("Profile.Unlink")"
                                                          ButtonStyle="ButtonStyle.Danger"
                                                          Variant="Variant.Outlined"
                                                          Size="ButtonSize.Small"
                                                          Click="@OnUnlinkGoogleClick"
                                                          IsBusy="@_isUnlinkingGoogle"
                                                          BusyText="@L("Profile.Unlinking")"
                                                          aria-label="Unlink Google account"/>
                                        </RadzenStack>
                                    }
                                    else
                                    {
                                        <RadzenButton Text="@L("Profile.LinkGoogleAccount")"
                                                      ButtonStyle="ButtonStyle.Secondary"
                                                      Variant="Variant.Outlined"
                                                      Size="ButtonSize.Small"
                                                      Click="@OnLinkGoogleClick"
                                                      IsBusy="@_isLinkingGoogle"
                                                      BusyText="@L("Profile.Linking")"
                                                      aria-label="Link Google account"/>
                                    }
                                </RadzenColumn>
                            </RadzenRow>
                            
                            @if (!string.IsNullOrEmpty(_googleLinkError))
                            {
                                <RadzenAlert AlertStyle="AlertStyle.Danger" Shade="Shade.Lighter" AllowClose="true" Close="@(() => _googleLinkError = null)">
                                    @_googleLinkError
                                </RadzenAlert>
                            }
                            
                            @if (!string.IsNullOrEmpty(_googleLinkSuccess))
                            {
                                <RadzenAlert AlertStyle="AlertStyle.Success" Shade="Shade.Lighter" AllowClose="true" Close="@(() => _googleLinkSuccess = null)">
                                    @_googleLinkSuccess
                                </RadzenAlert>
                            }
                        </RadzenStack>
                    </RadzenFieldset>
                }
            </div>
        </div>
    </div>
</RadzenCard>

@code {
    private string[] _timeZoneIds = [];
    private UserProfileModel UserProfile { get; set; } = new();
    private bool _isSaving;
    private string? _errorMessage;
    private ImageSearchResult? _newSelectedProfileImage;
    
    // Google linking state
    private bool _googleAuthEnabled;
    private bool _isGoogleLinked;
    private string? _linkedGoogleEmail;
    private bool _isLinkingGoogle;
    private bool _isUnlinkingGoogle;
    private string? _googleLinkError;
    private string? _googleLinkSuccess;
    private DotNetObjectReference<Profile>? _dotNetRef;
    private bool _googleInitialized;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        _timeZoneIds = DateTimeZoneProviders.Tzdb.Ids.OrderBy(x => x).ToArray();
        _googleAuthEnabled = GoogleAuthOptions.Value.Enabled && !string.IsNullOrEmpty(GoogleAuthOptions.Value.ClientId);

        var user = await UserService.GetAsync(CurrentUser!.UserId());
        UserProfile = new UserProfileModel
        {
            Username = user.Data!.UserName,
            Email = user.Data!.Email,
            Bio = user.Data!.Description ?? string.Empty,
            TimeZoneId = string.IsNullOrWhiteSpace(user.Data!.TimeZoneId) ? "UTC" : user.Data.TimeZoneId,
            PreferredLanguage = user.Data!.PreferredLanguage,
            ProfilePicturePath = $"/images/{user.Data.ToApiKey()}/{MelodeeConfiguration.DefaultThumbNailSize}"
        };
        
        // Check if Google is linked
        if (_googleAuthEnabled)
        {
            await LoadGoogleLinkStatusAsync();
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        
        // Initialize Google Sign-In for linking if enabled and not already initialized
        if (firstRender && _googleAuthEnabled && !_googleInitialized)
        {
            await InitializeGoogleSignInAsync();
        }
    }

    private async Task LoadGoogleLinkStatusAsync()
    {
        try
        {
            var linkedProviders = await UserService.GetLinkedProvidersAsync(CurrentUser!.UserId());
            if (linkedProviders.IsSuccess && linkedProviders.Data != null)
            {
                var googleLink = linkedProviders.Data.FirstOrDefault(p => p.Provider == "Google");
                _isGoogleLinked = googleLink != null;
                _linkedGoogleEmail = googleLink?.Email;
            }
        }
        catch
        {
            // Ignore errors loading link status
        }
    }

    private async Task InitializeGoogleSignInAsync()
    {
        try
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JsRuntime.InvokeVoidAsync("initializeGoogleSignIn", GoogleAuthOptions.Value.ClientId, _dotNetRef);
            _googleInitialized = true;
        }
        catch
        {
            _googleLinkError = L("Profile.GoogleSignInUnavailable");
        }
    }

    private async Task OnLinkGoogleClick()
    {
        if (_isLinkingGoogle) return;
        
        _isLinkingGoogle = true;
        _googleLinkError = null;
        _googleLinkSuccess = null;
        StateHasChanged();
        
        try
        {
            await JsRuntime.InvokeVoidAsync("promptGoogleSignIn");
        }
        catch
        {
            _googleLinkError = L("Profile.GoogleSignInOpenFailed");
            _isLinkingGoogle = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnGoogleSignInSuccess(string idToken)
    {
        try
        {
            _isLinkingGoogle = true;
            StateHasChanged();
            
            // Call the link endpoint
            var httpClient = HttpClientFactory.CreateClient("MelodeeApi");
            var response = await httpClient.PostAsJsonAsync("/api/v1/Users/me/link/google", new { idToken });
            
            if (response.IsSuccessStatusCode)
            {
                _isGoogleLinked = true;
                _googleLinkSuccess = L("Profile.GoogleLinkedSuccess");
                await LoadGoogleLinkStatusAsync();
            }
            else
            {
                var errorResponse = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                _googleLinkError = errorResponse?.Message ?? L("Profile.GoogleLinkFailed");
            }
        }
        catch
        {
            _googleLinkError = L("Profile.LinkingError");
        }
        finally
        {
            _isLinkingGoogle = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task OnGoogleSignInError(string error)
    {
        _googleLinkError = error;
        _isLinkingGoogle = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnGoogleSignInCancelled()
    {
        _isLinkingGoogle = false;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnUnlinkGoogleClick()
    {
        if (_isUnlinkingGoogle) return;
        
        var confirmed = await DialogService.Confirm(
            L("Profile.UnlinkConfirmation"),
            L("Profile.UnlinkGoogleAccount"),
            new ConfirmOptions { OkButtonText = L("Profile.Unlink"), CancelButtonText = L("Actions.Cancel") });
        
        if (confirmed != true) return;
        
        _isUnlinkingGoogle = true;
        _googleLinkError = null;
        _googleLinkSuccess = null;
        StateHasChanged();
        
        try
        {
            var httpClient = HttpClientFactory.CreateClient("MelodeeApi");
            var response = await httpClient.DeleteAsync("/api/v1/Users/me/link/google");
            
            if (response.IsSuccessStatusCode)
            {
                _isGoogleLinked = false;
                _linkedGoogleEmail = null;
                _googleLinkSuccess = L("Profile.GoogleUnlinkedSuccess");
            }
            else
            {
                var errorResponse = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
                _googleLinkError = errorResponse?.Message ?? L("Profile.GoogleUnlinkFailed");
            }
        }
        catch
        {
            _googleLinkError = L("Profile.UnlinkingError");
        }
        finally
        {
            _isUnlinkingGoogle = false;
            StateHasChanged();
        }
    }

    private async Task OpenFileUploadDialog()
    {
        await DialogService.OpenAsync(L("Profile.ProfileImage"), ds =>
            @<ImageSearchUpload
                SearchType="ImageSearchType.Profile"
                OnUpdateCallback="ProfileImageSelected"
                SearchValues="[]"/>);
    }

    private void ProfileImageSelected(ImageSearchResult? selectedImageSearchResult)
    {
        DialogService.Close();
        _newSelectedProfileImage = selectedImageSearchResult;
    }

    private async Task SaveProfileAsync(UserProfileModel model)
    {
        try
        {
            _isSaving = true;

            var user = await UserService.GetAsync(CurrentUser!.UserId());

            var tz = string.IsNullOrWhiteSpace(model.TimeZoneId) ? "UTC" : model.TimeZoneId.Trim();
            if (DateTimeZoneProviders.Tzdb.GetZoneOrNull(tz) == null)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = L("Profile.InvalidTimeZone"),
                    Detail = L("Profile.InvalidTimeZoneDetail", tz),
                    Duration = 5000
                });
                return;
            }

            var originalLanguage = user.Data!.PreferredLanguage;
            var newLanguage = string.IsNullOrWhiteSpace(UserProfile.PreferredLanguage) ? null : UserProfile.PreferredLanguage;
            var languageChanged = originalLanguage != newLanguage;

            user.Data!.UserName = UserProfile.Username;
            user.Data!.Email = UserProfile.Email;
            user.Data!.Description = UserProfile.Bio;
            user.Data!.TimeZoneId = tz;
            user.Data!.PreferredLanguage = newLanguage;

            var saveResult = await UserService.UpdateAsync(user.Data, user.Data);
            if (!saveResult.IsSuccess || !saveResult.Data)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = L("Profile.UpdateFailed"),
                    Detail = string.Join("; ", saveResult.Messages ?? []),
                    Duration = 5000
                });
                return;
            }

            // Ensure server-side cache is refreshed and UI will re-read the updated timezone on next load.
            await UserService.GetAsync(user.Data.Id);

            var configuration = await ConfigurationFactory.GetConfigurationAsync();
            var userImageLibrary = await LibraryService.GetUserImagesLibraryAsync();
            await AuthService.Login(user.Data.ToUserInfo().ToClaimsPrincipal(configuration, userImageLibrary.Data.Path));

            if (_newSelectedProfileImage?.ImageBytes != null)
            {
                await UserService.SaveProfileImageAsync(user.Data.Id, _newSelectedProfileImage.ImageBytes);
            }

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = L("Profile.ProfileUpdated"),
                Detail = L("Profile.ProfileUpdatedDetail"),
                Duration = 5000
            });

            if (languageChanged && !string.IsNullOrWhiteSpace(UserProfile.PreferredLanguage))
            {
                var cultureCode = UserProfile.PreferredLanguage;
                var cookieValue = $"c={cultureCode}|uic={cultureCode}";
                await JsRuntime.InvokeVoidAsync("eval", 
                    $"document.cookie = '.AspNetCore.Culture={Uri.EscapeDataString(cookieValue)}; path=/; max-age=31536000; samesite=lax'");
                await ProfileLocalizationService.SetCultureAsync(cultureCode);
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            }
            else if (languageChanged && string.IsNullOrWhiteSpace(UserProfile.PreferredLanguage))
            {
                var cookieValue = "c=en-US|uic=en-US";
                await JsRuntime.InvokeVoidAsync("eval", 
                    $"document.cookie = '.AspNetCore.Culture={Uri.EscapeDataString(cookieValue)}; path=/; max-age=31536000; samesite=lax'");
                await ProfileLocalizationService.SetCultureAsync("en-US");
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error saving profile: {ex.Message}";

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = L("Profile.UpdateFailed"),
                Detail = _errorMessage,
                Duration = 5000
            });
        }
        finally
        {
            _isSaving = false;
        }
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_googleInitialized)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("cleanupGoogleSignIn");
            }
            catch
            {
                // Ignore errors during disposal
            }
        }
        _dotNetRef?.Dispose();
    }

    // User profile model
    public class UserProfileModel
    {
        [Required(ErrorMessage = "Username is required")]
        [StringLength(100, MinimumLength = 3, ErrorMessage = "Username must be between 3 and 100 characters")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [StringLength(500, ErrorMessage = "Bio cannot exceed 500 characters")]
        public string Bio { get; set; } = string.Empty;

        [Required(ErrorMessage = "Time zone is required")]
        public string TimeZoneId { get; set; } = "UTC";

        [StringLength(10, ErrorMessage = "Language code cannot exceed 10 characters")]
        public string? PreferredLanguage { get; set; }

        public string? ProfilePicturePath { get; init; }
    }

    private class ApiErrorResponse
    {
        public string? Code { get; init; }
        public string? Message { get; init; }
    }
}
